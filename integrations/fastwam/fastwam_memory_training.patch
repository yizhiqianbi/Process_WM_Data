index 0000000..99937e8
--- /dev/null
+++ b/src/fastwam/utils/eval_visualization.py
@@ -0,0 +1,216 @@
+from __future__ import annotations
+
+from typing import Sequence
+
+import numpy as np
+import torch
+from PIL import Image, ImageDraw
+
+
+_ACTION_SLOT_LABELS = {
+    13: "R GRIP",
+    21: "R J1",
+    22: "R J2",
+    23: "R J3",
+    24: "R J4",
+    25: "R J5",
+    26: "R J6",
+    27: "R J7",
+}
+
+
+def _as_td(value: torch.Tensor, name: str) -> torch.Tensor:
+    value = value.detach().to(device="cpu", dtype=torch.float32)
+    if value.ndim == 3 and value.shape[0] == 1:
+        value = value[0]
+    if value.ndim != 2:
+        raise ValueError(f"{name} must be [T,D] or [1,T,D], got {tuple(value.shape)}")
+    return value
+
+
+def labeled_video_frames(
+    video: torch.Tensor, label: str, *, label_height: int = 32
+) -> list[Image.Image]:
+    if video.ndim != 4 or video.shape[0] != 3:
+        raise ValueError(f"video must be [3,T,H,W], got {tuple(video.shape)}")
+    if label_height <= 0:
+        raise ValueError("label_height must be positive")
+    video = video.detach().to(device="cpu", dtype=torch.float32).clamp(0.0, 1.0)
+    frames: list[Image.Image] = []
+    for time_index in range(video.shape[1]):
+        array = (
+            video[:, time_index].permute(1, 2, 0).numpy() * 255.0
+        ).round().astype(np.uint8)
+        image = Image.fromarray(array, mode="RGB")
+        labeled = Image.new(
+            "RGB", (image.width, image.height + label_height), color=(16, 16, 16)
+        )
+        labeled.paste(image, (0, label_height))
+        ImageDraw.Draw(labeled).text((8, 9), label, fill=(255, 255, 255))
+        frames.append(labeled)
+    return frames
+
+
+def action_trace_frames(
+    pred_action: torch.Tensor,
+    gt_action: torch.Tensor,
+    *,
+    valid_dimensions: torch.Tensor | Sequence[bool] | None,
+    frame_count: int,
+    width: int,
+    height: int = 224,
+) -> list[Image.Image]:
+    pred = _as_td(pred_action, "pred_action")
+    gt = _as_td(gt_action, "gt_action")
+    if pred.shape != gt.shape:
+        raise ValueError(
+            f"pred_action and gt_action must have the same shape, got {tuple(pred.shape)} and {tuple(gt.shape)}"
+        )
+    if frame_count <= 0 or width < 320 or height < 120:
+        raise ValueError("Action visualization dimensions are too small.")
+    if valid_dimensions is None:
+        valid = torch.ones(pred.shape[1], dtype=torch.bool)
+    else:
+        valid = torch.as_tensor(valid_dimensions, dtype=torch.bool).flatten()
+        if valid.shape[0] != pred.shape[1]:
+            raise ValueError(
+                f"valid_dimensions must be [D], got {tuple(valid.shape)} for action {tuple(pred.shape)}"
+            )
+    slots = torch.where(valid)[0].tolist()
+    margin_left = 58
+    margin_right = 12
+    header_height = 36
+    plot_width = width - margin_left - margin_right
+    row_height = max((height - header_height - 8) // max(len(slots), 1), 1)
+    time_count = pred.shape[0]
+
+    def x_position(index: int) -> int:
+        if time_count <= 1:
+            return margin_left
+        return margin_left + round(index * (plot_width - 1) / (time_count - 1))
+
+    scales: dict[int, tuple[float, float]] = {}
+    for slot in slots:
+        values = torch.cat([pred[:, slot], gt[:, slot]])
+        low = float(values.min().item())
+        high = float(values.max().item())
+        if high - low < 1.0e-5:
+            center = 0.5 * (low + high)
+            low, high = center - 0.5, center + 0.5
+        padding = 0.08 * (high - low)
+        scales[slot] = (low - padding, high + padding)
+
+    def y_position(slot: int, row: int, value: float) -> int:
+        low, high = scales[slot]
+        top = header_height + row * row_height + 2
+        bottom = header_height + (row + 1) * row_height - 3
+        fraction = (value - low) / (high - low)
+        return bottom - round(float(np.clip(fraction, 0.0, 1.0)) * max(bottom - top, 1))
+
+    frames: list[Image.Image] = []
+    for frame_index in range(frame_count):
+        image = Image.new("RGB", (width, height), color=(16, 16, 16))
+        draw = ImageDraw.Draw(image)
+        draw.text((8, 8), "ACTION (normalized)", fill=(255, 255, 255))
+        draw.line((158, 15, 181, 15), fill=(255, 166, 72), width=3)
+        draw.text((186, 8), "GT", fill=(255, 166, 72))
+        draw.line((226, 15, 249, 15), fill=(70, 210, 255), width=3)
+        draw.text((254, 8), "PRED", fill=(70, 210, 255))
+        if not slots:
+            draw.text((8, 54), "NO ACTION-SUPERVISED DIMENSIONS", fill=(180, 180, 180))
+            frames.append(image)
+            continue
+        for row, slot in enumerate(slots):
+            top = header_height + row * row_height
+            bottom = header_height + (row + 1) * row_height - 1
+            draw.text(
+                (6, top + max((row_height - 11) // 2, 0)),
+                _ACTION_SLOT_LABELS.get(slot, f"S{slot}"),
+                fill=(210, 210, 210),
+            )
+            draw.line((margin_left, bottom, width - margin_right, bottom), fill=(48, 48, 48))
+            gt_points = [
+                (x_position(index), y_position(slot, row, float(gt[index, slot].item())))
+                for index in range(time_count)
+            ]
+            pred_points = [
+                (x_position(index), y_position(slot, row, float(pred[index, slot].item())))
+                for index in range(time_count)
+            ]
+            if len(gt_points) > 1:
+                draw.line(gt_points, fill=(255, 166, 72), width=2)
+                draw.line(pred_points, fill=(70, 210, 255), width=2)
+            else:
+                draw.point(gt_points[0], fill=(255, 166, 72))
+                draw.point(pred_points[0], fill=(70, 210, 255))
+        action_index = (
+            0
+            if frame_count <= 1
+            else round(frame_index * (time_count - 1) / (frame_count - 1))
+        )
+        cursor_x = x_position(action_index)
+        draw.line(
+            (cursor_x, header_height, cursor_x, height - 2),
+            fill=(255, 255, 255),
+            width=1,
+        )
+        frames.append(image)
+    return frames
+
+
+def imagination_execution_pair_frames(
+    pred_video: torch.Tensor,
+    gt_video: torch.Tensor,
+) -> tuple[list[Image.Image], list[Image.Image], list[Image.Image]]:
+    imagination = labeled_video_frames(pred_video, "IMAGINATION")
+    execution = labeled_video_frames(gt_video, "GROUND TRUTH EXECUTION")
+    if len(imagination) != len(execution):
+        raise ValueError("Predicted and ground-truth videos have different frame counts.")
+    pair: list[Image.Image] = []
+    for imagination_frame, execution_frame in zip(imagination, execution):
+        frame = Image.new(
+            "RGB",
+            (
+                imagination_frame.width + execution_frame.width,
+                max(imagination_frame.height, execution_frame.height),
+            ),
+            color=(16, 16, 16),
+        )
+        frame.paste(imagination_frame, (0, 0))
+        frame.paste(execution_frame, (imagination_frame.width, 0))
+        pair.append(frame)
+    return imagination, execution, pair
+
+
+def imagination_execution_action_frames(
+    pred_video: torch.Tensor,
+    gt_video: torch.Tensor,
+    pred_action: torch.Tensor,
+    gt_action: torch.Tensor,
+    *,
+    valid_dimensions: torch.Tensor | Sequence[bool] | None,
+) -> tuple[list[Image.Image], list[Image.Image], list[Image.Image], list[Image.Image]]:
+    imagination, execution, pair = imagination_execution_pair_frames(
+        pred_video, gt_video
+    )
+    action = action_trace_frames(
+        pred_action,
+        gt_action,
+        valid_dimensions=valid_dimensions,
+        frame_count=len(imagination),
+        width=imagination[0].width + execution[0].width,
+    )
+    combined: list[Image.Image] = []
+    for pair_frame, action_frame in zip(pair, action):
+        frame = Image.new(
+            "RGB",
+            (
+                pair_frame.width,
+                pair_frame.height + action_frame.height,
+            ),
+            color=(16, 16, 16),
+        )
+        frame.paste(pair_frame, (0, 0))
+        frame.paste(action_frame, (0, pair_frame.height))
+        combined.append(frame)
+    return imagination, execution, action, combined
