new file mode 100755
index 0000000..90b2254
--- /dev/null
+++ b/scripts/rmbench/summarize_rmbench_results.py
@@ -0,0 +1,367 @@
+#!/usr/bin/env python3
+"""Compare Helios MemoryFastWAM RMBench rollouts with the official table."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import re
+from pathlib import Path
+from typing import Any
+
+from launch_rmbench_helios_training import _checkpoint_is_complete
+
+
+M1_TASKS = (
+    "observe_and_pickup",
+    "rearrange_blocks",
+    "put_back_block",
+    "swap_blocks",
+    "swap_T",
+)
+MN_TASKS = (
+    "battery_try",
+    "blocks_ranking_try",
+    "cover_blocks",
+    "press_button",
+)
+OFFICIAL_TASKS = (*M1_TASKS, *MN_TASKS)
+DISPLAY_NAMES = {
+    "observe_and_pickup": "Observe and Pick Up",
+    "rearrange_blocks": "Rearrange Blocks",
+    "put_back_block": "Put Back Block",
+    "swap_blocks": "Swap Blocks",
+    "swap_T": "Swap T",
+    "battery_try": "Battery Try",
+    "blocks_ranking_try": "Blocks Ranking Try",
+    "cover_blocks": "Cover Blocks",
+    "press_button": "Press Button",
+}
+
+OFFICIAL_BASELINES = {
+    "DP": [1, 0, 0, 11, 20, 10, 10, 0, 0],
+    "ACT": [1, 29, 0, 2, 2, 19, 0, 0, 0],
+    "Pi0.5": [9, 13, 11, 24, 15, 16, 6, 0, 0],
+    "X-VLA": [9, 13, 18, 16, 3, 26, 1, 2, 0],
+    "Mem-0 paper": [4, 89, 90, 67, 14, 28, 18, 68, 0],
+    # Publicly retrained checkpoints announced by RMBench on 2026-07-14.
+    "Mem-0 current": [3, 86, 100, 81, 13, 21, 15, 76, 2],
+}
+SOURCE_URLS = {
+    "project": "https://rmbench.github.io/",
+    "paper": "https://arxiv.org/abs/2603.01229",
+    "code": "https://github.com/robotwin-Platform/rmbench",
+    "current_m1_release": "https://huggingface.co/qiuly/Mem-0-m1mix-RMBench",
+    "current_mn_release": "https://huggingface.co/qiuly/Mem-0-mn-RMBench",
+}
+
+
+def _read_success_rate(path: Path) -> float:
+    text = path.read_text(encoding="utf-8")
+    candidates = []
+    for line in text.splitlines():
+        stripped = line.strip()
+        if re.fullmatch(r"(?:0(?:\.\d+)?|1(?:\.0+)?)", stripped):
+            candidates.append(float(stripped))
+    if not candidates:
+        raise ValueError(f"No [0,1] success rate found in {path}.")
+    return 100.0 * candidates[-1]
+
+
+def _result_from_receipt(receipt_root: Path, task: str, step: int) -> tuple[Path, dict[str, Any]]:
+    receipt_path = receipt_root / f"{task}.json"
+    if not receipt_path.is_file():
+        raise FileNotFoundError(f"RMBench evaluation receipt is missing: {receipt_path}")
+    receipt = json.loads(receipt_path.read_text(encoding="utf-8"))
+    checkpoint = Path(str(receipt.get("checkpoint", "")))
+    result = Path(str(receipt.get("result_path", "")))
+    progress_path = Path(str(receipt.get("progress_path", "")))
+    expected_name = f"step_{step:06d}.pt"
+    if (
+        receipt.get("status") != "succeeded"
+        or checkpoint.name != expected_name
+        or not _checkpoint_is_complete(checkpoint)
+        or not result.is_file()
+        or not progress_path.is_file()
+        or int((receipt.get("protocol") or {}).get("rollouts", -1)) != 100
+    ):
+        raise ValueError(
+            f"Invalid evaluation receipt for {task}: status={receipt.get('status')!r}, "
+            f"checkpoint={checkpoint}, result={result}, progress={progress_path}, "
+            f"expected={expected_name}"
+        )
+    progress = json.loads(progress_path.read_text(encoding="utf-8"))
+    identity = progress.get("identity") or {}
+    feasible_seeds = progress.get("expert_feasible_seeds") or []
+    successes = int(progress.get("successes", -1))
+    receipt_protocol = receipt.get("protocol") or {}
+    receipt_renderer = receipt_protocol.get("renderer") or {}
+    expected_progress_protocol = {
+        "observation_stride_actions": receipt_protocol.get(
+            "observation_stride_actions"
+        ),
+        "camera_config_in_observation": receipt_protocol.get(
+            "camera_config_in_observation"
+        ),
+        "renderer": {
+            key: receipt_renderer.get(key)
+            for key in (
+                "shader",
+                "pipeline",
+                "samples_per_pixel",
+                "path_depth",
+                "denoiser",
+            )
+        },
+    }
+    if (
+        progress.get("status") != "completed"
+        or int(progress.get("evaluated_rollouts", -1)) != 100
+        or int(identity.get("target_rollouts", -1)) != 100
+        or Path(str(identity.get("checkpoint", ""))).resolve() != checkpoint.resolve()
+        or identity.get("protocol") != expected_progress_protocol
+        or len(feasible_seeds) != 100
+        or len(set(int(seed) for seed in feasible_seeds)) != 100
+        or not 0 <= successes <= 100
+        or abs(_read_success_rate(result) - successes) > 1e-6
+    ):
+        raise ValueError(
+            f"Invalid 100-rollout progress for {task}: progress={progress_path}, "
+            f"evaluated={progress.get('evaluated_rollouts')}, successes={successes}, "
+            f"feasible_seeds={len(feasible_seeds)}"
+        )
+    return result.resolve(), receipt
+
+
+def _average(values: dict[str, float], tasks: tuple[str, ...]) -> float | None:
+    selected = [values[task] for task in tasks if task in values]
+    return None if not selected else sum(selected) / len(selected)
+
+
+def _fmt(value: float | None) -> str:
+    return "pending" if value is None else f"{value:.1f}%"
+
+
+def _renderer_note(protocols: dict[str, Any]) -> str:
+    normalized: set[tuple[str, str, str, str, str, str]] = set()
+    for renderer in protocols.values():
+        if not isinstance(renderer, dict):
+            continue
+        normalized.add(
+            (
+                str(renderer.get("shader", "unknown")),
+                str(renderer.get("pipeline", "unknown")),
+                str(renderer.get("samples_per_pixel", "unknown")),
+                str(renderer.get("path_depth", "unknown")),
+                str(renderer.get("denoiser", "unknown")),
+                str(renderer.get("vulkan_device", "unknown")),
+            )
+        )
+    if not normalized:
+        return (
+            "- Renderer protocol is unavailable because no evaluation receipt was "
+            "loaded."
+        )
+
+    descriptions = []
+    for shader, pipeline, samples, depth, denoiser, device in sorted(normalized):
+        if pipeline == "raster":
+            descriptions.append(f"{shader} raster, device {device}")
+        else:
+            descriptions.append(
+                f"{shader} {pipeline}, {samples} spp, depth {depth}, "
+                f"denoiser {denoiser}, device {device}"
+            )
+    label = "Renderer receipt" if len(descriptions) == 1 else "Renderer receipts"
+    return (
+        f"- {label}: {'; '.join(descriptions)}. Official GPU rendering uses OIDN; "
+        "results from a different renderer are not pixel-equivalent."
+    )
+
+
+def summarize(args: argparse.Namespace) -> dict[str, Any]:
+    receipt_root = args.receipt_root.expanduser().resolve()
+    explicit: dict[str, Path] = {}
+    for value in args.result:
+        task, separator, path = value.partition("=")
+        if not separator or task not in OFFICIAL_TASKS:
+            raise SystemExit(f"--result must be task=/path for an official task, got {value!r}.")
+        explicit[task] = Path(path).expanduser().resolve()
+
+    fastwam: dict[str, float] = {}
+    result_paths: dict[str, str] = {}
+    evaluation_receipts: dict[str, dict[str, Any]] = {}
+    for task in OFFICIAL_TASKS:
+        path = explicit.get(task)
+        if path is None:
+            try:
+                path, receipt = _result_from_receipt(receipt_root, task, args.step)
+                evaluation_receipts[task] = receipt
+            except (FileNotFoundError, ValueError):
+                if args.allow_partial:
+                    continue
+                raise
+        fastwam[task] = _read_success_rate(path)
+        result_paths[task] = str(path)
+    missing = [task for task in OFFICIAL_TASKS if task not in fastwam]
+    if missing and not args.allow_partial:
+        raise SystemExit(f"Missing official RMBench results for: {', '.join(missing)}")
+
+    rows = []
+    for index, task in enumerate(OFFICIAL_TASKS):
+        baselines = {
+            policy: values[index] for policy, values in OFFICIAL_BASELINES.items()
+        }
+        score = fastwam.get(task)
+        best_baseline = max(baselines.values())
+        rows.append(
+            {
+                "task": task,
+                "display_name": DISPLAY_NAMES[task],
+                "tmc": "M(1)" if task in M1_TASKS else "M(n)",
+                "fastwam": score,
+                "official_baselines": baselines,
+                "best_official_baseline": best_baseline,
+                "delta_vs_best_baseline": None if score is None else score - best_baseline,
+                "delta_vs_mem0_paper": (
+                    None if score is None else score - baselines["Mem-0 paper"]
+                ),
+                "delta_vs_mem0_current": (
+                    None if score is None else score - baselines["Mem-0 current"]
+                ),
+            }
+        )
+
+    averages = {
+        "fastwam_m1": _average(fastwam, M1_TASKS),
+        "fastwam_mn": _average(fastwam, MN_TASKS),
+        "fastwam_total": _average(fastwam, OFFICIAL_TASKS),
+        "official": {
+            policy: {
+                "m1": sum(values[: len(M1_TASKS)]) / len(M1_TASKS),
+                "mn": sum(values[len(M1_TASKS) :]) / len(MN_TASKS),
+                "total": sum(values) / len(OFFICIAL_TASKS),
+            }
+            for policy, values in OFFICIAL_BASELINES.items()
+        },
+    }
+    renderer_protocols = {
+        task: receipt.get("protocol", {}).get("renderer")
+        for task, receipt in evaluation_receipts.items()
+    }
+    payload = {
+        "schema_version": "fastwam-rmbench-leaderboard-comparison-v2",
+        "metric": "closed_loop_success_rate_percent",
+        "training_protocol": "task_specific_50_demo_clean_episodes",
+        "training_budget": {
+            "initialization": "tianji_helios_memory_fastwam_2500_steps",
+            "fine_tune_steps_per_task": args.step,
+            "paper_mem0": {
+                "iterations_per_task": 30000,
+                "global_batch_size": 448,
+                "gpus": "8xA800",
+            },
+            "current_mem0_release": {
+                "release_date": "2026-07-14",
+                "m1": "one five-task m1_mix checkpoint, 50000 steps, batch 56",
+                "mn": "four task-specific checkpoints, 30000 steps per task",
+            },
+            "budget_or_organization_matched_to_mem0": False,
+        },
+        "evaluation_protocol": "100_expert-feasible_rollouts_per_task_seed0_unseen_instruction",
+        "evaluation_receipts": {
+            task: str((receipt_root / f"{task}.json").resolve())
+            for task in evaluation_receipts
+        },
+        "renderer_protocols": renderer_protocols,
+        "source_urls": SOURCE_URLS,
+        "result_paths": result_paths,
+        "missing_tasks": missing,
+        "rows": rows,
+        "averages": averages,
+    }
+
+    output_json = args.output_json.expanduser().resolve()
+    output_md = args.output_md.expanduser().resolve()
+    output_json.parent.mkdir(parents=True, exist_ok=True)
+    output_md.parent.mkdir(parents=True, exist_ok=True)
+    output_json.write_text(json.dumps(payload, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+
+    lines = [
+        "# RMBench Helios MemoryFastWAM Comparison",
+        "",
+        "Metric: closed-loop success rate, 100 expert-feasible rollouts per task.",
+        "",
+        "| Task | TMC | Helios FastWAM | DP | ACT | Pi0.5 | X-VLA | Mem-0 paper | Mem-0 current | Delta vs best official |",
+        "| --- | --- | ---: | ---: | ---: | ---: | ---: | ---: | ---: | ---: |",
+    ]
+    for row in rows:
+        baseline = row["official_baselines"]
+        lines.append(
+            f"| {row['display_name']} | {row['tmc']} | {_fmt(row['fastwam'])} | "
+            f"{baseline['DP']:.0f}% | {baseline['ACT']:.0f}% | {baseline['Pi0.5']:.0f}% | "
+            f"{baseline['X-VLA']:.0f}% | {baseline['Mem-0 paper']:.0f}% | "
+            f"{baseline['Mem-0 current']:.0f}% | "
+            f"{_fmt(row['delta_vs_best_baseline'])} |"
+        )
+    lines.extend(
+        [
+            "",
+            f"- Helios FastWAM M(1) average: {_fmt(averages['fastwam_m1'])}",
+            f"- Helios FastWAM M(n) average: {_fmt(averages['fastwam_mn'])}",
+            f"- Helios FastWAM total average: {_fmt(averages['fastwam_total'])}",
+            "- Mem-0 paper averages: 52.8% M(1), 28.5% M(n), 42.0% total.",
+            "- Current public Mem-0 release averages (2026-07-14): 56.6% M(1), "
+            "28.5% M(n), 44.1% total.",
+            "- Best non-Mem-0 official total average: Pi0.5 at 10.4%.",
+            f"- Helios FastWAM uses the 2,500-step Tianji memory initialization and {args.step:,} "
+            "fine-tune steps per task. It matches neither the paper Mem-0 budget (30K iterations, "
+            "global batch 448) nor the current M(1) joint-training organization, so this is not "
+            "a budget- or organization-matched comparison.",
+            _renderer_note(renderer_protocols),
+            "",
+            "Sources: [project page](https://rmbench.github.io/), "
+            "[paper](https://arxiv.org/abs/2603.01229), "
+            "[official code](https://github.com/robotwin-Platform/rmbench), "
+            "[current M(1) release](https://huggingface.co/qiuly/Mem-0-m1mix-RMBench), "
+            "[current M(n) release](https://huggingface.co/qiuly/Mem-0-mn-RMBench).",
+        ]
+    )
+    output_md.write_text("\n".join(lines) + "\n", encoding="utf-8")
+    return payload
+
+
+def parse_args() -> argparse.Namespace:
+    default_root = Path("/public/interns/hubin/dataset/RMBench/fastwam_helios")
+    parser = argparse.ArgumentParser()
+    parser.add_argument(
+        "--eval-root",
+        type=Path,
+        default=Path("/public/interns/hubin/code/RMBench/eval_result"),
+    )
+    parser.add_argument(
+        "--receipt-root",
+        type=Path,
+        default=default_root / "evaluation" / "receipts",
+    )
+    parser.add_argument("--step", type=int, default=2500)
+    parser.add_argument("--result", action="append", default=[])
+    parser.add_argument("--allow-partial", action="store_true")
+    parser.add_argument(
+        "--output-json",
+        type=Path,
+        default=default_root / "evaluation" / "leaderboard_comparison.json",
+    )
+    parser.add_argument(
+        "--output-md",
+        type=Path,
+        default=default_root / "evaluation" / "leaderboard_comparison.md",
+    )
+    args = parser.parse_args()
+    if args.step <= 0:
+        parser.error("--step must be positive")
+    return args
+
+
+if __name__ == "__main__":
+    print(json.dumps(summarize(parse_args()), indent=2, sort_keys=True))
