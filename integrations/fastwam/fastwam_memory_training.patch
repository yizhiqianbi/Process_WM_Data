+import torch
+
+from fastwam.utils.eval_visualization import (
+    action_trace_frames,
+    imagination_execution_action_frames,
+    imagination_execution_pair_frames,
+)
+
+
+def test_imagination_execution_action_artifacts_have_stable_dimensions():
+    pred_video = torch.zeros((3, 21, 384, 320), dtype=torch.float32)
+    gt_video = torch.ones_like(pred_video)
+    pred_action = torch.linspace(-1.0, 1.0, 80).view(80, 1).repeat(1, 80)
+    gt_action = pred_action * 0.5
+    valid = torch.zeros(80, dtype=torch.bool)
+    valid[[13, 21, 22, 23, 24, 25, 26, 27]] = True
+
+    imagination, execution, action, combined = imagination_execution_action_frames(
+        pred_video,
+        gt_video,
+        pred_action,
+        gt_action,
+        valid_dimensions=valid,
+    )
+
+    assert len(imagination) == len(execution) == len(action) == len(combined) == 21
+    assert imagination[0].size == (320, 416)
+    assert execution[0].size == (320, 416)
+    assert action[0].size == (640, 224)
+    assert combined[0].size == (640, 640)
+
+
+def test_action_trace_supports_video_only_samples():
+    frames = action_trace_frames(
+        torch.zeros((80, 80)),
+        torch.zeros((80, 80)),
+        valid_dimensions=torch.zeros(80, dtype=torch.bool),
+        frame_count=21,
+        width=640,
+    )
+
+    assert len(frames) == 21
+    assert frames[0].size == (640, 224)
+
+
+def test_imagination_execution_pair_has_stable_dimensions():
+    pred_video = torch.zeros((3, 21, 384, 320), dtype=torch.float32)
+    gt_video = torch.ones_like(pred_video)
+
+    imagination, execution, pair = imagination_execution_pair_frames(
+        pred_video, gt_video
+    )
+
+    assert len(imagination) == len(execution) == len(pair) == 21
+    assert imagination[0].size == (320, 416)
+    assert execution[0].size == (320, 416)
+    assert pair[0].size == (640, 416)
