+import json
+import sys
+import zipfile
+from pathlib import Path
+
+
+SCRIPT_DIR = Path(__file__).resolve().parents[1] / "scripts" / "rmbench"
+if str(SCRIPT_DIR) not in sys.path:
+    sys.path.insert(0, str(SCRIPT_DIR))
+
+from summarize_rmbench_results import (  # noqa: E402
+    M1_TASKS,
+    MN_TASKS,
+    OFFICIAL_BASELINES,
+    OFFICIAL_TASKS,
+    _renderer_note,
+    _result_from_receipt,
+)
+
+
+def test_official_mem0_baselines_preserve_paper_and_current_release():
+    paper = OFFICIAL_BASELINES["Mem-0 paper"]
+    current = OFFICIAL_BASELINES["Mem-0 current"]
+
+    assert len(paper) == len(OFFICIAL_TASKS)
+    assert len(current) == len(OFFICIAL_TASKS)
+    assert sum(paper[: len(M1_TASKS)]) / len(M1_TASKS) == 52.8
+    assert sum(paper[len(M1_TASKS) :]) / len(MN_TASKS) == 28.5
+    assert sum(paper) / len(OFFICIAL_TASKS) == 42.0
+    assert sum(current[: len(M1_TASKS)]) / len(M1_TASKS) == 56.6
+    assert sum(current[len(M1_TASKS) :]) / len(MN_TASKS) == 28.5
+    assert round(sum(current) / len(OFFICIAL_TASKS), 1) == 44.1
+
+
+def test_result_receipt_requires_requested_checkpoint_step(tmp_path: Path):
+    checkpoint = tmp_path / "step_002500.pt"
+    result = tmp_path / "_result.txt"
+    with zipfile.ZipFile(checkpoint, "w") as archive:
+        archive.writestr("archive/data.pkl", b"checkpoint")
+        archive.writestr("archive/version", b"3\n")
+    result.write_text("0.25\n", encoding="utf-8")
+    progress = tmp_path / "progress.json"
+    progress_protocol = {
+        "observation_stride_actions": 4,
+        "camera_config_in_observation": False,
+        "renderer": {
+            "shader": "rt",
+            "pipeline": "ray_tracing",
+            "samples_per_pixel": 1,
+            "path_depth": 1,
+            "denoiser": "none",
+        },
+    }
+    progress.write_text(
+        json.dumps(
+            {
+                "status": "completed",
+                "identity": {
+                    "checkpoint": str(checkpoint),
+                    "target_rollouts": 100,
+                    "protocol": progress_protocol,
+                },
+                "evaluated_rollouts": 100,
+                "successes": 25,
+                "expert_feasible_seeds": list(range(100000, 100100)),
+            }
+        ),
+        encoding="utf-8",
+    )
+    receipt_root = tmp_path / "receipts"
+    receipt_root.mkdir()
+    receipt = {
+        "status": "succeeded",
+        "checkpoint": str(checkpoint),
+        "result_path": str(result),
+        "progress_path": str(progress),
+        "protocol": {"rollouts": 100, **progress_protocol},
+    }
+    (receipt_root / "press_button.json").write_text(
+        json.dumps(receipt), encoding="utf-8"
+    )
+
+    selected, payload = _result_from_receipt(receipt_root, "press_button", 2500)
+    assert selected == result.resolve()
+    assert payload["protocol"]["rollouts"] == 100
+
+    progress_payload = json.loads(progress.read_text(encoding="utf-8"))
+    progress_payload["successes"] = 24
+    progress.write_text(json.dumps(progress_payload), encoding="utf-8")
+    try:
+        _result_from_receipt(receipt_root, "press_button", 2500)
+    except ValueError as error:
+        assert "Invalid 100-rollout progress" in str(error)
+    else:
+        raise AssertionError("result receipt accepted a score/count mismatch")
+    progress_payload["successes"] = 25
+    progress.write_text(json.dumps(progress_payload), encoding="utf-8")
+
+    progress_payload["identity"]["protocol"]["observation_stride_actions"] = 1
+    progress.write_text(json.dumps(progress_payload), encoding="utf-8")
+    try:
+        _result_from_receipt(receipt_root, "press_button", 2500)
+    except ValueError as error:
+        assert "Invalid 100-rollout progress" in str(error)
+    else:
+        raise AssertionError("result receipt accepted a mixed observation protocol")
+    progress_payload["identity"]["protocol"]["observation_stride_actions"] = 4
+    progress.write_text(json.dumps(progress_payload), encoding="utf-8")
+
+    try:
+        _result_from_receipt(receipt_root, "press_button", 2000)
+    except ValueError as error:
+        assert "step_002000.pt" in str(error)
+    else:
