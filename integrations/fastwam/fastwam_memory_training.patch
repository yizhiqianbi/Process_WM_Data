+#!/usr/bin/env python3
+"""Index raw RMBench HDF5 data for canonical Helios MemoryFastWAM training."""
+
+from __future__ import annotations
+
+import argparse
+import hashlib
+import json
+import os
+import re
+import tempfile
+from pathlib import Path
+from typing import Any
+
+import h5py
+import numpy as np
+
+from fastwam.datasets.rmbench_memory_dataset import (
+    CAMERA_DATASETS,
+    CANONICAL_DIM,
+    EPISODE_SCHEMA_VERSION,
+    NORMALIZATION_SCHEMA_VERSION,
+    RMBENCH_ACTION_DIM,
+    RMBENCH_TO_CANONICAL,
+)
+
+
+OFFICIAL_TASKS = (
+    "observe_and_pickup",
+    "rearrange_blocks",
+    "put_back_block",
+    "swap_blocks",
+    "swap_T",
+    "battery_try",
+    "blocks_ranking_try",
+    "cover_blocks",
+    "press_button",
+)
+
+
+def _episode_index(path: Path) -> int:
+    match = re.fullmatch(r"episode(\d+)\.hdf5", path.name)
+    if match is None:
+        raise ValueError(f"Cannot parse RMBench episode index from {path}.")
+    return int(match.group(1))
+
+
+def _pick_instruction(value: Any) -> str | None:
+    if isinstance(value, str):
+        value = value.strip()
+        return value or None
+    if isinstance(value, list):
+        for item in value:
+            selected = _pick_instruction(item)
+            if selected:
+                return selected
+    return None
+
+
+def _load_instruction(setting_dir: Path, episode_index: int, instruction_type: str) -> str:
+    path = setting_dir / "instructions" / f"episode{episode_index}.json"
+    if not path.is_file():
+        raise FileNotFoundError(f"RMBench episode instruction not found: {path}")
+    with path.open("r", encoding="utf-8") as handle:
+        payload = json.load(handle)
+    instruction = _pick_instruction(payload.get(instruction_type))
+    if instruction is None:
+        fallback = "seen" if instruction_type == "unseen" else "unseen"
+        instruction = _pick_instruction(payload.get(fallback))
+    if instruction is None:
+        raise ValueError(f"No usable instruction in {path}.")
+    return instruction
+
+
+def _atomic_write(path: Path, content: str) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with tempfile.NamedTemporaryFile(
+        mode="w", encoding="utf-8", dir=path.parent, delete=False
+    ) as handle:
+        handle.write(content)
+        temp_path = Path(handle.name)
+    os.replace(temp_path, path)
+
+
+def _json_text(payload: Any) -> str:
+    return json.dumps(payload, ensure_ascii=False, indent=2, sort_keys=True) + "\n"
+
+
+def _jsonl_text(records: list[dict[str, Any]]) -> str:
+    return "".join(
+        json.dumps(record, ensure_ascii=False, sort_keys=True) + "\n" for record in records
+    )
+
+
+def _domain_name(task_name: str) -> str:
+    return f"rmbench:{task_name}:aloha-agilex:qpos-next-v1"
+
+
+def _canonical_stats(
+    *,
+    state_sum: np.ndarray,
+    state_sq_sum: np.ndarray,
+    action_sum: np.ndarray,
+    action_sq_sum: np.ndarray,
+    count: int,
+    minimum_std: float,
+) -> dict[str, Any]:
+    if count <= 0:
+        raise ValueError("Cannot build RMBench normalization from zero transitions.")
+
+    def one(sum_value: np.ndarray, sq_sum_value: np.ndarray) -> dict[str, Any]:
+        mean_raw = sum_value / count
+        variance_raw = np.maximum(sq_sum_value / count - mean_raw**2, 0.0)
+        std_raw = np.maximum(np.sqrt(variance_raw), minimum_std)
+        mean = np.zeros(CANONICAL_DIM, dtype=np.float64)
+        std = np.ones(CANONICAL_DIM, dtype=np.float64)
+        counts = np.zeros(CANONICAL_DIM, dtype=np.int64)
+        valid = np.zeros(CANONICAL_DIM, dtype=np.bool_)
+        slots = np.asarray(RMBENCH_TO_CANONICAL, dtype=np.int64)
+        mean[slots] = mean_raw
+        std[slots] = std_raw
+        counts[slots] = count
+        valid[slots] = True
+        return {
+            "count": counts.tolist(),
+            "mean": mean.tolist(),
+            "std": std.tolist(),
+            "valid_mask": valid.tolist(),
+        }
+
+    return {
+        "state": one(state_sum, state_sq_sum),
+        "action": one(action_sum, action_sq_sum),
+    }
+
+
+def prepare(args: argparse.Namespace) -> None:
+    data_root = args.data_root.expanduser().resolve()
+    output_root = args.output_root.expanduser().resolve()
+    tasks = tuple(args.tasks or OFFICIAL_TASKS)
+    if len(tasks) != len(set(tasks)):
+        raise SystemExit(f"Duplicate RMBench task names: {tasks}")
+
+    episode_records: list[dict[str, Any]] = []
+    task_instruction_order: list[str] = []
+    task_instruction_seen: set[str] = set()
+    stats_domains: dict[str, Any] = {}
+    task_receipts: dict[str, Any] = {}
+
+    for task_name in tasks:
+        setting_dir = data_root / task_name / args.setting
+        episode_paths = sorted(
+            (setting_dir / "data").glob("episode*.hdf5"), key=_episode_index
+        )
+        if args.max_episodes is not None:
+            episode_paths = episode_paths[: int(args.max_episodes)]
+        if not episode_paths:
+            raise FileNotFoundError(
+                f"No RMBench episodes for {task_name}/{args.setting} under {data_root}."
+            )
+
+        state_sum = np.zeros(RMBENCH_ACTION_DIM, dtype=np.float64)
+        state_sq_sum = np.zeros(RMBENCH_ACTION_DIM, dtype=np.float64)
+        action_sum = np.zeros(RMBENCH_ACTION_DIM, dtype=np.float64)
+        action_sq_sum = np.zeros(RMBENCH_ACTION_DIM, dtype=np.float64)
+        transition_count = 0
+        frame_count = 0
+        window_count = 0
+        lengths: list[int] = []
+        domain = _domain_name(task_name)
+
+        for hdf5_path in episode_paths:
+            source_episode_index = _episode_index(hdf5_path)
+            instruction = _load_instruction(
+                setting_dir, source_episode_index, args.instruction_type
+            )
+            with h5py.File(hdf5_path, "r") as handle:
+                raw_state = np.asarray(handle["joint_action/vector"], dtype=np.float64)
+                if raw_state.ndim != 2 or raw_state.shape[1] != RMBENCH_ACTION_DIM:
+                    raise ValueError(
+                        f"Expected joint_action/vector [T,{RMBENCH_ACTION_DIM}], got "
+                        f"{raw_state.shape} in {hdf5_path}."
+                    )
+                length = int(raw_state.shape[0])
+                if length < 81:
+                    raise ValueError(f"RMBench episode is shorter than 81 frames: {hdf5_path}")
+                for dataset_key in CAMERA_DATASETS.values():
+                    if dataset_key not in handle or len(handle[dataset_key]) != length:
+                        raise ValueError(
+                            f"Camera/action length mismatch for {dataset_key} in {hdf5_path}."
+                        )
+
+            state_values = raw_state[:-1]
+            action_values = raw_state[1:]
+            state_sum += state_values.sum(axis=0)
+            state_sq_sum += np.square(state_values).sum(axis=0)
+            action_sum += action_values.sum(axis=0)
+            action_sq_sum += np.square(action_values).sum(axis=0)
+            transition_count += length - 1
+            frame_count += length
+            window_count += length - 80
+            lengths.append(length)
+
+            if instruction not in task_instruction_seen:
+                task_instruction_seen.add(instruction)
+                task_instruction_order.append(instruction)
+            episode_records.append(
+                {
+                    "schema_version": EPISODE_SCHEMA_VERSION,
+                    "task_name": task_name,
+                    "source_episode_index": source_episode_index,
+                    "hdf5_path": os.path.relpath(hdf5_path, output_root),
+                    "instruction": instruction,
+                    "instruction_type": args.instruction_type,
+                    "length": length,
+                    "normalization_domain": domain,
+                    "action_semantics": "next_qpos",
+                    "camera_order": ["head", "left_wrist", "right_wrist"],
+                }
+            )
+
+        domain_stats = _canonical_stats(
+            state_sum=state_sum,
+            state_sq_sum=state_sq_sum,
+            action_sum=action_sum,
+            action_sq_sum=action_sq_sum,
+            count=transition_count,
+            minimum_std=args.minimum_std,
+        )
+        stats_domains[domain] = {
+            **domain_stats,
+            "datasets": ["RMBench"],
+            "embodiments": ["aloha-agilex"],
+            "episode_count": len(episode_paths),
+            "row_count": frame_count,
+            "selected_state_row_count": transition_count,
+            "selected_action_row_count": transition_count,
+            "window_count": window_count,
+            "task_name": task_name,
+        }
+        task_receipts[task_name] = {
+            "episode_count": len(episode_paths),
+            "frame_count": frame_count,
+            "transition_count": transition_count,
+            "window_count_81f": window_count,
+            "min_episode_frames": min(lengths),
+            "max_episode_frames": max(lengths),
+            "normalization_domain": domain,
+        }
+
+    normalization = {
+        "schema_version": NORMALIZATION_SCHEMA_VERSION,
+        "method": "zscore",
+        "minimum_std": args.minimum_std,
+        "scope": "rmbench_task_and_active_canonical_slot",
+        "row_selection": "state_t_and_next_qpos_t_plus_1",
+        "source_splits": [args.setting],
+        "source_training_modes": ["joint_video_action"],
+        "source_quality_tiers": ["official_demo_clean"],
+        "domains": stats_domains,
+    }
+    tasks_records = [
+        {"task_index": index, "task": instruction}
+        for index, instruction in enumerate(task_instruction_order)
+    ]
+    manifest_text = _jsonl_text(episode_records)
+    receipt = {
+        "schema_version": "fastwam-rmbench-helios-preparation-v1",
+        "data_root": str(data_root),
+        "output_root": str(output_root),
+        "setting": args.setting,
+        "instruction_type": args.instruction_type,
+        "official_protocol": (
+            tuple(tasks) == OFFICIAL_TASKS
+            and args.max_episodes is None
+            and args.setting == "demo_clean"
+            and args.instruction_type == "seen"
+        ),
+        "tasks": list(tasks),
+        "task_statistics": task_receipts,
+        "total_episodes": len(episode_records),
+        "total_frames": sum(value["frame_count"] for value in task_receipts.values()),
+        "total_windows_81f": sum(
+            value["window_count_81f"] for value in task_receipts.values()
+        ),
+        "canonical_dim": CANONICAL_DIM,
+        "active_canonical_slots": list(RMBENCH_TO_CANONICAL),
+        "timeline": {"state": 81, "action": 80, "video": 21, "video_stride": 4},
+        "memory": {"long": 8, "mid": 2, "short": 1, "target_leak": False},
+        "episode_manifest_sha256": hashlib.sha256(manifest_text.encode("utf-8")).hexdigest(),
+    }
+
+    meta = output_root / "meta"
+    _atomic_write(meta / "episodes.jsonl", manifest_text)
+    _atomic_write(meta / "tasks.jsonl", _jsonl_text(tasks_records))
+    _atomic_write(meta / "normalization_stats.json", _json_text(normalization))
+    _atomic_write(meta / "preparation_receipt.json", _json_text(receipt))
+    (output_root / "text_embeds").mkdir(parents=True, exist_ok=True)
+
+    print(_json_text(receipt), end="")
+
+
+def parse_args() -> argparse.Namespace:
+    parser = argparse.ArgumentParser()
+    parser.add_argument(
+        "--data-root",
+        type=Path,
+        default=Path("/public/interns/hubin/dataset/RMBench/data"),
+    )
+    parser.add_argument(
+        "--output-root",
+        type=Path,
+        default=Path("/public/interns/hubin/dataset/RMBench/fastwam_helios"),
+    )
+    parser.add_argument("--tasks", nargs="*", default=None)
+    parser.add_argument("--setting", default="demo_clean")
+    parser.add_argument("--instruction-type", choices=("seen", "unseen"), default="seen")
+    parser.add_argument("--max-episodes", type=int, default=None)
+    parser.add_argument("--minimum-std", type=float, default=1.0e-3)
+    args = parser.parse_args()
+    if args.max_episodes is not None and args.max_episodes <= 0:
+        parser.error("--max-episodes must be positive.")
+    if args.minimum_std <= 0:
+        parser.error("--minimum-std must be positive.")
+    return args
+
+
+if __name__ == "__main__":
+    prepare(parse_args())
