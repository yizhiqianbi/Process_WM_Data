+#!/usr/bin/env python3
+"""Run one real MemoryFastWAM action-inference case from a training config."""
+
+from __future__ import annotations
+
+import json
+
+import hydra
+import torch
+from hydra.utils import instantiate
+from omegaconf import DictConfig
+
+from fastwam.utils.config_resolvers import register_default_resolvers
+
+
+register_default_resolvers()
+
+
+@hydra.main(config_path="../configs", config_name="train", version_base="1.3")
+def main(cfg: DictConfig) -> None:
+    checkpoint = cfg.get("validation_checkpoint")
+    if not checkpoint:
+        raise ValueError("Set +validation_checkpoint=/path/to/memory_fastwam.pt")
+    device = str(cfg.get("validation_device", "cuda:0"))
+    inference_steps = int(cfg.get("validation_num_inference_steps", 1))
+
+    dataset = instantiate(cfg.data.train)
+    sample = dataset[0]
+    model = instantiate(cfg.model, model_dtype=torch.bfloat16, device=device)
+    model.load_checkpoint(str(checkpoint))
+
+    output = model.infer_action(
+        prompt=None,
+        input_image=sample["video"][:, 0],
+        action_horizon=int(sample["action"].shape[0]),
+        proprio=sample["proprio"][0],
+        memory_video_long=sample["memory_video_long"],
+        memory_video_mid=sample["memory_video_mid"],
+        memory_video_short=sample["memory_video_short"],
+        memory_mask_long=sample["memory_mask_long"],
+        memory_mask_mid=sample["memory_mask_mid"],
+        memory_mask_short=sample["memory_mask_short"],
+        context=sample["context"],
+        context_mask=sample["context_mask"],
+        num_inference_steps=inference_steps,
+        seed=int(cfg.seed),
+        rand_device="cpu",
+        tiled=False,
+    )
+    action = output["action"]
+    if tuple(action.shape) != (80, 80):
+        raise ValueError(f"Expected inferred action [80,80], got {tuple(action.shape)}")
+    if not torch.isfinite(action).all():
+        raise ValueError("Inferred action contains non-finite values")
+
+    print(
+        json.dumps(
+            {
+                "status": "passed",
+                "checkpoint": str(checkpoint),
+                "window_start": int(sample["window_start"]),
+                "action_shape": list(action.shape),
+                "action_min": float(action.min()),
+                "action_max": float(action.max()),
+                "memory_valid_ratio": float(output["memory_valid_ratio"]),
+                "inference_steps": inference_steps,
+            },
+            sort_keys=True,
+        )
+    )
+
+
+if __name__ == "__main__":
+    main()
