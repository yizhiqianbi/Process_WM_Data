new file mode 100644
index 0000000..6791da3
--- /dev/null
+++ b/experiments/robotwin/fastwam_helios_client/__init__.py
@@ -0,0 +1,45 @@
+"""Dependency-light RMBench client bridge for the FastWAM model server."""
+
+from __future__ import annotations
+
+import os
+
+import numpy as np
+
+
+def get_model(_usr_args):
+    raise RuntimeError("fastwam_helios_client is a socket client and does not load a local model.")
+
+
+def _should_refresh_observation(
+    completed_actions: int, total_actions: int, observation_stride: int
+) -> bool:
+    if observation_stride <= 0:
+        raise ValueError("RMBENCH_OBSERVATION_STRIDE must be positive")
+    if completed_actions <= 0 or completed_actions > total_actions:
+        raise ValueError("completed_actions must be within the current action chunk")
+    return completed_actions < total_actions and completed_actions % observation_stride == 0
+
+
+def eval(task_env, model_client, observation):
+    instruction = task_env.get_instruction()
+    observation_stride = int(os.environ.get("RMBENCH_OBSERVATION_STRIDE", "4"))
+    payload = dict(observation)
+    payload["_fastwam_instruction"] = instruction
+    actions = np.asarray(
+        model_client.call(func_name="get_action", obs=payload), dtype=np.float32
+    )
+    for action_index, action in enumerate(actions):
+        task_env.take_action(action, action_type="qpos")
+        if task_env.eval_success:
+            break
+        if _should_refresh_observation(
+            action_index + 1, len(actions), observation_stride
+        ):
+            follow_up = dict(task_env.get_obs())
+            follow_up["_fastwam_instruction"] = instruction
+            model_client.call(func_name="update_obs", obs=follow_up)
+
+
+def reset_model(model_client):
+    return model_client.call(func_name="reset_model")
