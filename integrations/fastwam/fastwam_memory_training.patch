+class RMBenchCanonicalNormalizer:
+    def __init__(self, path: Path, task_name: str) -> None:
+        with path.open("r", encoding="utf-8") as handle:
+            payload = json.load(handle)
+        if payload.get("schema_version") != NORMALIZATION_SCHEMA_VERSION:
+            raise ValueError(
+                f"Unsupported canonical normalization schema in {path}: "
+                f"{payload.get('schema_version')!r}"
+            )
+        matches = [
+            domain
+            for domain, stats in payload.get("domains", {}).items()
+            if stats.get("task_name") == task_name
+            or str(domain).startswith(f"rmbench:{task_name}:")
+        ]
+        if len(matches) != 1:
+            raise ValueError(
+                f"Expected one canonical normalization domain for task={task_name}, got {matches}."
+            )
+        self.domain = matches[0]
+        self.stats = payload["domains"][self.domain]
+        expected_valid = canonical_valid_mask()
+        for kind in ("state", "action"):
+            values = self.stats.get(kind) or {}
+            mean = np.asarray(values.get("mean"), dtype=np.float32)
+            std = np.asarray(values.get("std"), dtype=np.float32)
+            valid = np.asarray(values.get("valid_mask"), dtype=np.bool_)
+            if mean.shape != (CANONICAL_DIM,) or std.shape != (CANONICAL_DIM,):
+                raise ValueError(f"Malformed {kind} stats for canonical domain {self.domain}.")
+            if valid.shape != (CANONICAL_DIM,) or not np.array_equal(valid, expected_valid):
+                raise ValueError(f"Unexpected active slots in {kind} stats for {self.domain}.")
+            if not np.isfinite(mean).all() or not np.isfinite(std).all() or (std <= 0).any():
+                raise ValueError(f"Invalid {kind} mean/std for canonical domain {self.domain}.")
+
+    def normalize_state(self, state: np.ndarray) -> torch.Tensor:
+        canonical = rmbench_to_canonical(np.asarray(state, dtype=np.float32))
+        stats = self.stats["state"]
+        mean = np.asarray(stats["mean"], dtype=np.float32)
+        std = np.asarray(stats["std"], dtype=np.float32)
+        normalized = (canonical - mean) / std
+        normalized = np.clip(normalized, -10.0, 10.0)
+        normalized[~canonical_valid_mask()] = 0.0
+        return torch.from_numpy(normalized).unsqueeze(0)
+
+    def denormalize_action(self, action: torch.Tensor) -> np.ndarray:
+        values = action.detach().to(dtype=torch.float32, device="cpu").numpy()
+        stats = self.stats["action"]
+        mean = np.asarray(stats["mean"], dtype=np.float32)
+        std = np.asarray(stats["std"], dtype=np.float32)
+        canonical = values * std + mean
+        return canonical_to_rmbench(canonical)
+
+    @property
+    def action_dim_is_pad(self) -> torch.Tensor:
+        return torch.from_numpy(~canonical_valid_mask()).unsqueeze(0)
 
 
