+#!/usr/bin/env bash
+set -euo pipefail
+
+FASTWAM_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
+FASTWAM_PYTHON="${FASTWAM_PYTHON:-/public/interns/hubin/code/hubin/miniforge3/envs/fastwam/bin/python3.10}"
+RMBENCH_HELIOS_ROOT="${RMBENCH_HELIOS_ROOT:-/public/interns/hubin/dataset/RMBench/fastwam_helios}"
+
+if [[ $# -lt 2 ]]; then
+  echo "Usage: $0 <task_name> <gpu_id> [max_steps] [hydra overrides ...]" >&2
+  exit 1
+fi
+
+TASK_NAME="$1"
+GPU_ID="$2"
+MAX_STEPS="${3:-2500}"
+if [[ $# -ge 3 ]]; then
+  shift 3
+else
+  shift 2
+fi
+
+OUTPUT_DIR="${RMBENCH_HELIOS_ROOT}/runs/${TASK_NAME}"
+mkdir -p "${OUTPUT_DIR}"
+
+cd "${FASTWAM_ROOT}"
+export CUDA_VISIBLE_DEVICES="${GPU_ID}"
+export RMBENCH_TASK_NAME="${TASK_NAME}"
+export RMBENCH_HELIOS_ROOT
+export PYTHONPATH="${FASTWAM_ROOT}/src:${FASTWAM_ROOT}:${PYTHONPATH:-}"
+export DIFFSYNTH_MODEL_BASE_PATH="${DIFFSYNTH_MODEL_BASE_PATH:-${FASTWAM_ROOT}/checkpoints}"
+
+exec "${FASTWAM_PYTHON}" scripts/train.py \
+  task=rmbench_helios_memory_finetune \
+  "output_dir=${OUTPUT_DIR}" \
+  "max_steps=${MAX_STEPS}" \
+  "$@"
