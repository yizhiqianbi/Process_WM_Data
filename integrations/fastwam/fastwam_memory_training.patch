+        if len(selected) == 4:
+            if self.video_size[0] % 2 or self.video_size[1] % 2:
+                raise ValueError(
+                    "Four-camera FastWAM composites require an even video_size, got "
+                    f"{self.video_size}."
+                )
+            panel_size = (self.video_size[0] // 2, self.video_size[1] // 2)
+            global_primary, primary_rectified = prepare(selected[0], panel_size)
+            global_secondary, secondary_rectified = prepare(selected[1], panel_size)
+            left_wrist, left_rectified = prepare(selected[2], panel_size)
+            right_wrist, right_rectified = prepare(selected[3], panel_size)
+            composite = torch.cat(
+                [
+                    torch.cat([global_primary, global_secondary], dim=-1),
+                    torch.cat([left_wrist, right_wrist], dim=-1),
+                ],
+                dim=-2,
+            )
+            rectified_flags = [
+                primary_rectified,
+                secondary_rectified,
+                left_rectified,
+                right_rectified,
+            ]
+        else:
+            top, top_rectified = prepare(selected[0], (256, 320))
+            left, left_rectified = prepare(selected[1], (128, 160))
+            right, right_rectified = prepare(selected[2], (128, 160))
+            composite = torch.cat([top, torch.cat([left, right], dim=-1)], dim=-2)
+            rectified_flags = [top_rectified, left_rectified, right_rectified]
+        if tuple(composite.shape[-2:]) != self.video_size:
+            composite = transforms_F.resize(
+                composite,
+                size=list(self.video_size),
+                interpolation=transforms_F.InterpolationMode.BILINEAR,
+                antialias=True,
+            )
+        video = composite.mul(2.0).sub(1.0).permute(1, 0, 2, 3).contiguous()
+        rectified = torch.tensor(rectified_flags, dtype=torch.bool)
+        return video, present, rectified
+
+    def _get_cached_text_context(self, prompt: str) -> tuple[torch.Tensor, torch.Tensor]:
+        hashed = hashlib.sha256(prompt.encode("utf-8")).hexdigest()
+        path = self.text_embedding_cache_dir / f"{hashed}.t5_len{self.context_len}.wan22ti2v5b.pt"
+        if not path.is_file():
+            raise FileNotFoundError(
+                f"Missing text embedding cache: {path}. Run scripts/precompute_text_embeds.py first."
+            )
+        payload = torch.load(path, map_location="cpu", weights_only=True)
+        context = payload["context"]
+        context_mask = payload["mask"].to(dtype=torch.bool)
+        if context.ndim != 2 or tuple(context.shape) != (self.context_len, 4096):
+            raise ValueError(
+                f"Cached context must have shape [{self.context_len},4096], got {tuple(context.shape)} in {path}"
+            )
+        if tuple(context_mask.shape) != (self.context_len,):
+            raise ValueError(
+                f"Cached context mask must have shape [{self.context_len}], got {tuple(context_mask.shape)} in {path}"
+            )
+        context = context.clone()
+        context[~context_mask] = 0.0
+        # Keep parity with the Wan2.2 text-conditioning behavior used by RobotVideoDataset.
+        context_mask = torch.ones_like(context_mask)
+        return context, context_mask
+
+    def _build_sample(
+        self,
+        index: int,
+        *,
+        additional_source_indices: Sequence[int] | None = None,
+    ) -> tuple[dict[str, Any], torch.Tensor | None]:
+        ref = self.samples[index]
+        case = self.cases[ref.case_index]
+        episode = self._read_episode(case)
+        start = ref.start
+        stop = start + 81
+        if stop > len(episode["source_frame_index"]):
+            raise IndexError(
+                f"Training window exceeds canonical episode: case_id={case['case_id']}, "
+                f"start={start}, stop={stop}, rows={len(episode['source_frame_index'])}"
+            )
+
+        training = case["training"]
+        has_robot_supervision = (
+            self.include_robot_supervision
+            and str(training.get("mode")) == "joint_video_action"
+            and bool((training.get("loss_mask") or {}).get("action", True))
+        )
+        if has_robot_supervision:
+            state_values = episode["state"][start : start + 80].copy()
+            action_values = episode["action"][start : start + 80].copy()
+            state_valid = episode["state_mask"][start : start + 80].all(axis=0)
+            action_valid = episode["action_mask"][start : start + 80].all(axis=0)
+            state_valid &= np.asarray(case["inputs"]["state_slot_mask"], dtype=np.bool_)
+            action_valid &= np.asarray(case["inputs"]["action_slot_mask"], dtype=np.bool_)
