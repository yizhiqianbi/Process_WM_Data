+from collections import Counter
+
+from fastwam.utils.samplers import ResumableEpochSampler
+
+
+class _GroupedDataset:
+    def __init__(self, group_ids):
+        self.sample_group_ids = tuple(group_ids)
+
+    def __len__(self):
+        return len(self.sample_group_ids)
+
+
+def test_dataset_balanced_sampler_equalizes_group_counts():
+    dataset = _GroupedDataset(["large"] * 10 + ["medium"] * 3 + ["small"])
+    sampler = ResumableEpochSampler(
+        dataset,
+        seed=7,
+        batch_size=1,
+        num_processes=1,
+        sampling_strategy="dataset_balanced",
+    )
+
+    sampled = list(sampler)
+    counts = Counter(dataset.sample_group_ids[index] for index in sampled)
+
+    assert len(sampled) == len(dataset)
+    assert max(counts.values()) - min(counts.values()) <= 1
+    assert set(counts) == {"large", "medium", "small"}
+
+
+def test_dataset_balanced_sampler_is_deterministic_per_epoch():
+    dataset = _GroupedDataset(["a"] * 8 + ["b"] * 2)
+    sampler = ResumableEpochSampler(
+        dataset,
+        seed=11,
+        batch_size=1,
+        num_processes=1,
+        sampling_strategy="dataset_balanced",
+    )
+
+    epoch_zero = list(sampler)
+    assert epoch_zero == list(sampler)
+
+    sampler.set_epoch(1)
+    assert epoch_zero != list(sampler)
+
+
+def test_dataset_balanced_sampler_resume_skips_global_batches():
+    dataset = _GroupedDataset(["a"] * 6 + ["b"] * 6)
+    sampler = ResumableEpochSampler(
+        dataset,
+        seed=5,
+        batch_size=2,
+        num_processes=2,
+        sampling_strategy="dataset_balanced",
+    )
+    full_epoch = list(sampler)
+
+    sampler.set_resume_batch_offset(1)
+    assert list(sampler) == full_epoch[4:]
