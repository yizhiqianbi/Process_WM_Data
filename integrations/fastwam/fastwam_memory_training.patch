+import io
+import json
+from pathlib import Path
+import tarfile
+from types import SimpleNamespace
+
+import pytest
+import torch
+
+from fastwam.datasets.training_case_dataset import (
+    CameraRectificationRegistry,
+    TrainingCaseDataset,
+    materialize_tar_video_member,
+)
+
+
+def test_materialize_tar_video_member_reuses_cached_file(tmp_path, monkeypatch):
+    archive_path = tmp_path / "videos.tar.gz"
+    payload = b"not-a-real-video-but-a-valid-member"
+    with tarfile.open(archive_path, mode="w:gz") as archive:
+        member = tarfile.TarInfo("episodes/example.mp4")
+        member.size = len(payload)
+        archive.addfile(member, io.BytesIO(payload))
+
+    uri = f"tar://{archive_path}!episodes/example.mp4"
+    cached = materialize_tar_video_member(uri, tmp_path / "cache")
+
+    assert cached.read_bytes() == payload
+    assert cached.suffix == ".mp4"
+
+    def fail_if_reopened(*args, **kwargs):
+        raise AssertionError("cache hit must not reopen the tar archive")
+
+    monkeypatch.setattr(tarfile, "open", fail_if_reopened)
+    assert materialize_tar_video_member(uri, tmp_path / "cache") == cached
+
+
+def test_denormalize_action_uses_selected_case_domain_and_masks_invalid_slots():
+    dataset = object.__new__(TrainingCaseDataset)
+    valid = [False] * 80
+    valid[13] = True
+    valid[21] = True
+    dataset._normalization = {
+        "domains": {
+            "tianji": {
+                "action": {
+                    "mean": [1.0] * 80,
+                    "std": [2.0] * 80,
+                    "valid_mask": valid,
+                }
+            }
+        }
+    }
+    dataset.normalization_stats_path = Path("stats.json")
+    dataset.samples = [SimpleNamespace(case_index=0)]
+    dataset.cases = [{"embodiment": {"normalization_domain": "tianji"}}]
+
+    denormalized, valid_tensor = dataset.denormalize_action(
+        torch.full((3, 80), 0.5), sample_index=0
+    )
+
+    assert tuple(denormalized.shape) == (3, 80)
+    assert torch.equal(torch.where(valid_tensor)[0], torch.tensor([13, 21]))
+    assert torch.all(denormalized[:, 13] == 2.0)
+    assert torch.all(denormalized[:, 21] == 2.0)
+    assert torch.count_nonzero(denormalized[:, ~valid_tensor]) == 0
+
+
+def _write_rectification_config(path: Path):
+    path.write_text(
+        json.dumps(
+            {
+                "schema_version": "fastwam-camera-rectification-v1",
+                "profiles": {
+                    "test": {
+                        "model": "opencv_fisheye",
+                        "calibration_status": "synthetic_test",
+                        "image_size": [9, 9],
+                        "camera_matrix": [
+                            [9.0 / torch.pi, 0.0, 4.0],
+                            [0.0, 9.0 / torch.pi, 4.0],
+                            [0.0, 0.0, 1.0],
+                        ],
+                        "distortion_coefficients": [0.0, 0.0, 0.0, 0.0],
+                        "virtual_camera": {"horizontal_fov_degrees": 100.0},
+                    }
+                },
+                "bindings": {
+                    "source_key": {"camera.test": "test"},
+                    "role": {},
+                },
+                "unmatched_policy": "identity",
+            }
+        ),
+        encoding="utf-8",
+    )
+
+
+def test_camera_rectification_preserves_center_and_resizes(tmp_path):
+    config = tmp_path / "rectification.json"
+    _write_rectification_config(config)
+    registry = CameraRectificationRegistry(config)
+    frames = torch.zeros((2, 3, 9, 9), dtype=torch.float32)
+    frames[:, 0, 4, 4] = 1.0
+
+    rectified, applied = registry.rectify(
+        frames,
+        camera={"source_key": "camera.test", "role": "global_primary"},
+        output_size=(5, 7),
+    )
+
+    assert applied
+    assert tuple(rectified.shape) == (2, 3, 5, 7)
+    torch.testing.assert_close(rectified[:, 0, 2, 3], torch.ones(2))
+    assert registry.metadata["calibration_status"] == {"test": "synthetic_test"}
+
+
+def test_camera_rectification_leaves_unbound_camera_as_identity_resize(tmp_path):
+    config = tmp_path / "rectification.json"
+    _write_rectification_config(config)
+    registry = CameraRectificationRegistry(config)
+    frames = torch.rand((1, 3, 9, 9), dtype=torch.float32)
+
+    resized, applied = registry.rectify(
+        frames,
+        camera={"source_key": "camera.other", "role": "auxiliary"},
+        output_size=(5, 7),
+    )
+
+    assert not applied
+    assert tuple(resized.shape) == (1, 3, 5, 7)
+
+
+def test_camera_rectification_rejects_source_size_mismatch(tmp_path):
+    config = tmp_path / "rectification.json"
+    _write_rectification_config(config)
+    registry = CameraRectificationRegistry(config)
+
+    with torch.no_grad(), pytest.raises(ValueError, match="expects source"):
+        registry.rectify(
+            torch.zeros((1, 3, 8, 9), dtype=torch.float32),
+            camera={"source_key": "camera.test", "role": "global_primary"},
+            output_size=(5, 7),
+        )
