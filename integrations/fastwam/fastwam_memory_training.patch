     @torch.no_grad()
+    def _merge_fixed_probe_result_shards(
+        shards: list[list[dict]], expected_indices: tuple[int, ...]
+    ) -> list[dict]:
+        records = [record for shard in shards for record in shard]
+        records.sort(key=lambda record: int(record["eval_probe_position"]))
+        expected_positions = list(range(len(expected_indices)))
+        actual_positions = [int(record["eval_probe_position"]) for record in records]
+        if actual_positions != expected_positions:
+            raise RuntimeError(
+                "Distributed eval probe coverage mismatch: "
+                f"expected_positions={expected_positions}, actual_positions={actual_positions}."
+            )
+        for position, (record, expected_index) in enumerate(
+            zip(records, expected_indices)
+        ):
+            if int(record["eval_index"]) != int(expected_index):
+                raise RuntimeError(
+                    "Distributed eval probe index mismatch at position "
+                    f"{position}: expected={expected_index}, "
+                    f"actual={record['eval_index']}."
+                )
+        return records
