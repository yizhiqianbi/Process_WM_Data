+            [
+                frame_freq.view(frames, 1, 1, -1).expand(frames, height, width, -1),
+                height_freq.view(1, height, 1, -1).expand(frames, height, width, -1),
+                width_freq.view(1, 1, width, -1).expand(frames, height, width, -1),
+            ],
+            dim=-1,
+        ).reshape(frames * height * width, 1, -1)
+
+    def _patch_memory_group(
+        self,
+        *,
+        latents: torch.Tensor,
+        mask: torch.Tensor,
+        group: str,
+        frame_start: int,
+    ) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor, int]:
+        patcher = self.memory_patchers[group]
+        kernel = tuple(int(value) for value in patcher.kernel_size)
+        padded = _pad_for_3d_conv(latents, kernel)
+        token_grid = patcher(padded.to(device=self.device, dtype=self.torch_dtype))
+        batch_size, _, frames, height, width = token_grid.shape
+        tokens = rearrange(token_grid, "b c f h w -> b (f h w) c").contiguous()
+
+        temporal_kernel = kernel[0]
+        temporal_pad = padded.shape[2] - mask.shape[1]
+        if temporal_pad:
+            mask = torch.cat([mask, mask[:, -1:].expand(-1, temporal_pad)], dim=1)
+        frame_valid = mask.view(batch_size, frames, temporal_kernel).any(dim=2)
+        token_valid = (
+            frame_valid[:, :, None]
+            .expand(-1, -1, height * width)
+            .reshape(batch_size, frames * height * width)
+        )
+        tokens = tokens * token_valid.unsqueeze(2).to(dtype=tokens.dtype)
+        freqs = self._freqs_for_grid(
+            frame_indices=torch.arange(frame_start, frame_start + frames, device=tokens.device),
+            height=height,
+            width=width,
+            device=tokens.device,
+        )
+        return tokens, freqs, token_valid, frames
+
+    def _zero_time_mod(
+        self, *, batch_size: int, seq_len: int, device: torch.device, dtype: torch.dtype
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        zero_steps = torch.zeros((batch_size, seq_len), device=device, dtype=dtype)
+        embedding = sinusoidal_embedding_1d(
+            self.video_expert.freq_dim, zero_steps.reshape(-1)
+        )
+        time = self.video_expert.time_embedding(embedding).reshape(
+            batch_size, seq_len, self.video_expert.hidden_dim
+        )
+        time_mod = self.video_expert.time_projection(time).unflatten(
+            2, (6, self.video_expert.hidden_dim)
+        )
+        return time.to(dtype=dtype), time_mod.to(dtype=dtype)
+
+    def _prepend_memory(
+        self, video_pre: dict[str, Any], inputs: dict[str, Any]
+    ) -> tuple[dict[str, Any], torch.Tensor]:
+        frame_start = 0
+        token_groups = []
+        freq_groups = []
+        valid_groups = []
+        for group in ("long", "mid", "short"):
+            tokens, freqs, valid, frame_count = self._patch_memory_group(
+                latents=inputs[f"memory_latents_{group}"],
+                mask=inputs[f"memory_mask_{group}"],
+                group=group,
+                frame_start=frame_start,
+            )
+            frame_start += frame_count
+            token_groups.append(tokens)
+            freq_groups.append(freqs)
+            valid_groups.append(valid)
+
+        memory_tokens = torch.cat(token_groups, dim=1)
+        memory_freqs = torch.cat(freq_groups, dim=0)
+        memory_valid = torch.cat(valid_groups, dim=1)
+        target_tokens = video_pre["tokens"]
+        target_frames, target_height, target_width = video_pre["meta"]["grid_size"]
+        target_freqs = self._freqs_for_grid(
+            frame_indices=torch.arange(
+                frame_start, frame_start + int(target_frames), device=target_tokens.device
+            ),
+            height=int(target_height),
+            width=int(target_width),
+            device=target_tokens.device,
+        )
+        zero_time, zero_time_mod = self._zero_time_mod(
+            batch_size=target_tokens.shape[0],
+            seq_len=memory_tokens.shape[1],
+            device=target_tokens.device,
+            dtype=target_tokens.dtype,
+        )
+
+        context_mask = video_pre["context_mask"]
+        if context_mask.ndim == 3:
+            memory_context_mask = context_mask[:, :1].expand(-1, memory_tokens.shape[1], -1)
+            context_mask = torch.cat([memory_context_mask, context_mask], dim=1)
+        elif context_mask.ndim == 2:
+            context_mask = context_mask.unsqueeze(1).expand(
+                -1, memory_tokens.shape[1] + target_tokens.shape[1], -1
+            )
+        else:
+            raise ValueError(f"Unexpected context mask shape {tuple(context_mask.shape)}")
+
+        output = dict(video_pre)
+        output.update(
+            tokens=torch.cat([memory_tokens, target_tokens], dim=1),
+            freqs=torch.cat([memory_freqs, target_freqs], dim=0),
+            t=torch.cat([zero_time, video_pre["t"]], dim=1),
+            t_mod=torch.cat([zero_time_mod, video_pre["t_mod"]], dim=1),
+            context_mask=context_mask,
+        )
+        return output, memory_valid
+
+    @torch.no_grad()
+    def _build_memory_attention_mask(
+        self,
+        *,
+        memory_valid: torch.Tensor,
+        target_video_seq_len: int,
+        action_seq_len: int,
+        video_tokens_per_frame: int,
+        device: torch.device,
+    ) -> torch.Tensor:
+        batch_size, memory_seq_len = memory_valid.shape
+        video_seq_len = memory_seq_len + target_video_seq_len
+        total_seq_len = video_seq_len + action_seq_len
+        mask = torch.zeros(
+            (batch_size, total_seq_len, total_seq_len), dtype=torch.bool, device=device
+        )
+        memory_valid = memory_valid.to(device=device, dtype=torch.bool)
+        mask[:, :memory_seq_len, :memory_seq_len] = (
+            memory_valid.unsqueeze(2) & memory_valid.unsqueeze(1)
+        )
+
+        target_start = memory_seq_len
+        target_end = video_seq_len
+        mask[:, target_start:target_end, :memory_seq_len] = memory_valid.unsqueeze(1)
+        target_mask = self.video_expert.build_video_to_video_mask(
+            video_seq_len=target_video_seq_len,
+            video_tokens_per_frame=video_tokens_per_frame,
+            device=device,
+        )
+        mask[:, target_start:target_end, target_start:target_end] = target_mask
+
+        mask[:, video_seq_len:, video_seq_len:] = True
+        mask[:, video_seq_len:, :memory_seq_len] = memory_valid.unsqueeze(1)
+        first_target_end = min(target_end, target_start + video_tokens_per_frame)
+        mask[:, video_seq_len:, target_start:first_target_end] = True
+        return mask.unsqueeze(1)
+
+    def _default_inference_memory(self, input_image: torch.Tensor) -> dict[str, torch.Tensor]:
+        def repeated(group: str) -> torch.Tensor:
+            size = self.memory_history_sizes[group]
+            return input_image.unsqueeze(2).expand(-1, -1, size, -1, -1).contiguous()
+
+        return {
+            f"memory_video_{group}": repeated(group)
+            for group in ("long", "mid", "short")
+        } | {
+            f"memory_mask_{group}": torch.zeros(
+                (input_image.shape[0], self.memory_history_sizes[group]),
+                device=input_image.device,
+                dtype=torch.bool,
+            )
+            for group in ("long", "mid", "short")
+        }
+
+    def _prepare_inference_memory(
+        self,
+        *,
+        input_image: torch.Tensor,
+        memory_video: Optional[torch.Tensor],
+        memory_video_long: Optional[torch.Tensor],
+        memory_video_mid: Optional[torch.Tensor],
+        memory_video_short: Optional[torch.Tensor],
+        memory_mask_long: Optional[torch.Tensor],
+        memory_mask_mid: Optional[torch.Tensor],
+        memory_mask_short: Optional[torch.Tensor],
+        tiled: bool,
+    ) -> dict[str, Any]:
+        explicit_videos = {
+            "long": memory_video_long,
+            "mid": memory_video_mid,
+            "short": memory_video_short,
+        }
+        provided = [value is not None for value in explicit_videos.values()]
+        if any(provided) and not all(provided):
+            raise ValueError(
+                "memory_video_long/mid/short must either all be provided or all be omitted."
+            )
+        if all(provided) and memory_video is not None:
+            raise ValueError(
+                "memory_video is mutually exclusive with memory_video_long/mid/short."
+            )
+
+        if not any(provided):
+            if memory_video is None:
+                sample = self._default_inference_memory(input_image)
+            else:
+                if memory_video.ndim == 4:
+                    memory_video = memory_video.unsqueeze(0)
+                if memory_video.ndim != 5 or memory_video.shape[:2] != (1, 3):
+                    raise ValueError(
+                        "memory_video must be closed-loop history [1,3,T,H,W] or [3,T,H,W], "
+                        f"got {tuple(memory_video.shape)}"
+                    )
+                memory_video = memory_video.to(
+                    device=self.device, dtype=self.torch_dtype, non_blocking=True
+                )
+                history = [
+                    memory_video[:, :, frame_index].contiguous()
+                    for frame_index in range(memory_video.shape[2])
+                ]
+                sample = build_multiscale_memory_videos_from_history(
+                    history, history_sizes=self.memory_history_sizes
+                )
+        else:
+            sample = {}
+            masks = {
+                "long": memory_mask_long,
+                "mid": memory_mask_mid,
+                "short": memory_mask_short,
+            }
+            for group, video in explicit_videos.items():
+                if video is None:
+                    raise RuntimeError(f"Missing explicit memory video group {group}")
+                if video.ndim == 4:
+                    video = video.unsqueeze(0)
+                expected_frames = self.memory_history_sizes[group]
+                if (
+                    video.ndim != 5
+                    or video.shape[0] != 1
+                    or video.shape[1] != 3
+                    or video.shape[2] != expected_frames
+                ):
+                    raise ValueError(
+                        f"memory_video_{group} must be [1,3,{expected_frames},H,W] "
+                        f"or [3,{expected_frames},H,W], got {tuple(video.shape)}"
+                    )
+                sample[f"memory_video_{group}"] = video
+                if masks[group] is not None:
+                    sample[f"memory_mask_{group}"] = masks[group]
+        return self._build_memory_inputs(sample, tiled=tiled)
+
+    @torch.no_grad()
+    def infer_action(
+        self,
+        prompt: Optional[str],
+        input_image: torch.Tensor,
+        action_horizon: int,
+        action_dim_is_pad: Optional[torch.Tensor] = None,
+        proprio: Optional[torch.Tensor] = None,
+        memory_video: Optional[torch.Tensor] = None,
+        memory_video_long: Optional[torch.Tensor] = None,
+        memory_video_mid: Optional[torch.Tensor] = None,
+        memory_video_short: Optional[torch.Tensor] = None,
+        memory_mask_long: Optional[torch.Tensor] = None,
+        memory_mask_mid: Optional[torch.Tensor] = None,
+        memory_mask_short: Optional[torch.Tensor] = None,
+        context: Optional[torch.Tensor] = None,
+        context_mask: Optional[torch.Tensor] = None,
+        negative_prompt: Optional[str] = None,
+        text_cfg_scale: float = 1.0,
+        num_inference_steps: int = 20,
+        sigma_shift: Optional[float] = None,
+        seed: Optional[int] = None,
+        rand_device: str = "cpu",
+        tiled: bool = False,
+    ) -> dict[str, Any]:
+        del negative_prompt, text_cfg_scale
+        self.eval()
+        if str(getattr(self.video_expert, "video_attention_mask_mode", "")) != "first_frame_causal":
+            raise ValueError(
+                "MemoryFastWAM.infer_action requires video_attention_mask_mode='first_frame_causal'."
+            )
+        if int(action_horizon) <= 0:
+            raise ValueError("action_horizon must be positive.")
+        if input_image.ndim == 3:
+            input_image = input_image.unsqueeze(0)
+        if input_image.ndim != 4 or input_image.shape[0] != 1 or input_image.shape[1] != 3:
+            raise ValueError(
+                f"input_image must be [1,3,H,W] or [3,H,W], got {tuple(input_image.shape)}"
+            )
+        height, width = int(input_image.shape[-2]), int(input_image.shape[-1])
+        if height % 16 or width % 16:
+            raise ValueError(
+                f"input_image H/W must be multiples of 16, got ({height},{width})."
+            )
+
+        if proprio is not None:
+            if self.proprio_dim is None:
+                raise ValueError("proprio was provided but proprio_dim=None.")
+            if proprio.ndim == 1:
+                proprio = proprio.unsqueeze(0)
+            if proprio.ndim != 2 or proprio.shape != (1, self.proprio_dim):
+                raise ValueError(
+                    f"proprio must be [D] or [1,D] with D={self.proprio_dim}, "
+                    f"got {tuple(proprio.shape)}"
+                )
+            proprio = proprio.to(device=self.device, dtype=self.torch_dtype)
+
+        use_prompt = prompt is not None
+        use_context = context is not None or context_mask is not None
+        if use_prompt and use_context:
+            raise ValueError("prompt and context/context_mask are mutually exclusive.")
+        if not use_prompt and not use_context:
+            raise ValueError("Either prompt or both context/context_mask must be provided.")
+        if use_prompt:
+            context, context_mask = self.encode_prompt(prompt)
+        else:
+            if context is None or context_mask is None:
+                raise ValueError("context and context_mask must be provided together.")
+            if context.ndim == 2:
+                context = context.unsqueeze(0)
+            if context_mask.ndim == 1:
+                context_mask = context_mask.unsqueeze(0)
+            if context.ndim != 3 or context_mask.ndim != 2 or context.shape[0] != 1:
+                raise ValueError(
+                    "context/context_mask must be [1,L,D]/[1,L], got "
+                    f"{tuple(context.shape)} and {tuple(context_mask.shape)}"
+                )
+            context = context.to(
+                device=self.device, dtype=self.torch_dtype, non_blocking=True
+            )
+            context_mask = context_mask.to(
+                device=self.device, dtype=torch.bool, non_blocking=True
+            )
+        if proprio is not None:
+            context, context_mask = self._append_proprio_to_context(
+                context=context,
+                context_mask=context_mask,
+                proprio=proprio,
+            )
+
+        generator = None if seed is None else torch.Generator(device=rand_device).manual_seed(seed)
+        latents_action = torch.randn(
+            (1, int(action_horizon), self.action_expert.action_dim),
+            generator=generator,
+            device=rand_device,
+            dtype=torch.float32,
+        ).to(device=self.device, dtype=self.torch_dtype)
+        action_padding_mask = self._prepare_action_dim_padding_mask(
+            action_dim_is_pad,
+            action_dim=int(self.action_expert.action_dim),
+            device=self.device,
+        )
+        latents_action = self._mask_padded_action_dims(
+            latents_action, action_padding_mask
+        )
+
+        input_image = input_image.to(device=self.device, dtype=self.torch_dtype)
+        memory_inputs = self._prepare_inference_memory(
+            input_image=input_image,
+            memory_video=memory_video,
+            memory_video_long=memory_video_long,
+            memory_video_mid=memory_video_mid,
+            memory_video_short=memory_video_short,
+            memory_mask_long=memory_mask_long,
+            memory_mask_mid=memory_mask_mid,
+            memory_mask_short=memory_mask_short,
+            tiled=tiled,
+        )
+        first_frame_latents = self._encode_input_image_latents_tensor(
+            input_image=input_image, tiled=tiled
+        )
+        fuse_flag = bool(
+            getattr(self.video_expert, "fuse_vae_embedding_in_latents", False)
+        )
+        timestep_video = torch.zeros(
+            (1,), dtype=first_frame_latents.dtype, device=self.device
+        )
+        video_pre_target = self.video_expert.pre_dit(
+            x=first_frame_latents,
+            timestep=timestep_video,
+            context=context,
+            context_mask=context_mask,
+            action=None,
+            fuse_vae_embedding_in_latents=fuse_flag,
+        )
+        video_pre_model, memory_valid = self._prepend_memory(
+            video_pre_target, memory_inputs
+        )
+        video_seq_len = int(video_pre_model["tokens"].shape[1])
+        attention_mask = self._build_memory_attention_mask(
+            memory_valid=memory_valid,
+            target_video_seq_len=int(video_pre_target["tokens"].shape[1]),
+            action_seq_len=int(latents_action.shape[1]),
+            video_tokens_per_frame=int(video_pre_target["meta"]["tokens_per_frame"]),
+            device=video_pre_model["tokens"].device,
+        )
+        video_kv_cache = self.mot.prefill_video_cache(
+            video_tokens=video_pre_model["tokens"],
+            video_freqs=video_pre_model["freqs"],
+            video_t_mod=video_pre_model["t_mod"],
+            video_context_payload={
+                "context": video_pre_model["context"],
+                "mask": video_pre_model["context_mask"],
+            },
+            video_attention_mask=attention_mask[
+                ..., :video_seq_len, :video_seq_len
+            ],
+        )
+
+        infer_timesteps, infer_deltas = self.infer_action_scheduler.build_inference_schedule(
+            num_inference_steps=num_inference_steps,
+            device=self.device,
+            dtype=latents_action.dtype,
+            shift_override=sigma_shift,
+        )
+        for step_t, step_delta in zip(infer_timesteps, infer_deltas):
+            timestep_action = step_t.unsqueeze(0).to(
+                dtype=latents_action.dtype, device=self.device
+            )
+            pred_action = self._predict_action_noise_with_cache(
+                latents_action=latents_action,
+                timestep_action=timestep_action,
+                context=context,
+                context_mask=context_mask,
+                video_kv_cache=video_kv_cache,
+                attention_mask=attention_mask,
+                video_seq_len=video_seq_len,
+            )
+            latents_action = self.infer_action_scheduler.step(
+                pred_action, step_delta, latents_action
+            )
+            latents_action = self._mask_padded_action_dims(
+                latents_action, action_padding_mask
+            )
+        return {
+            "action": latents_action[0].detach().to(device="cpu", dtype=torch.float32),
+            "memory_valid_ratio": float(memory_valid.float().mean().item()),
+        }
+
+    @torch.no_grad()
+    def _predict_joint_noise_with_memory(
+        self,
+        *,
+        latents_video: torch.Tensor,
+        latents_action: torch.Tensor,
+        timestep_video: torch.Tensor,
+        timestep_action: torch.Tensor,
+        context: torch.Tensor,
+        context_mask: torch.Tensor,
+        fuse_vae_embedding_in_latents: bool,
+        memory_inputs: dict[str, Any],
+        gt_action: Optional[torch.Tensor] = None,
+    ) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+        video_pre_target = self.video_expert.pre_dit(
+            x=latents_video,
+            timestep=timestep_video,
+            context=context,
+            context_mask=context_mask,
+            action=gt_action,
+            fuse_vae_embedding_in_latents=fuse_vae_embedding_in_latents,
+        )
+        video_pre_model, memory_valid = self._prepend_memory(
+            video_pre_target, memory_inputs
+        )
+        action_pre = self.action_expert.pre_dit(
+            action_tokens=latents_action,
+            timestep=timestep_action,
+            context=context,
+            context_mask=context_mask,
+        )
+        attention_mask = self._build_memory_attention_mask(
+            memory_valid=memory_valid,
+            target_video_seq_len=int(video_pre_target["tokens"].shape[1]),
+            action_seq_len=int(action_pre["tokens"].shape[1]),
+            video_tokens_per_frame=int(video_pre_target["meta"]["tokens_per_frame"]),
+            device=video_pre_model["tokens"].device,
+        )
+        tokens_out = self.mot(
+            embeds_all={
+                "video": video_pre_model["tokens"],
+                "action": action_pre["tokens"],
+            },
+            attention_mask=attention_mask,
+            freqs_all={
+                "video": video_pre_model["freqs"],
+                "action": action_pre["freqs"],
+            },
+            context_all={
+                "video": {
+                    "context": video_pre_model["context"],
+                    "mask": video_pre_model["context_mask"],
+                },
+                "action": {
+                    "context": action_pre["context"],
+                    "mask": action_pre["context_mask"],
+                },
+            },
+            t_mod_all={
+                "video": video_pre_model["t_mod"],
+                "action": action_pre["t_mod"],
+            },
+        )
+        memory_seq_len = int(memory_valid.shape[1])
+        pred_video = self.video_expert.post_dit(
+            tokens_out["video"][:, memory_seq_len:], video_pre_target
+        )
+        pred_action = self.action_expert.post_dit(tokens_out["action"], action_pre)
+        return pred_video, pred_action, memory_valid
+
+    @torch.no_grad()
+    def infer_joint(
+        self,
+        prompt: Optional[str],
+        input_image: torch.Tensor,
+        num_video_frames: int,
+        action_horizon: int,
+        action: Optional[torch.Tensor] = None,
+        action_dim_is_pad: Optional[torch.Tensor] = None,
+        proprio: Optional[torch.Tensor] = None,
+        memory_video: Optional[torch.Tensor] = None,
+        memory_video_long: Optional[torch.Tensor] = None,
+        memory_video_mid: Optional[torch.Tensor] = None,
+        memory_video_short: Optional[torch.Tensor] = None,
+        memory_mask_long: Optional[torch.Tensor] = None,
+        memory_mask_mid: Optional[torch.Tensor] = None,
+        memory_mask_short: Optional[torch.Tensor] = None,
+        context: Optional[torch.Tensor] = None,
+        context_mask: Optional[torch.Tensor] = None,
+        negative_prompt: Optional[str] = None,
+        text_cfg_scale: float = 1.0,
+        num_inference_steps: int = 20,
+        sigma_shift: Optional[float] = None,
+        seed: Optional[int] = None,
+        rand_device: str = "cpu",
+        tiled: bool = False,
+        test_action_with_infer_action: bool = False,
+    ) -> dict[str, Any]:
+        del negative_prompt, text_cfg_scale
+        self.eval()
+        if str(getattr(self.video_expert, "video_attention_mask_mode", "")) != "first_frame_causal":
+            raise ValueError(
+                "MemoryFastWAM.infer_joint requires "
+                "video_attention_mask_mode='first_frame_causal'."
+            )
+        if int(action_horizon) <= 0:
+            raise ValueError("action_horizon must be positive.")
+        if input_image.ndim == 3:
+            input_image = input_image.unsqueeze(0)
+        if input_image.ndim != 4 or input_image.shape[0] != 1 or input_image.shape[1] != 3:
+            raise ValueError(
+                f"input_image must be [1,3,H,W] or [3,H,W], got {tuple(input_image.shape)}"
+            )
+        _, _, height, width = input_image.shape
+        checked_h, checked_w, checked_t = self._check_resize_height_width(
+            height, width, int(num_video_frames)
+        )
+        if (checked_h, checked_w) != (height, width):
+            raise ValueError(
+                "input_image must be resized before infer; "
+                f"expected multiples of 16, got HxW=({height},{width})."
+            )
+        if checked_t != int(num_video_frames):
+            raise ValueError(
+                f"num_video_frames must satisfy T % 4 == 1, got {num_video_frames}."
+            )
+
+        if action is not None:
+            if action.ndim == 2:
+                action = action.unsqueeze(0)
+            expected_action_shape = (
+                1,
+                int(action_horizon),
+                int(self.action_expert.action_dim),
+            )
+            if tuple(action.shape) != expected_action_shape:
+                raise ValueError(
+                    f"action must have shape {expected_action_shape} or without the batch "
+                    f"dimension, got {tuple(action.shape)}."
+                )
+            action = action.to(device=self.device, dtype=self.torch_dtype)
+
+        if proprio is not None:
+            if self.proprio_dim is None:
+                raise ValueError("proprio was provided but proprio_dim=None.")
+            if proprio.ndim == 1:
+                proprio = proprio.unsqueeze(0)
+            expected_proprio_shape = (1, int(self.proprio_dim))
+            if tuple(proprio.shape) != expected_proprio_shape:
+                raise ValueError(
+                    f"proprio must have shape {expected_proprio_shape} or without the batch "
+                    f"dimension, got {tuple(proprio.shape)}."
+                )
+            proprio = proprio.to(device=self.device, dtype=self.torch_dtype)
+
+        use_prompt = prompt is not None
+        use_context = context is not None or context_mask is not None
+        if use_prompt and use_context:
+            raise ValueError("prompt and context/context_mask are mutually exclusive.")
+        if not use_prompt and not use_context:
+            raise ValueError("Either prompt or both context/context_mask must be provided.")
+        if use_prompt:
+            context, context_mask = self.encode_prompt(prompt)
+        else:
+            if context is None or context_mask is None:
+                raise ValueError("context and context_mask must be provided together.")
+            if context.ndim == 2:
+                context = context.unsqueeze(0)
+            if context_mask.ndim == 1:
+                context_mask = context_mask.unsqueeze(0)
+            if (
+                context.ndim != 3
+                or context_mask.ndim != 2
+                or context.shape[0] != 1
+                or context_mask.shape[0] != 1
+            ):
+                raise ValueError(
+                    "context/context_mask must be [1,L,D]/[1,L], got "
+                    f"{tuple(context.shape)} and {tuple(context_mask.shape)}."
+                )
+            context = context.to(
+                device=self.device, dtype=self.torch_dtype, non_blocking=True
+            )
+            context_mask = context_mask.to(
+                device=self.device, dtype=torch.bool, non_blocking=True
+            )
+        if proprio is not None:
+            context, context_mask = self._append_proprio_to_context(
+                context=context,
+                context_mask=context_mask,
+                proprio=proprio,
+            )
+
+        latent_t = (
+            (int(num_video_frames) - 1) // self.vae.temporal_downsample_factor + 1
+        )
+        latent_h = height // self.vae.upsampling_factor
+        latent_w = width // self.vae.upsampling_factor
+        video_generator = (
+            None
+            if seed is None
+            else torch.Generator(device=rand_device).manual_seed(seed)
+        )
+        action_generator = (
+            None
+            if seed is None
+            else torch.Generator(device=rand_device).manual_seed(seed)
+        )
+        latents_video = torch.randn(
+            (1, self.vae.model.z_dim, latent_t, latent_h, latent_w),
+            generator=video_generator,
+            device=rand_device,
+            dtype=torch.float32,
+        ).to(device=self.device, dtype=self.torch_dtype)
+        latents_action = torch.randn(
+            (1, int(action_horizon), int(self.action_expert.action_dim)),
+            generator=action_generator,
+            device=rand_device,
+            dtype=torch.float32,
+        ).to(device=self.device, dtype=self.torch_dtype)
+        action_padding_mask = self._prepare_action_dim_padding_mask(
+            action_dim_is_pad,
+            action_dim=int(self.action_expert.action_dim),
+            device=self.device,
+        )
+        latents_action = self._mask_padded_action_dims(
+            latents_action, action_padding_mask
+        )
+
+        input_image = input_image.to(device=self.device, dtype=self.torch_dtype)
+        first_frame_latents = self._encode_input_image_latents_tensor(
+            input_image=input_image, tiled=tiled
+        )
+        latents_video[:, :, :1] = first_frame_latents
+        memory_inputs = self._prepare_inference_memory(
+            input_image=input_image,
+            memory_video=memory_video,
+            memory_video_long=memory_video_long,
+            memory_video_mid=memory_video_mid,
+            memory_video_short=memory_video_short,
+            memory_mask_long=memory_mask_long,
+            memory_mask_mid=memory_mask_mid,
+            memory_mask_short=memory_mask_short,
+            tiled=tiled,
+        )
+        fuse_flag = bool(
+            getattr(self.video_expert, "fuse_vae_embedding_in_latents", False)
+        )
+
+        action_only_out = None
+        if test_action_with_infer_action:
+            if seed is None:
+                raise ValueError(
+                    "test_action_with_infer_action=True requires a non-null seed."
+                )
+            action_only_out = self.infer_action(
+                prompt=None,
+                input_image=input_image,
+                action_horizon=int(action_horizon),
+                action_dim_is_pad=action_dim_is_pad,
+                proprio=None,
+                memory_video=memory_video,
+                memory_video_long=memory_video_long,
+                memory_video_mid=memory_video_mid,
+                memory_video_short=memory_video_short,
+                memory_mask_long=memory_mask_long,
+                memory_mask_mid=memory_mask_mid,
+                memory_mask_short=memory_mask_short,
+                context=context,
+                context_mask=context_mask,
+                num_inference_steps=num_inference_steps,
+                sigma_shift=sigma_shift,
+                seed=seed,
+                rand_device=rand_device,
+                tiled=tiled,
+            )["action"]
+
+        infer_timesteps_video, infer_deltas_video = (
+            self.infer_video_scheduler.build_inference_schedule(
+                num_inference_steps=num_inference_steps,
+                device=self.device,
+                dtype=latents_video.dtype,
+                shift_override=sigma_shift,
+            )
+        )
+        infer_timesteps_action, infer_deltas_action = (
+            self.infer_action_scheduler.build_inference_schedule(
+                num_inference_steps=num_inference_steps,
+                device=self.device,
+                dtype=latents_action.dtype,
+                shift_override=sigma_shift,
+            )
+        )
+        memory_valid = None
+        for step_t_video, step_delta_video, step_t_action, step_delta_action in zip(
+            infer_timesteps_video,
+            infer_deltas_video,
+            infer_timesteps_action,
+            infer_deltas_action,
+        ):
+            timestep_video = step_t_video.unsqueeze(0).to(
+                dtype=latents_video.dtype, device=self.device
+            )
+            timestep_action = step_t_action.unsqueeze(0).to(
+                dtype=latents_action.dtype, device=self.device
+            )
+            pred_video, pred_action, memory_valid = (
+                self._predict_joint_noise_with_memory(
+                    latents_video=latents_video,
+                    latents_action=latents_action,
+                    timestep_video=timestep_video,
+                    timestep_action=timestep_action,
+                    context=context,
+                    context_mask=context_mask,
+                    fuse_vae_embedding_in_latents=fuse_flag,
+                    memory_inputs=memory_inputs,
+                    gt_action=action,
+                )
+            )
+            latents_video = self.infer_video_scheduler.step(
+                pred_video, step_delta_video, latents_video
+            )
+            latents_action = self.infer_action_scheduler.step(
+                pred_action, step_delta_action, latents_action
+            )
+            latents_action = self._mask_padded_action_dims(
+                latents_action, action_padding_mask
+            )
+            latents_video[:, :, :1] = first_frame_latents
+
+        if memory_valid is None:
+            raise RuntimeError("Joint inference schedule produced no denoising steps.")
+        action_out = latents_action[0].detach().to(
+            device="cpu", dtype=torch.float32
+        )
+        if action_only_out is not None and not torch.allclose(
+            action_out, action_only_out, atol=1e-2, rtol=1e-2
+        ):
+            logger.warning(
+                "Memory joint/action-only inference differ: max_abs_diff=%.6f",
+                float((action_out - action_only_out).abs().max().item()),
+            )
+        return {
+            "video": self._decode_latents(latents_video, tiled=tiled),
+            "action": action_out,
+            "memory_valid_ratio": float(memory_valid.float().mean().item()),
+        }
+
+    @torch.no_grad()
+    def infer(
+        self,
+        prompt: Optional[str],
+        input_image: torch.Tensor,
+        num_frames: int,
+        action: Optional[torch.Tensor] = None,
+        action_horizon: Optional[int] = None,
+        action_dim_is_pad: Optional[torch.Tensor] = None,
+        proprio: Optional[torch.Tensor] = None,
+        memory_video: Optional[torch.Tensor] = None,
+        memory_video_long: Optional[torch.Tensor] = None,
+        memory_video_mid: Optional[torch.Tensor] = None,
+        memory_video_short: Optional[torch.Tensor] = None,
+        memory_mask_long: Optional[torch.Tensor] = None,
+        memory_mask_mid: Optional[torch.Tensor] = None,
+        memory_mask_short: Optional[torch.Tensor] = None,
+        context: Optional[torch.Tensor] = None,
+        context_mask: Optional[torch.Tensor] = None,
+        negative_prompt: Optional[str] = None,
+        text_cfg_scale: float = 5.0,
+        action_cfg_scale: float = 1.0,
+        num_inference_steps: int = 20,
+        sigma_shift: Optional[float] = None,
+        seed: Optional[int] = None,
+        rand_device: str = "cpu",
+        tiled: bool = False,
+    ) -> dict[str, Any]:
+        del action_cfg_scale
+        if action_horizon is None:
+            raise ValueError("action_horizon is required for MemoryFastWAM inference.")
+        return self.infer_joint(
+            prompt=prompt,
+            input_image=input_image,
+            num_video_frames=num_frames,
+            action_horizon=int(action_horizon),
+            action=action,
+            action_dim_is_pad=action_dim_is_pad,
+            proprio=proprio,
+            memory_video=memory_video,
+            memory_video_long=memory_video_long,
+            memory_video_mid=memory_video_mid,
+            memory_video_short=memory_video_short,
+            memory_mask_long=memory_mask_long,
+            memory_mask_mid=memory_mask_mid,
+            memory_mask_short=memory_mask_short,
+            context=context,
+            context_mask=context_mask,
+            negative_prompt=negative_prompt,
+            text_cfg_scale=text_cfg_scale,
+            num_inference_steps=num_inference_steps,
+            sigma_shift=sigma_shift,
+            seed=seed,
+            rand_device=rand_device,
+            tiled=tiled,
+        )
+
+    def training_loss(self, sample, tiled: bool = False):
+        inputs = self.build_inputs(sample, tiled=tiled)
+        input_latents = inputs["input_latents"]
+        batch_size = input_latents.shape[0]
+        action = inputs["action"]
+        action_is_pad = inputs["action_is_pad"]
+        action_dim_is_pad = inputs["action_dim_is_pad"]
+
+        noise_video = torch.randn_like(input_latents)
+        timestep_video = self.train_video_scheduler.sample_training_t(
+            batch_size=batch_size, device=self.device, dtype=input_latents.dtype
+        )
+        latents = self.train_video_scheduler.add_noise(
+            input_latents, noise_video, timestep_video
+        )
+        target_video = self.train_video_scheduler.training_target(
+            input_latents, noise_video, timestep_video
+        )
+        if inputs["first_frame_latents"] is not None:
+            latents[:, :, :1] = inputs["first_frame_latents"]
+
+        noise_action = torch.randn_like(action)
+        if action_dim_is_pad is not None:
+            noise_action = noise_action.masked_fill(action_dim_is_pad.unsqueeze(1), 0.0)
+        timestep_action = self.train_action_scheduler.sample_training_t(
+            batch_size=batch_size, device=self.device, dtype=action.dtype
+        )
+        noisy_action = self.train_action_scheduler.add_noise(
+            action, noise_action, timestep_action
+        )
+        target_action = self.train_action_scheduler.training_target(
+            action, noise_action, timestep_action
+        )
+        if action_dim_is_pad is not None:
+            invalid = action_dim_is_pad.unsqueeze(1)
+            noisy_action = noisy_action.masked_fill(invalid, 0.0)
+            target_action = target_action.masked_fill(invalid, 0.0)
+
+        video_pre_target = self.video_expert.pre_dit(
+            x=latents,
+            timestep=timestep_video,
+            context=inputs["context"],
+            context_mask=inputs["context_mask"],
+            action=action,
+            fuse_vae_embedding_in_latents=inputs["fuse_vae_embedding_in_latents"],
+        )
+        video_pre_model, memory_valid = self._prepend_memory(video_pre_target, inputs)
+        action_pre = self.action_expert.pre_dit(
+            action_tokens=noisy_action,
+            timestep=timestep_action,
+            context=inputs["context"],
+            context_mask=inputs["context_mask"],
+        )
+        attention_mask = self._build_memory_attention_mask(
+            memory_valid=memory_valid,
+            target_video_seq_len=video_pre_target["tokens"].shape[1],
+            action_seq_len=action_pre["tokens"].shape[1],
+            video_tokens_per_frame=int(video_pre_target["meta"]["tokens_per_frame"]),
+            device=video_pre_model["tokens"].device,
+        )
+        tokens_out = self.mot(
+            embeds_all={"video": video_pre_model["tokens"], "action": action_pre["tokens"]},
+            attention_mask=attention_mask,
+            freqs_all={"video": video_pre_model["freqs"], "action": action_pre["freqs"]},
+            context_all={
+                "video": {
+                    "context": video_pre_model["context"],
+                    "mask": video_pre_model["context_mask"],
+                },
+                "action": {"context": action_pre["context"], "mask": action_pre["context_mask"]},
+            },
+            t_mod_all={"video": video_pre_model["t_mod"], "action": action_pre["t_mod"]},
+        )
+
+        memory_seq_len = memory_valid.shape[1]
+        pred_video = self.video_expert.post_dit(
+            tokens_out["video"][:, memory_seq_len:], video_pre_target
+        )
+        pred_action = self.action_expert.post_dit(tokens_out["action"], action_pre)
+        include_initial_video_step = inputs["first_frame_latents"] is None
+        if not include_initial_video_step:
+            pred_video = pred_video[:, :, 1:]
+            target_video = target_video[:, :, 1:]
+
+        video_per_sample = self._compute_video_loss_per_sample(
+            pred_video=pred_video,
+            target_video=target_video,
+            image_is_pad=inputs["image_is_pad"],
+            include_initial_video_step=include_initial_video_step,
+        )
+        video_scheduler_weight = self.train_video_scheduler.training_weight(timestep_video).to(
+            video_per_sample.device, dtype=video_per_sample.dtype
+        )
+        loss_video = self._weighted_loss_mean(
+            loss_per_sample=video_per_sample,
+            scheduler_weight=video_scheduler_weight,
+            loss_mask=inputs["video_loss_mask"],
+            loss_weight=inputs["video_loss_weight"],
+            sample_weight=inputs["sample_weight"],
+        )
+
+        action_per_sample = self._compute_action_loss_per_sample(
+            pred_action=pred_action,
+            target_action=target_action,
+            action_is_pad=action_is_pad,
+            action_dim_is_pad=action_dim_is_pad,
+        )
+        action_scheduler_weight = self.train_action_scheduler.training_weight(
+            timestep_action
+        ).to(action_per_sample.device, dtype=action_per_sample.dtype)
+        loss_action = self._weighted_loss_mean(
+            loss_per_sample=action_per_sample,
+            scheduler_weight=action_scheduler_weight,
+            loss_mask=inputs["action_loss_mask"],
+            loss_weight=inputs["action_loss_weight"],
+            sample_weight=inputs["sample_weight"],
+        )
+        total = self.loss_lambda_video * loss_video + self.loss_lambda_action * loss_action
+        return total, {
+            "loss_video": self.loss_lambda_video * float(loss_video.detach().item()),
+            "loss_action": self.loss_lambda_action * float(loss_action.detach().item()),
+            "memory_tokens": float(memory_seq_len),
+            "memory_valid_ratio": float(memory_valid.float().mean().detach().item()),
+        }
+
+    def set_configured_train_mode(self) -> None:
+        self.eval()
+        self.requires_grad_(False)
+        self.vae.eval()
+        self.mot.train()
+        self.mot.requires_grad_(True)
+        self.memory_patchers.train()
+        self.memory_patchers.requires_grad_(True)
+        if self.proprio_encoder is not None:
+            self.proprio_encoder.train()
+            self.proprio_encoder.requires_grad_(True)
+
+    def configure_trainable_parameters(
+        self, *, backbone_lr: float, reference_lr: float, weight_decay: float
+    ) -> list[dict[str, Any]]:
+        self.set_configured_train_mode()
+        backbone = list(self.mot.parameters())
+        if self.proprio_encoder is not None:
+            backbone.extend(self.proprio_encoder.parameters())
+        memory = list(self.memory_patchers.parameters())
+        logger.info(
+            "MemoryFastWAM trainable params: backbone=%.3fM memory=%.3fM",
+            sum(parameter.numel() for parameter in backbone) / 1e6,
+            sum(parameter.numel() for parameter in memory) / 1e6,
+        )
+        return [
+            {"params": backbone, "lr": float(backbone_lr), "weight_decay": float(weight_decay)},
+            {"params": memory, "lr": float(reference_lr), "weight_decay": float(weight_decay)},
+        ]
+
+    def save_checkpoint(self, path, optimizer=None, step=None):
+        payload = {
+            "mot": self.mot.state_dict(),
+            "memory_patchers": self.memory_patchers.state_dict(),
+            "memory_history_sizes": dict(self.memory_history_sizes),
+            "model_paths": getattr(self, "model_paths", {}),
+            "step": step,
+            "torch_dtype": str(self.torch_dtype),
+            "memory_fastwam": True,
+        }
+        if self.proprio_encoder is not None:
+            payload["proprio_encoder"] = self.proprio_encoder.state_dict()
+        if optimizer is not None:
+            payload["optimizer"] = optimizer.state_dict()
+        torch.save(payload, path)
+
+    def load_checkpoint(self, path, optimizer=None):
+        payload = torch.load(path, map_location="cpu", weights_only=True)
+        if "mot" not in payload:
+            raise ValueError(f"MemoryFastWAM checkpoint has no `mot`: {path}")
+        checkpoint_history = payload.get("memory_history_sizes")
+        if checkpoint_history is not None and dict(checkpoint_history) != dict(
+            self.memory_history_sizes
+        ):
+            raise ValueError(
+                "Memory history mismatch: "
+                f"checkpoint={dict(checkpoint_history)}, model={self.memory_history_sizes}"
+            )
+        self.mot.load_state_dict(payload["mot"], strict=True)
+        if "memory_patchers" in payload:
+            self.memory_patchers.load_state_dict(payload["memory_patchers"], strict=True)
+        else:
+            logger.warning("Checkpoint has no memory patchers; using initialized values")
+        if self.proprio_encoder is not None and "proprio_encoder" in payload:
+            self.proprio_encoder.load_state_dict(payload["proprio_encoder"], strict=True)
+        if optimizer is not None and "optimizer" in payload:
+            optimizer.load_state_dict(payload["optimizer"])
+        return payload
