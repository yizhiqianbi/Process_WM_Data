+import json
+from pathlib import Path
+
+import hydra
+import torch
+from hydra.utils import instantiate
+from omegaconf import DictConfig
+from torch.utils.data import DataLoader
+
+from fastwam.utils.config_resolvers import register_default_resolvers
+
+
+register_default_resolvers()
+
+
+@hydra.main(config_path="../configs", config_name="train", version_base="1.3")
+def main(cfg: DictConfig):
+    dataset = instantiate(cfg.data.train)
+    validate_all = bool(cfg.get("validate_all", False))
+    indices = range(len(dataset)) if validate_all else range(1)
+    sample = None
+    for index in indices:
+        current = dataset[index]
+        if sample is None:
+            sample = current
+        expected = {
+            "video": (3, 21, 384, 320),
+            "action": (80, 80),
+            "proprio": (80, 80),
+            "context": (128, 4096),
+        }
+        for key, shape in expected.items():
+            if tuple(current[key].shape) != shape:
+                raise ValueError(
+                    f"sample={index} {key} shape mismatch: expected={shape}, got={tuple(current[key].shape)}"
+                )
+            if not torch.isfinite(current[key]).all():
+                raise ValueError(f"sample={index} {key} contains non-finite values")
+    if sample is None:
+        raise ValueError("Dataset is empty")
+    batch = next(iter(DataLoader(dataset, batch_size=1, num_workers=0)))
+
+    if tuple(batch["video"].shape) != (1, 3, 21, 384, 320):
+        raise ValueError(f"Collated video shape mismatch: {tuple(batch['video'].shape)}")
+
+    result = {
+        "status": "passed",
+        "windows": len(dataset),
+        "validated_windows": len(dataset) if validate_all else 1,
+        "video_shape": list(sample["video"].shape),
+        "action_shape": list(sample["action"].shape),
+        "proprio_shape": list(sample["proprio"].shape),
+        "context_shape": list(sample["context"].shape),
+        "active_action_dimensions": int((~sample["action_dim_is_pad"]).sum()),
+        "active_state_dimensions": int((~sample["proprio_dim_is_pad"]).sum()),
+        "camera_present_mask": sample["camera_present_mask"].tolist(),
+        "camera_rectification_applied_mask": sample.get(
+            "camera_rectification_applied_mask",
+            torch.zeros(3, dtype=torch.bool),
+        ).tolist(),
+        "camera_rectification": getattr(
+            dataset, "camera_rectification_metadata", None
+        ),
+        "video_min": float(sample["video"].min()),
+        "video_max": float(sample["video"].max()),
+    }
+    report_path = cfg.get("validation_report", None)
+    if report_path:
+        path = Path(str(report_path)).expanduser()
+        path.parent.mkdir(parents=True, exist_ok=True)
+        path.write_text(json.dumps(result, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    print(json.dumps(result, sort_keys=True))
+
+
+if __name__ == "__main__":
+    main()
