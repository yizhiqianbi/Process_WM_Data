+
+    def fake_decode(uri, source_indices, **kwargs):
+        value = values[uri]
+        return torch.full((len(source_indices), 4, 4, 3), value, dtype=torch.uint8)
+
+    monkeypatch.setattr(training_case_dataset, "decode_video_frames", fake_decode)
+    case = {
+        "inputs": {
+            "camera_slots": [
+                {"role": role, "valid": True, "source_uri": role, "source_key": role}
+                for role in values
+            ]
