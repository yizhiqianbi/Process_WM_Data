+#!/usr/bin/env python3
+"""Launch task-specific RMBench fine-tunes, one process per GPU."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import subprocess
+import time
+import zipfile
+from pathlib import Path
+from typing import Any
+
+from prepare_helios_memory_data import OFFICIAL_TASKS
+
+
+DEFAULT_INITIALIZATION = Path(
+    "/public/interns/hubin/dataset/robot_dataset/Process_WM_Data/work/tuning/runs/"
+    "fastwam_tianji_dataset_overfit_cont_1250_to_2500/checkpoints/weights/"
+    "step_001250.pt"
+)
+
+
+def _read_json(path: Path) -> dict[str, Any] | None:
+    try:
+        return json.loads(path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError):
+        return None
+
+
+def _latest_training_state(root: Path, task: str, max_step: int) -> Path | None:
+    state_root = root / "runs" / task / "checkpoints" / "state"
+    candidates: list[tuple[int, Path]] = []
+    for path in state_root.glob("step_*"):
+        try:
+            step = int(path.name.removeprefix("step_"))
+        except ValueError:
+            continue
+        trainer_state = _read_json(path / "trainer_state.json")
+        required_state_files = (
+            "model.safetensors",
+            "optimizer.bin",
+            "scheduler.bin",
+            "random_states_0.pkl",
+        )
+        if (
+            step < max_step
+            and trainer_state is not None
+            and int(trainer_state.get("global_step", -1)) == step
+            and all((path / name).is_file() for name in required_state_files)
+        ):
+            candidates.append((step, path.resolve()))
+    return max(candidates, default=(0, None), key=lambda item: item[0])[1]
+
+
+def _checkpoint_is_complete(path: Path) -> bool:
+    if not path.is_file() or path.stat().st_size <= 0:
+        return False
+    try:
+        with zipfile.ZipFile(path) as archive:
+            names = archive.namelist()
+        return any(name.endswith("/data.pkl") for name in names) and any(
+            name.endswith("/version") for name in names
+        )
+    except (OSError, zipfile.BadZipFile):
+        return False
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--gpus", default="0,1,2,3,4,5,6,7")
+    parser.add_argument("--tasks", nargs="*", default=list(OFFICIAL_TASKS))
+    parser.add_argument("--steps", type=int, default=2500)
+    parser.add_argument("--force", action="store_true")
+    parser.add_argument(
+        "--root",
+        type=Path,
+        default=Path("/public/interns/hubin/dataset/RMBench/fastwam_helios"),
+    )
+    args = parser.parse_args()
+    gpus = [value.strip() for value in args.gpus.split(",") if value.strip()]
+    try:
+        gpu_indices = [int(value) for value in gpus]
+    except ValueError:
+        gpu_indices = []
+    unknown = [task for task in args.tasks if task not in OFFICIAL_TASKS]
+    if (
+        not gpus
+        or len(gpu_indices) != len(gpus)
+        or any(value < 0 for value in gpu_indices)
+        or len(gpu_indices) != len(set(gpu_indices))
+        or args.steps <= 0
+        or not args.tasks
+        or len(args.tasks) != len(set(args.tasks))
+        or unknown
+    ):
+        parser.error(
+            "At least one GPU, positive --steps, and unique official task names are "
+            f"required; unknown={unknown}."
+        )
+
+    script = Path(__file__).with_name("train_rmbench_helios.sh").resolve()
+    root = args.root.expanduser().resolve()
+    initialization = Path(
+        os.environ.get("FASTWAM_RMBENCH_INIT", str(DEFAULT_INITIALIZATION))
+    ).expanduser().resolve()
+    if not _checkpoint_is_complete(initialization):
+        raise SystemExit(
+            f"MemoryFastWAM initialization checkpoint is incomplete: {initialization}"
+        )
+    log_dir = root / "launch_logs"
+    log_dir.mkdir(parents=True, exist_ok=True)
+    pending: list[tuple[str, Path | None]] = []
+    running: dict[
+        str, tuple[subprocess.Popen, object, str, float, Path | None]
+    ] = {}
+    results: dict[str, dict[str, object]] = {}
+    for task in args.tasks:
+        final_checkpoint = (
+            root / "runs" / task / "checkpoints" / "weights" / f"step_{args.steps:06d}.pt"
+        )
+        task_receipt_path = root / "runs" / task / "training_receipt.json"
+        task_receipt = _read_json(task_receipt_path)
+        reusable = (
+            _checkpoint_is_complete(final_checkpoint)
+            and task_receipt is not None
+            and task_receipt.get("status") == "succeeded"
+            and task_receipt.get("initialization_checkpoint") == str(initialization)
+            and int(task_receipt.get("target_steps", -1)) == args.steps
+            and task_receipt.get("checkpoint") == str(final_checkpoint.resolve())
+        )
+        if reusable and not args.force:
+            results[task] = {
+                "return_code": 0,
+                "gpu": None,
+                "status": "reused",
+                "checkpoint": str(final_checkpoint.resolve()),
+            }
+            print(f"[reuse] task={task} checkpoint={final_checkpoint}", flush=True)
+            continue
+        if _checkpoint_is_complete(final_checkpoint) and not args.force:
+            raise SystemExit(
+                "A complete final checkpoint exists without a matching training receipt: "
+                f"{final_checkpoint}. Inspect it, then rerun with --force only if overwrite "
+                "is intended."
+            )
+        resume = None if args.force else _latest_training_state(root, task, args.steps)
+        pending.append((task, resume))
+
+    while pending or running:
+        busy_gpus = {gpu for _, _, gpu, _, _ in running.values()}
+        for gpu in gpus:
+            if not pending or gpu in busy_gpus:
+                continue
+            task, resume = pending.pop(0)
+            log_path = log_dir / f"{task}.log"
+            log_handle = log_path.open("a", encoding="utf-8")
+            env = os.environ.copy()
+            env["RMBENCH_HELIOS_ROOT"] = str(root)
+            command = [str(script), task, gpu, str(args.steps)]
+            if resume is not None:
+                command.append(f"resume={resume}")
+            process = subprocess.Popen(
+                command,
+                stdout=log_handle,
+                stderr=subprocess.STDOUT,
+                start_new_session=True,
+                env=env,
+            )
+            running[task] = (process, log_handle, gpu, time.time(), resume)
+            print(
+                f"[launch] task={task} gpu={gpu} pid={process.pid} resume={resume} "
+                f"log={log_path}",
+                flush=True,
+            )
+
+        time.sleep(5)
+        for task, (process, log_handle, gpu, started_at, resume) in list(running.items()):
+            return_code = process.poll()
+            if return_code is None:
+                continue
+            log_handle.close()
+            checkpoint = (
+                root
+                / "runs"
+                / task
+                / "checkpoints"
+                / "weights"
+                / f"step_{args.steps:06d}.pt"
+            )
+            succeeded = return_code == 0 and _checkpoint_is_complete(checkpoint)
+            results[task] = {
+                "return_code": return_code,
+                "gpu": gpu,
+                "status": "succeeded" if succeeded else "failed",
+                "checkpoint": str(checkpoint.resolve()) if succeeded else None,
+            }
+            task_receipt = {
+                "schema_version": "fastwam-rmbench-helios-training-task-v1",
+                "status": "succeeded" if succeeded else "failed",
+                "task": task,
+                "gpu": gpu,
+                "target_steps": args.steps,
+                "initialization_checkpoint": str(initialization),
+                "resumed_from_state": None if resume is None else str(resume),
+                "checkpoint": str(checkpoint.resolve()) if succeeded else None,
+                "return_code": return_code,
+                "started_at_unix": started_at,
+                "finished_at_unix": time.time(),
+            }
+            task_receipt_path = root / "runs" / task / "training_receipt.json"
+            task_receipt_path.parent.mkdir(parents=True, exist_ok=True)
+            task_receipt_path.write_text(
+                json.dumps(task_receipt, indent=2, sort_keys=True) + "\n",
+                encoding="utf-8",
+            )
+            del running[task]
+            print(f"[done] task={task} gpu={gpu} return_code={return_code}", flush=True)
+
+    receipt = {
+        "schema_version": "fastwam-rmbench-helios-training-suite-v1",
+        "steps": args.steps,
+        "initialization_checkpoint": str(initialization),
+        "tasks": list(args.tasks),
+        "results": results,
+        "succeeded": all(
+            value["return_code"] == 0 and value.get("checkpoint")
+            for value in results.values()
+        ),
+    }
+    receipt_path = root / "training_suite_receipt.json"
+    receipt_path.write_text(json.dumps(receipt, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    print(json.dumps(receipt, indent=2, sort_keys=True))
+    if not receipt["succeeded"]:
+        raise SystemExit(1)
+
+
+if __name__ == "__main__":
+    main()
