+    def _parse_bindings(self, raw: Any, binding_type: str) -> dict[str, str]:
+        if not isinstance(raw, dict):
+            raise ValueError(f"Camera rectification {binding_type} bindings must be an object.")
+        bindings = {str(key): str(value) for key, value in raw.items()}
+        unknown = sorted(set(bindings.values()) - set(self.profiles))
+        if unknown:
+            raise ValueError(
+                f"Camera rectification {binding_type} bindings reference unknown profiles: {unknown}"
+            )
+        return bindings
+
+    @staticmethod
+    def _parse_profile(profile_id: str, raw: Any) -> _CameraRectificationProfile:
+        if not isinstance(raw, dict):
+            raise ValueError(f"Camera rectification profile {profile_id!r} must be an object.")
+        model = str(raw.get("model", "")).strip().lower()
+        if model not in {"opencv_fisheye", "opencv_pinhole_rational"}:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} uses unsupported model {model!r}."
+            )
+        image_size = tuple(int(value) for value in raw.get("image_size", ()))
+        if len(image_size) != 2 or any(value <= 1 for value in image_size):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} image_size must be [height,width]."
+            )
+        matrix = np.asarray(raw.get("camera_matrix"), dtype=np.float64)
+        if matrix.shape != (3, 3) or not np.isfinite(matrix).all():
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} camera_matrix must be finite 3x3."
+            )
+        if matrix[0, 0] <= 0 or matrix[1, 1] <= 0:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} focal lengths must be positive."
+            )
+        if not np.allclose(matrix[2], np.asarray([0.0, 0.0, 1.0])):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} camera_matrix bottom row is invalid."
+            )
+        if not np.isclose(matrix[0, 1], 0.0) or not np.isclose(matrix[1, 0], 0.0):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} skew is not supported."
+            )
+        distortion = tuple(float(value) for value in raw.get("distortion_coefficients", ()))
+        expected_distortion_count = 4 if model == "opencv_fisheye" else 8
+        if len(distortion) != expected_distortion_count or not np.isfinite(distortion).all():
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} with model {model!r} must have "
+                f"{expected_distortion_count} finite distortion coefficients."
+            )
+        virtual = raw.get("virtual_camera") or {}
+        horizontal_fov = float(virtual.get("horizontal_fov_degrees", 0.0))
+        if not 1.0 < horizontal_fov < 179.0:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} virtual horizontal FOV must be in (1,179)."
+            )
+        calibration_status = str(raw.get("calibration_status", "unspecified")).strip()
+        if not calibration_status:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} calibration_status is required."
+            )
+        return _CameraRectificationProfile(
+            profile_id=profile_id,
+            model=model,
+            calibration_status=calibration_status,
+            image_size=(image_size[0], image_size[1]),
+            camera_matrix=tuple(tuple(float(value) for value in row) for row in matrix),
+            distortion_coefficients=distortion,
+            virtual_horizontal_fov_degrees=horizontal_fov,
