@@ -0,0 +1,142 @@
+import unittest
+
+import torch
+
+from fastwam.models.wan22.fastwam import FastWAM
+from fastwam.trainer import Wan22Trainer
+
+
+class MaskedLossTest(unittest.TestCase):
+    def test_action_loss_ignores_padded_steps_and_inactive_dimensions(self):
+        pred = torch.zeros((2, 3, 4), dtype=torch.float32)
+        target = torch.ones_like(pred)
+        target[0, 0, 0] = 2.0
+        action_is_pad = torch.tensor(
+            [
+                [False, True, True],
+                [False, False, False],
+            ]
+        )
+        action_dim_is_pad = torch.tensor(
+            [
+                [False, True, True, True],
+                [True, True, True, True],
+            ]
+        )
+
+        loss = FastWAM._compute_action_loss_per_sample(
+            pred_action=pred,
+            target_action=target,
+            action_is_pad=action_is_pad,
+            action_dim_is_pad=action_dim_is_pad,
+        )
+
+        torch.testing.assert_close(loss, torch.tensor([4.0, 0.0]))
+
+    def test_weighted_mean_respects_sample_loss_mask(self):
+        loss = FastWAM._weighted_loss_mean(
+            loss_per_sample=torch.tensor([2.0, 100.0, 4.0]),
+            scheduler_weight=torch.tensor([1.0, 1.0, 2.0]),
+            loss_mask=torch.tensor([True, False, True]),
+            loss_weight=torch.tensor([1.0, 1.0, 0.5]),
+            sample_weight=torch.tensor([1.0, 1.0, 2.0]),
+        )
+
+        # Effective reduction weights are [1, 0, 1].
+        torch.testing.assert_close(loss, torch.tensor(5.0))
+
+    def test_all_masked_batch_stays_differentiable(self):
+        value = torch.tensor([3.0], requires_grad=True)
+        loss = FastWAM._weighted_loss_mean(
+            loss_per_sample=value,
+            scheduler_weight=torch.ones(1),
+            loss_mask=torch.zeros(1, dtype=torch.bool),
+            loss_weight=torch.ones(1),
+            sample_weight=torch.ones(1),
+        )
+        loss.backward()
+
+        self.assertEqual(float(loss), 0.0)
+        torch.testing.assert_close(value.grad, torch.zeros_like(value))
+
+    def test_eval_batch_preserves_canonical_masks_and_weights(self):
+        sample = {
+            "video": torch.zeros(3, 21, 16, 16),
+            "prompt": "task",
+            "action": torch.zeros(80, 80),
+            "proprio": torch.zeros(80, 80),
+            "context": torch.zeros(128, 4096),
+            "context_mask": torch.ones(128, dtype=torch.bool),
+            "action_is_pad": torch.zeros(80, dtype=torch.bool),
+            "action_dim_is_pad": torch.ones(80, dtype=torch.bool),
+            "proprio_dim_is_pad": torch.ones(80, dtype=torch.bool),
+            "action_loss_mask": torch.tensor(False),
+            "video_loss_mask": torch.tensor(True),
+            "sample_weight": torch.tensor(0.5),
+            "memory_video_long": torch.zeros(3, 8, 16, 16),
+            "memory_video_mid": torch.zeros(3, 2, 16, 16),
+            "memory_video_short": torch.zeros(3, 1, 16, 16),
+            "memory_mask_long": torch.ones(8, dtype=torch.bool),
+            "memory_mask_mid": torch.ones(2, dtype=torch.bool),
+            "memory_mask_short": torch.ones(1, dtype=torch.bool),
+            "sample_index": torch.tensor(4),
+            "window_start": torch.tensor(40),
+        }
+
+        batched = Wan22Trainer._to_batched_eval_sample(sample)
+
+        self.assertEqual(tuple(batched["action_dim_is_pad"].shape), (1, 80))
+        self.assertEqual(tuple(batched["proprio_dim_is_pad"].shape), (1, 80))
+        self.assertEqual(tuple(batched["action_loss_mask"].shape), (1,))
+        self.assertEqual(tuple(batched["sample_weight"].shape), (1,))
+        self.assertEqual(tuple(batched["memory_video_long"].shape), (1, 3, 8, 16, 16))
+        self.assertEqual(tuple(batched["memory_mask_short"].shape), (1, 1))
+        self.assertEqual(int(batched["window_start"][0]), 40)
+
+    def test_action_metric_mask_supports_expanded_dimension_mask(self):
+        target = torch.zeros(1, 3, 4)
+        valid = Wan22Trainer._action_metric_valid_mask(
+            target,
+            dimension_valid=torch.tensor([True, False, True, False]),
+            action_is_pad=torch.tensor([[False, False, True]]),
+            action_dim_is_pad=torch.tensor([[False, False, False, True]]),
+        )
+
+        self.assertEqual(tuple(valid.shape), (1, 3, 4))
+        self.assertEqual(int(valid.sum()), 4)
+        self.assertTrue(valid[0, :2, 0].all())
+        self.assertTrue(valid[0, :2, 2].all())
+        self.assertFalse(valid[0, 2].any())
+
+    def test_action_inference_padding_mask_zeros_inactive_dimensions(self):
+        padding = FastWAM._prepare_action_dim_padding_mask(
+            torch.tensor([False, True, False, True]),
+            action_dim=4,
+            device=torch.device("cpu"),
+        )
+        action = torch.arange(24, dtype=torch.float32).view(1, 6, 4)
+
+        masked = FastWAM._mask_padded_action_dims(action, padding)
+
+        self.assertEqual(tuple(padding.shape), (1, 1, 4))
+        self.assertTrue((masked[:, :, [1, 3]] == 0).all())
+        torch.testing.assert_close(masked[:, :, [0, 2]], action[:, :, [0, 2]])
+
+    def test_action_inference_padding_mask_rejects_wrong_width(self):
+        with self.assertRaisesRegex(ValueError, "action_dim_is_pad"):
+            FastWAM._prepare_action_dim_padding_mask(
+                torch.zeros(3, dtype=torch.bool),
+                action_dim=4,
+                device=torch.device("cpu"),
+            )
+
+    def test_eval_video_panels_are_stitched_horizontally(self):
+        panel = torch.zeros(3, 21, 384, 320)
+
+        stitched = Wan22Trainer._stitch_eval_video_panels(panel, panel, panel)
+
+        self.assertEqual(tuple(stitched.shape), (3, 21, 384, 960))
+
+
+if __name__ == "__main__":
+    unittest.main()
