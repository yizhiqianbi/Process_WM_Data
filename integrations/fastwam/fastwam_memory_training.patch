+                raise ValueError(
+                    "No camera rectification profile matches "
+                    f"source_key={camera.get('source_key')!r}, role={camera.get('role')!r}."
+                )
+            return None
+        return self.profiles[profile_id]
+
+    def _build_grid(
+        self,
+        profile: _CameraRectificationProfile,
+        *,
+        source_size: tuple[int, int],
+        output_size: tuple[int, int],
+    ) -> torch.Tensor:
+        source_height, source_width = source_size
+        if source_size != profile.image_size:
+            raise ValueError(
+                f"Camera rectification profile {profile.profile_id!r} expects source "
+                f"{profile.image_size}, got {source_size}."
+            )
+        output_height, output_width = output_size
+        key = (
+            profile.profile_id,
+            source_height,
+            source_width,
+            output_height,
+            output_width,
+        )
+        cached = self._grid_cache.get(key)
+        if cached is not None:
+            return cached
+
+        matrix = profile.camera_matrix
+        source_fx = matrix[0][0]
+        source_fy = matrix[1][1]
+        source_cx = matrix[0][2]
+        source_cy = matrix[1][2]
+        virtual_fx = (output_width * 0.5) / np.tan(
+            np.deg2rad(profile.virtual_horizontal_fov_degrees) * 0.5
+        )
+        virtual_fy = virtual_fx
+        virtual_cx = (output_width - 1) * 0.5
+        virtual_cy = (output_height - 1) * 0.5
+
+        yy, xx = torch.meshgrid(
+            torch.arange(output_height, dtype=torch.float32),
+            torch.arange(output_width, dtype=torch.float32),
+            indexing="ij",
+        )
+        x = (xx - virtual_cx) / float(virtual_fx)
+        y = (yy - virtual_cy) / float(virtual_fy)
+        if profile.model == "opencv_fisheye":
+            radius = torch.sqrt(x.square() + y.square())
+            theta = torch.atan(radius)
+            theta2 = theta.square()
+            k1, k2, k3, k4 = profile.distortion_coefficients
+            theta_distorted = theta * (
+                1.0
+                + k1 * theta2
+                + k2 * theta2.square()
+                + k3 * theta2.pow(3)
+                + k4 * theta2.pow(4)
+            )
+            scale = torch.where(
+                radius > 1.0e-8,
+                theta_distorted / radius.clamp_min(1.0e-8),
+                torch.ones_like(radius),
+            )
+            distorted_x = x * scale
+            distorted_y = y * scale
+        else:
+            # OpenCV's pinhole rational model: [k1, k2, p1, p2, k3, k4, k5, k6].
+            # The dataset stores an image resized from the calibration resolution, so
+            # K is already scaled to the decoded source frame before this mapping.
+            k1, k2, p1, p2, k3, k4, k5, k6 = profile.distortion_coefficients
+            radius2 = x.square() + y.square()
+            radial = (
+                1.0 + k1 * radius2 + k2 * radius2.square() + k3 * radius2.pow(3)
+            ) / (
+                1.0 + k4 * radius2 + k5 * radius2.square() + k6 * radius2.pow(3)
+            )
+            distorted_x = x * radial + 2.0 * p1 * x * y + p2 * (radius2 + 2.0 * x.square())
+            distorted_y = y * radial + p1 * (radius2 + 2.0 * y.square()) + 2.0 * p2 * x * y
+        source_x = float(source_fx) * distorted_x + float(source_cx)
+        source_y = float(source_fy) * distorted_y + float(source_cy)
+        grid_x = source_x.mul(2.0 / float(source_width - 1)).sub(1.0)
+        grid_y = source_y.mul(2.0 / float(source_height - 1)).sub(1.0)
+        grid = torch.stack([grid_x, grid_y], dim=-1).unsqueeze(0).contiguous()
+        self._grid_cache[key] = grid
+        return grid
+
+    def rectify(
+        self,
+        frames: torch.Tensor,
+        *,
+        camera: dict[str, Any],
+        output_size: tuple[int, int],
+    ) -> tuple[torch.Tensor, bool]:
+        if frames.ndim != 4 or frames.shape[1] != 3:
+            raise ValueError(f"Camera frames must be [T,3,H,W], got {tuple(frames.shape)}")
+        profile = self.resolve(camera)
+        if profile is None:
+            return (
+                transforms_F.resize(
+                    frames,
+                    size=list(output_size),
+                    interpolation=transforms_F.InterpolationMode.BILINEAR,
+                    antialias=True,
+                ),
+                False,
+            )
+        grid = self._build_grid(
+            profile,
+            source_size=(int(frames.shape[2]), int(frames.shape[3])),
+            output_size=output_size,
+        ).to(device=frames.device, dtype=frames.dtype)
+        rectified = nn_F.grid_sample(
+            frames,
+            grid.expand(frames.shape[0], -1, -1, -1),
+            mode="bilinear",
+            padding_mode="zeros",
+            align_corners=True,
+        )
+        return rectified, True
