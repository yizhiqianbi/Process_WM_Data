+    def _compose_video(self, handle: h5py.File, indices: Sequence[int]) -> torch.Tensor:
+        unique_indices = list(dict.fromkeys(int(index) for index in indices))
+        decoded: dict[str, dict[int, torch.Tensor]] = {}
