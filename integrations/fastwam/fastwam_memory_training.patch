+++ b/tests/test_rmbench_memory_dataset.py
@@ -0,0 +1,197 @@
+import hashlib
+import io
+import json
+from pathlib import Path
+
+import h5py
+import numpy as np
+import torch
+from PIL import Image
+
+from fastwam.datasets.lerobot.robot_video_dataset import DEFAULT_PROMPT
+from fastwam.datasets.rmbench_memory_dataset import (
+    CANONICAL_DIM,
+    EPISODE_SCHEMA_VERSION,
+    NORMALIZATION_SCHEMA_VERSION,
+    RMBENCH_TO_CANONICAL,
+    RMBenchMemoryDataset,
+    canonical_to_rmbench,
+    canonical_valid_mask,
+    rmbench_to_canonical,
+)
+from experiments.robotwin.fastwam_policy.deploy_policy import _resize_rgb
+
+
+def _jpeg(frame: np.ndarray) -> np.ndarray:
+    buffer = io.BytesIO()
+    Image.fromarray(frame, mode="RGB").save(buffer, format="JPEG", quality=95)
+    return np.frombuffer(buffer.getvalue(), dtype=np.uint8)
+
+
+def _write_fixture(root: Path, *, length: int = 96) -> tuple[Path, Path]:
+    source = root / "source" / "episode0.hdf5"
+    source.parent.mkdir(parents=True)
+    with h5py.File(source, "w") as handle:
+        state = np.stack(
+            [np.arange(14, dtype=np.float32) / 100.0 + frame for frame in range(length)]
+        )
+        handle.create_dataset("joint_action/vector", data=state)
+        dtype = h5py.vlen_dtype(np.dtype("uint8"))
+        for camera_index, key in enumerate(
+            (
+                "observation/head_camera/rgb",
+                "observation/left_camera/rgb",
+                "observation/right_camera/rgb",
+            )
+        ):
+            dataset = handle.create_dataset(key, (length,), dtype=dtype)
+            for frame in range(length):
+                image = np.zeros((12, 16, 3), dtype=np.uint8)
+                image[..., camera_index] = frame
+                dataset[frame] = _jpeg(image)
+
+    prepared = root / "prepared"
+    meta = prepared / "meta"
+    meta.mkdir(parents=True)
+    instruction = "Complete the RMBench fixture task."
+    domain = "rmbench:fixture:aloha-agilex:qpos-next-v1"
+    record = {
+        "schema_version": EPISODE_SCHEMA_VERSION,
+        "task_name": "fixture",
+        "source_episode_index": 0,
+        "hdf5_path": str(source),
+        "instruction": instruction,
+        "length": length,
+        "normalization_domain": domain,
+    }
+    (meta / "episodes.jsonl").write_text(json.dumps(record) + "\n", encoding="utf-8")
+    (meta / "tasks.jsonl").write_text(
+        json.dumps({"task_index": 0, "task": instruction}) + "\n", encoding="utf-8"
+    )
+
+    valid = canonical_valid_mask()
+    kind = {
+        "count": (valid.astype(np.int64) * (length - 1)).tolist(),
+        "mean": np.zeros(CANONICAL_DIM).tolist(),
+        "std": np.ones(CANONICAL_DIM).tolist(),
+        "valid_mask": valid.tolist(),
+    }
+    stats = {
+        "schema_version": NORMALIZATION_SCHEMA_VERSION,
+        "method": "zscore",
+        "domains": {
+            domain: {
+                "task_name": "fixture",
+                "state": kind,
+                "action": kind,
+            }
+        },
+    }
+    stats_path = meta / "normalization_stats.json"
+    stats_path.write_text(json.dumps(stats), encoding="utf-8")
+
+    prompt = DEFAULT_PROMPT.format(task=instruction)
+    digest = hashlib.sha256(prompt.encode("utf-8")).hexdigest()
+    cache = prepared / "text_embeds"
+    cache.mkdir()
+    torch.save(
+        {"context": torch.ones(128, 8), "mask": torch.ones(128, dtype=torch.bool)},
+        cache / f"{digest}.t5_len128.wan22ti2v5b.pt",
+    )
+    return prepared, stats_path
+
+
+def test_rmbench_canonical_mapping_round_trip():
+    raw = np.arange(28, dtype=np.float32).reshape(2, 14)
+    canonical = rmbench_to_canonical(raw)
+    assert canonical.shape == (2, 80)
+    assert np.array_equal(canonical_to_rmbench(canonical), raw)
+    assert np.count_nonzero(canonical_valid_mask()) == 14
+    assert np.array_equal(
+        canonical[..., list(RMBENCH_TO_CANONICAL)],
+        raw,
+    )
+
+
+def test_rmbench_deployment_resize_preserves_training_uint8_contract():
+    image = np.arange(17 * 23 * 3, dtype=np.uint8).reshape(17, 23, 3)
+    image.setflags(write=False)
+    resized = _resize_rgb(image, (160, 128))
+    expected = torch.nn.functional.interpolate(
+        torch.from_numpy(image.copy()).permute(2, 0, 1).unsqueeze(0).float(),
+        size=(128, 160),
+        mode="bilinear",
+        align_corners=False,
+        antialias=True,
+    ).round().clamp(0, 255).to(torch.uint8)[0].permute(1, 2, 0).numpy()
+    assert resized.dtype == np.uint8
+    assert resized.shape == (128, 160, 3)
+    assert np.max(np.abs(resized.astype(np.int16) - expected.astype(np.int16))) <= 1
+
+
+def test_rmbench_memory_dataset_uses_81_frames_and_past_only(tmp_path: Path):
+    prepared, stats = _write_fixture(tmp_path)
+    dataset = RMBenchMemoryDataset(
+        dataset_dirs=[str(prepared)],
+        normalization_stats=str(stats),
+        text_embedding_cache_dir=str(prepared / "text_embeds"),
+        tasks=["fixture"],
+        jpeg_color_mode="rgb",
+        hdf5_cache_size=0,
+        normalization_clip=None,
+    )
+    sample = dataset[12]
+
+    assert tuple(sample["video"].shape) == (3, 21, 384, 320)
+    assert tuple(sample["action"].shape) == (80, 80)
+    assert tuple(sample["proprio"].shape) == (80, 80)
+    assert tuple(sample["memory_video_long"].shape) == (3, 8, 384, 320)
+    assert tuple(sample["memory_video_mid"].shape) == (3, 2, 384, 320)
+    assert tuple(sample["memory_video_short"].shape) == (3, 1, 384, 320)
+    assert sample["memory_mask_long"].all()
+    assert sample["memory_mask_mid"].all()
+    assert sample["memory_mask_short"].all()
+
+    memory_indices = torch.cat(
+        [
+            sample["memory_indices_long"],
+            sample["memory_indices_mid"],
+            sample["memory_indices_short"],
+        ]
+    )
+    assert memory_indices.tolist() == list(range(1, 12))
+    assert int(memory_indices.max()) < int(sample["window_start"])
+
+    expected_action = np.arange(14, dtype=np.float32) / 100.0 + 13
+    assert np.allclose(
+        sample["action"][0, list(RMBENCH_TO_CANONICAL)].numpy(), expected_action
+    )
+    assert torch.count_nonzero(sample["action"][0, sample["action_dim_is_pad"]]) == 0
+
+
+def test_rmbench_memory_left_padding_is_masked(tmp_path: Path):
+    prepared, stats = _write_fixture(tmp_path)
+    dataset = RMBenchMemoryDataset(
+        dataset_dirs=str(prepared),
+        normalization_stats=str(stats),
+        text_embedding_cache_dir=str(prepared / "text_embeds"),
+        tasks="fixture",
+        jpeg_color_mode="rgb",
+        hdf5_cache_size=0,
+        max_samples=1,
+    )
+    sample = dataset[0]
+    assert not torch.cat(
+        [
+            sample["memory_mask_long"],
+            sample["memory_mask_mid"],
+            sample["memory_mask_short"],
+        ]
+    ).any()
+    assert torch.cat(
+        [
+            sample["memory_indices_long"],
+            sample["memory_indices_mid"],
+            sample["memory_indices_short"],
+        ]
+    ).tolist() == [0] * 11
