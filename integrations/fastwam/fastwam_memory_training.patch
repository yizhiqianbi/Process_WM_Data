@@ -0,0 +1,496 @@
+from __future__ import annotations
+
+import hashlib
+import io
+import json
+import os
+from collections import OrderedDict
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any, Sequence
+
+import h5py
+import numpy as np
+import torch
+import torchvision.transforms.functional as transforms_F
+from PIL import Image
+
+from fastwam.datasets.lerobot.robot_video_dataset import DEFAULT_PROMPT
+from fastwam.datasets.memory_bank import (
+    normalize_history_sizes,
+    select_multiscale_history_indices,
+)
+from fastwam.utils.logging_config import get_logger
+
+
+logger = get_logger(__name__)
+
+EPISODE_SCHEMA_VERSION = "fastwam-rmbench-episode-v1"
+NORMALIZATION_SCHEMA_VERSION = "fastwam-canonical-normalization-v1"
+CANONICAL_DIM = 80
+RMBENCH_ACTION_DIM = 14
+
+CAMERA_DATASETS = {
+    "global": "observation/head_camera/rgb",
+    "left_wrist": "observation/left_camera/rgb",
+    "right_wrist": "observation/right_camera/rgb",
+}
+
+# Aloha-AgileX stores [left arm 6, left gripper, right arm 6, right gripper].
+# The canonical FastWAM layout reserves 7 joint slots per arm and uses slots 6/13
+# for the grippers.
+RMBENCH_TO_CANONICAL = (
+    14,
+    15,
+    16,
+    17,
+    18,
+    19,
+    6,
+    21,
+    22,
+    23,
+    24,
+    25,
+    26,
+    13,
+)
+
+
+@dataclass(frozen=True)
+class _Episode:
+    task_name: str
+    source_episode_index: int
+    hdf5_path: Path
+    instruction: str
+    length: int
+    normalization_domain: str
+
+
+@dataclass(frozen=True)
+class _Sample:
+    episode_index: int
+    start: int
+
+
+def rmbench_to_canonical(values: np.ndarray) -> np.ndarray:
+    values = np.asarray(values, dtype=np.float32)
+    if values.shape[-1] != RMBENCH_ACTION_DIM:
+        raise ValueError(
+            f"RMBench Aloha vector must end in {RMBENCH_ACTION_DIM} dims, got {values.shape}."
+        )
+    output = np.zeros((*values.shape[:-1], CANONICAL_DIM), dtype=np.float32)
+    output[..., list(RMBENCH_TO_CANONICAL)] = values
+    return output
+
+
+def canonical_to_rmbench(values: np.ndarray) -> np.ndarray:
+    values = np.asarray(values, dtype=np.float32)
+    if values.shape[-1] != CANONICAL_DIM:
+        raise ValueError(f"Canonical vector must end in {CANONICAL_DIM} dims, got {values.shape}.")
+    return np.asarray(values[..., list(RMBENCH_TO_CANONICAL)], dtype=np.float32)
+
+
+def canonical_valid_mask() -> np.ndarray:
+    mask = np.zeros(CANONICAL_DIM, dtype=np.bool_)
+    mask[list(RMBENCH_TO_CANONICAL)] = True
+    return mask
+
+
+def _decode_jpeg(payload: Any, *, jpeg_color_mode: str) -> np.ndarray:
+    raw = payload.tobytes() if isinstance(payload, np.ndarray) else bytes(payload)
+    raw = raw.rstrip(b"\x00")
+    with Image.open(io.BytesIO(raw)) as image:
+        rgb = np.asarray(image.convert("RGB"), dtype=np.uint8)
+    if jpeg_color_mode == "opencv":
+        # RMBench calls cv2.imencode on arrays returned by get_obs(). Flipping the
+        # PIL decode reproduces the numeric RGB arrays consumed by the simulator.
+        rgb = rgb[..., ::-1].copy()
+    return np.array(rgb, dtype=np.uint8, copy=True, order="C")
+
+
+class RMBenchMemoryDataset(torch.utils.data.Dataset):
+    """Direct RMBench HDF5 loader for canonical-80D Helios MemoryFastWAM.
+
+    A sample contains 81 control states, 80 next-qpos targets, 21 video frames
+    sampled at offsets 0,4,...,80, and leak-free 8/2/1 observations strictly
+    before the current window. No intermediate video dataset is materialized.
+    """
+
+    def __init__(
+        self,
+        dataset_dirs: str | Sequence[str],
+        normalization_stats: str,
+        text_embedding_cache_dir: str,
+        tasks: str | Sequence[str] | None = None,
+        manifest_path: str | None = None,
+        context_len: int = 128,
+        action_dim: int = CANONICAL_DIM,
+        proprio_dim: int = CANONICAL_DIM,
+        num_frames: int = 81,
+        action_video_freq_ratio: int = 4,
+        video_size: Sequence[int] = (384, 320),
+        sample_stride: int = 1,
+        sample_offset: int = 0,
+        max_samples: int | None = None,
+        max_samples_per_episode: int | None = None,
+        normalization_clip: float | None = 10.0,
+        memory_history_long: int = 8,
+        memory_history_mid: int = 2,
+        memory_history_short: int = 1,
+        hdf5_cache_size: int = 2,
+        jpeg_color_mode: str = "opencv",
+    ) -> None:
+        super().__init__()
+        if isinstance(dataset_dirs, (str, os.PathLike)):
+            dataset_dirs = [str(dataset_dirs)]
+        roots = [Path(value).expanduser().resolve() for value in dataset_dirs]
+        if len(roots) != 1:
+            raise ValueError(f"RMBenchMemoryDataset requires one prepared root, got {roots}.")
+        self.prepared_root = roots[0]
+        self.manifest_path = (
+            Path(manifest_path).expanduser().resolve()
+            if manifest_path is not None
+            else self.prepared_root / "meta" / "episodes.jsonl"
+        )
+        self.normalization_stats_path = Path(normalization_stats).expanduser().resolve()
+        self.text_embedding_cache_dir = Path(text_embedding_cache_dir).expanduser().resolve()
+        self.context_len = int(context_len)
+        self.action_dim = int(action_dim)
+        self.proprio_dim = int(proprio_dim)
+        self.num_frames = int(num_frames)
+        self.action_video_freq_ratio = int(action_video_freq_ratio)
+        self.video_size = tuple(int(value) for value in video_size)
+        self.normalization_clip = (
+            None if normalization_clip is None else float(normalization_clip)
+        )
+        self.memory_history_sizes = normalize_history_sizes(
+            {
+                "long": memory_history_long,
+                "mid": memory_history_mid,
+                "short": memory_history_short,
+            }
+        )
+        self.hdf5_cache_size = int(hdf5_cache_size)
+        self.jpeg_color_mode = str(jpeg_color_mode)
+        self._hdf5_cache: OrderedDict[str, h5py.File] = OrderedDict()
+        self._hdf5_cache_pid = os.getpid()
+
+        if self.action_dim != CANONICAL_DIM or self.proprio_dim != CANONICAL_DIM:
+            raise ValueError(
+                "RMBench Helios training uses canonical 80D action/proprio, got "
+                f"action_dim={self.action_dim}, proprio_dim={self.proprio_dim}."
+            )
+        if self.num_frames != 81:
+            raise ValueError(f"Helios RMBench contract requires num_frames=81, got {self.num_frames}.")
+        if self.action_video_freq_ratio != 4:
+            raise ValueError(
+                "Helios RMBench contract requires action_video_freq_ratio=4, got "
+                f"{self.action_video_freq_ratio}."
+            )
+        if self.video_size != (384, 320):
+            raise ValueError(f"RMBench composite must be 384x320, got {self.video_size}.")
+        if sample_stride <= 0 or sample_offset < 0:
+            raise ValueError("sample_stride must be positive and sample_offset non-negative.")
+        if max_samples is not None and int(max_samples) <= 0:
+            raise ValueError("max_samples must be positive when provided.")
+        if max_samples_per_episode is not None and int(max_samples_per_episode) <= 0:
+            raise ValueError("max_samples_per_episode must be positive when provided.")
+        if self.hdf5_cache_size < 0:
+            raise ValueError("hdf5_cache_size must be non-negative.")
+        if self.jpeg_color_mode not in {"opencv", "rgb"}:
+            raise ValueError("jpeg_color_mode must be `opencv` or `rgb`.")
+
+        task_filter = None
+        if tasks is not None:
+            task_values = [tasks] if isinstance(tasks, str) else tasks
+            task_filter = {str(value) for value in task_values}
+        self.episodes = self._load_episodes(task_filter)
+        self._normalization = self._load_normalization(self.normalization_stats_path)
+
+        samples: list[_Sample] = []
+        for episode_index, episode in enumerate(self.episodes):
+            starts = list(range(max(0, episode.length - self.num_frames + 1)))
+            if max_samples_per_episode is not None:
+                starts = starts[: int(max_samples_per_episode)]
+            samples.extend(_Sample(episode_index, start) for start in starts)
+        samples = samples[int(sample_offset) :: int(sample_stride)]
+        if max_samples is not None:
+            samples = samples[: int(max_samples)]
+        if not samples:
+            raise ValueError("No RMBench 81-frame windows remain after filtering.")
+        self.samples = samples
+        self.sample_group_ids = tuple(
+            self.episodes[sample.episode_index].task_name for sample in self.samples
+        )
+        self.sample_episode_ids = tuple(
+            f"{self.episodes[sample.episode_index].task_name}:"
+            f"{self.episodes[sample.episode_index].source_episode_index:06d}"
+            for sample in self.samples
+        )
+
+        logger.info(
+            "Loaded RMBench Helios dataset: tasks=%s episodes=%d windows=%d video=21 action=80 memory=8/2/1",
+            sorted({episode.task_name for episode in self.episodes}),
+            len(self.episodes),
+            len(self.samples),
+        )
+
+    def _load_episodes(self, task_filter: set[str] | None) -> list[_Episode]:
+        if not self.manifest_path.is_file():
+            raise FileNotFoundError(f"RMBench episode manifest not found: {self.manifest_path}")
+        episodes: list[_Episode] = []
+        with self.manifest_path.open("r", encoding="utf-8") as handle:
+            for line_number, line in enumerate(handle, start=1):
+                if not line.strip():
+                    continue
+                record = json.loads(line)
+                if record.get("schema_version") != EPISODE_SCHEMA_VERSION:
+                    raise ValueError(
+                        f"Unsupported RMBench episode schema at {self.manifest_path}:{line_number}: "
+                        f"{record.get('schema_version')!r}"
+                    )
+                task_name = str(record["task_name"])
+                if task_filter is not None and task_name not in task_filter:
+                    continue
+                hdf5_path = Path(str(record["hdf5_path"])).expanduser()
+                if not hdf5_path.is_absolute():
+                    hdf5_path = self.prepared_root / hdf5_path
+                hdf5_path = hdf5_path.resolve()
+                if not hdf5_path.is_file():
+                    raise FileNotFoundError(f"RMBench HDF5 file not found: {hdf5_path}")
+                episodes.append(
+                    _Episode(
+                        task_name=task_name,
+                        source_episode_index=int(record["source_episode_index"]),
+                        hdf5_path=hdf5_path,
+                        instruction=str(record["instruction"]),
+                        length=int(record["length"]),
+                        normalization_domain=str(record["normalization_domain"]),
+                    )
+                )
+        if not episodes:
+            raise ValueError(
+                f"No RMBench episodes match tasks={None if task_filter is None else sorted(task_filter)}."
+            )
+        return episodes
+
+    @staticmethod
+    def _load_normalization(path: Path) -> dict[str, Any]:
+        if not path.is_file():
+            raise FileNotFoundError(f"RMBench normalization stats not found: {path}")
+        with path.open("r", encoding="utf-8") as handle:
+            payload = json.load(handle)
+        if payload.get("schema_version") != NORMALIZATION_SCHEMA_VERSION:
+            raise ValueError(f"Unsupported normalization schema: {payload.get('schema_version')!r}")
+        if payload.get("method") != "zscore" or not payload.get("domains"):
+            raise ValueError("RMBench normalization must contain non-empty zscore domains.")
+        return payload
+
+    def _domain_stats(self, episode: _Episode, kind: str) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
+        payload = (self._normalization["domains"].get(episode.normalization_domain) or {}).get(kind)
+        if payload is None:
+            raise KeyError(
+                f"Missing {kind} stats for domain={episode.normalization_domain} in "
+                f"{self.normalization_stats_path}."
+            )
+        mean = np.asarray(payload["mean"], dtype=np.float32)
+        std = np.asarray(payload["std"], dtype=np.float32)
+        valid = np.asarray(payload["valid_mask"], dtype=np.bool_)
+        if mean.shape != (CANONICAL_DIM,) or std.shape != (CANONICAL_DIM,) or valid.shape != (
+            CANONICAL_DIM,
+        ):
+            raise ValueError(f"Malformed canonical {kind} stats for {episode.normalization_domain}.")
+        if not np.isfinite(mean).all() or not np.isfinite(std).all() or (std <= 0).any():
+            raise ValueError(f"Invalid canonical {kind} stats for {episode.normalization_domain}.")
+        return mean, std, valid
+
+    def _normalize(self, values: np.ndarray, episode: _Episode, kind: str) -> torch.Tensor:
+        mean, std, valid = self._domain_stats(episode, kind)
+        output = (values - mean[None, :]) / std[None, :]
+        if self.normalization_clip is not None:
+            output = np.clip(output, -self.normalization_clip, self.normalization_clip)
+        output[:, ~valid] = 0.0
+        if not np.isfinite(output).all():
+            raise ValueError(
+                f"Non-finite normalized {kind} in {episode.task_name}/"
+                f"episode{episode.source_episode_index}."
+            )
+        return torch.from_numpy(np.ascontiguousarray(output, dtype=np.float32))
+
+    def _reset_hdf5_cache_after_fork(self) -> None:
+        pid = os.getpid()
+        if pid == self._hdf5_cache_pid:
+            return
+        self._hdf5_cache.clear()
+        self._hdf5_cache_pid = pid
+
+    def _open_hdf5(self, path: Path) -> h5py.File:
+        self._reset_hdf5_cache_after_fork()
+        key = str(path)
+        cached = self._hdf5_cache.pop(key, None)
+        if cached is not None:
+            self._hdf5_cache[key] = cached
+            return cached
+        handle = h5py.File(path, "r")
+        if self.hdf5_cache_size == 0:
+            return handle
+        self._hdf5_cache[key] = handle
+        while len(self._hdf5_cache) > self.hdf5_cache_size:
+            _, old = self._hdf5_cache.popitem(last=False)
+            old.close()
+        return handle
+
+    @staticmethod
+    def _validate_hdf5(handle: h5py.File, episode: _Episode) -> None:
+        state = handle.get("joint_action/vector")
+        if state is None or tuple(state.shape) != (episode.length, RMBENCH_ACTION_DIM):
+            raise ValueError(
+                f"RMBench state shape mismatch in {episode.hdf5_path}: "
