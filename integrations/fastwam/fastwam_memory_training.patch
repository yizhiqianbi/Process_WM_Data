@@ -0,0 +1,115 @@
+from __future__ import annotations
+
+from dataclasses import dataclass
+from typing import Mapping, Sequence
+
+import torch
+
+
+@dataclass(frozen=True)
+class MultiScaleMemorySelection:
+    indices_long: list[int]
+    indices_mid: list[int]
+    indices_short: list[int]
+    mask_long: torch.Tensor
+    mask_mid: torch.Tensor
+    mask_short: torch.Tensor
+    progress: float
+
+    @property
+    def indices_all(self) -> list[int]:
+        return [*self.indices_long, *self.indices_mid, *self.indices_short]
+
+
+def normalize_history_sizes(history_sizes: Mapping[str, int] | None = None) -> dict[str, int]:
+    sizes = {"long": 8, "mid": 2, "short": 1}
+    if history_sizes is not None:
+        for key in sizes:
+            if key in history_sizes:
+                sizes[key] = int(history_sizes[key])
+    for key, value in sizes.items():
+        if value <= 0:
+            raise ValueError(f"history_sizes[{key!r}] must be positive, got {value}.")
+    return sizes
+
+
+def select_multiscale_history_indices(
+    *,
+    start_index: int,
+    current_index: int,
+    end_index: int,
+    history_sizes: Mapping[str, int] | None = None,
+) -> MultiScaleMemorySelection:
+    """Select prior observations using the recovered FastWAM-memory convention.
+
+    The current observation is excluded because it is already supplied as x0.
+    Missing history is left-padded with the current index, and its mask is false.
+    This preserves the historical 8/2/1 checkpoint layout without leaking target
+    frames from the current 81-step training window.
+    """
+
+    sizes = normalize_history_sizes(history_sizes)
+    start_index = int(start_index)
+    current_index = int(current_index)
+    end_index = int(end_index)
+    if end_index <= start_index:
+        raise ValueError(
+            f"end_index must be greater than start_index, got {start_index}/{end_index}."
+        )
+    current_index = max(start_index, min(current_index, end_index - 1))
+
+    total = sum(sizes.values())
+    selected_valid = list(range(start_index, current_index))[-total:]
+    pad_count = total - len(selected_valid)
+    indices = [current_index] * pad_count + selected_valid
+    masks = [False] * pad_count + [True] * len(selected_valid)
+
+    long_end = sizes["long"]
+    mid_end = long_end + sizes["mid"]
+    denominator = max(1, end_index - start_index - 1)
+    return MultiScaleMemorySelection(
+        indices_long=indices[:long_end],
+        indices_mid=indices[long_end:mid_end],
+        indices_short=indices[mid_end:],
+        mask_long=torch.tensor(masks[:long_end], dtype=torch.bool),
+        mask_mid=torch.tensor(masks[long_end:mid_end], dtype=torch.bool),
+        mask_short=torch.tensor(masks[mid_end:], dtype=torch.bool),
+        progress=float((current_index - start_index) / denominator),
+    )
+
+
+def build_multiscale_memory_videos_from_history(
+    history: Sequence[torch.Tensor],
+    *,
+    history_sizes: Mapping[str, int] | None = None,
+) -> dict[str, torch.Tensor]:
+    """Convert closed-loop observations, including current last, into 8/2/1 memory."""
+    if not history:
+        raise ValueError("Cannot build memory videos from empty history.")
+    first = history[0]
+    if first.ndim != 4 or first.shape[1] != 3:
+        raise ValueError(f"History frames must be [B,3,H,W], got {tuple(first.shape)}.")
+    if any(frame.shape != first.shape for frame in history):
+        raise ValueError("All history frames must have the same [B,3,H,W] shape.")
+
+    selection = select_multiscale_history_indices(
+        start_index=0,
+        current_index=len(history) - 1,
+        end_index=len(history),
+        history_sizes=history_sizes,
+    )
+
+    def stack(indices: Sequence[int]) -> torch.Tensor:
+        return torch.stack([history[int(index)] for index in indices], dim=2).contiguous()
+
+    return {
+        "memory_video_long": stack(selection.indices_long),
+        "memory_video_mid": stack(selection.indices_mid),
+        "memory_video_short": stack(selection.indices_short),
+        "memory_mask_long": selection.mask_long.to(device=first.device),
+        "memory_mask_mid": selection.mask_mid.to(device=first.device),
+        "memory_mask_short": selection.mask_short.to(device=first.device),
+        "memory_progress": torch.tensor(
+            selection.progress, dtype=torch.float32, device=first.device
+        ),
+    }
