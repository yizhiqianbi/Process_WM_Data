+from collections import OrderedDict
+from contextlib import contextmanager
+from dataclasses import dataclass
+from pathlib import Path
+from typing import Any, Sequence
+
+import av
+import numpy as np
+import pyarrow.parquet as pq
+import torch
+import torch.nn.functional as nn_F
+import torchvision.transforms.functional as transforms_F
+from PIL import Image
+
+from fastwam.datasets.memory_bank import (
+    normalize_history_sizes,
+    select_multiscale_history_indices,
+)
+from fastwam.datasets.lerobot.robot_video_dataset import DEFAULT_PROMPT
+from fastwam.utils.logging_config import get_logger
+
+
+logger = get_logger(__name__)
+
+SCHEMA_VERSION = "fastwam-training-case-v1"
+NORMALIZATION_SCHEMA_VERSION = "fastwam-canonical-normalization-v1"
+RECTIFICATION_SCHEMA_VERSION = "fastwam-camera-rectification-v1"
+CANONICAL_DIM = 80
+
+
+@dataclass(frozen=True)
+class _SampleRef:
+    case_index: int
+    start: int
+
+
+@dataclass(frozen=True)
+class _CameraRectificationProfile:
+    profile_id: str
+    model: str
+    calibration_status: str
+    image_size: tuple[int, int]
+    camera_matrix: tuple[tuple[float, float, float], ...]
+    distortion_coefficients: tuple[float, float, float, float]
+    virtual_horizontal_fov_degrees: float
+
+
+class CameraRectificationRegistry:
+    """Resolve and apply deterministic fisheye-to-pinhole camera projections."""
+
+    def __init__(self, path: str | os.PathLike[str]):
+        self.path = Path(path).expanduser().resolve(strict=True)
+        with self.path.open("r", encoding="utf-8") as handle:
+            payload = json.load(handle)
+        if payload.get("schema_version") != RECTIFICATION_SCHEMA_VERSION:
+            raise ValueError(
+                f"Unsupported camera rectification schema in {self.path}: "
+                f"{payload.get('schema_version')!r}"
+            )
+        raw_profiles = payload.get("profiles")
+        if not isinstance(raw_profiles, dict) or not raw_profiles:
+            raise ValueError(f"Camera rectification config contains no profiles: {self.path}")
+        self.profiles = {
+            str(profile_id): self._parse_profile(str(profile_id), raw_profile)
+            for profile_id, raw_profile in raw_profiles.items()
+        }
+        raw_bindings = payload.get("bindings") or {}
+        if not isinstance(raw_bindings, dict):
+            raise ValueError("Camera rectification bindings must be an object.")
+        self.source_key_bindings = self._parse_bindings(
+            raw_bindings.get("source_key") or {}, "source_key"
+        )
+        self.role_bindings = self._parse_bindings(raw_bindings.get("role") or {}, "role")
+        default_profile = payload.get("default_profile")
+        self.default_profile = None if default_profile is None else str(default_profile)
+        if self.default_profile is not None and self.default_profile not in self.profiles:
+            raise ValueError(
+                f"Unknown default camera rectification profile {self.default_profile!r}."
+            )
+        self.unmatched_policy = str(payload.get("unmatched_policy", "identity")).strip().lower()
+        if self.unmatched_policy not in {"identity", "error"}:
+            raise ValueError(
+                f"Unsupported camera rectification unmatched_policy={self.unmatched_policy!r}."
+            )
+        self._grid_cache: dict[tuple[str, int, int, int, int], torch.Tensor] = {}
+        self.metadata = {
+            "schema_version": RECTIFICATION_SCHEMA_VERSION,
+            "config_path": str(self.path),
+            "config_sha256": hashlib.sha256(self.path.read_bytes()).hexdigest(),
+            "profile_ids": sorted(self.profiles),
+            "calibration_status": {
+                profile_id: profile.calibration_status
+                for profile_id, profile in sorted(self.profiles.items())
+            },
+        }
+
+    def _parse_bindings(self, raw: Any, binding_type: str) -> dict[str, str]:
+        if not isinstance(raw, dict):
+            raise ValueError(f"Camera rectification {binding_type} bindings must be an object.")
+        bindings = {str(key): str(value) for key, value in raw.items()}
+        unknown = sorted(set(bindings.values()) - set(self.profiles))
+        if unknown:
+            raise ValueError(
+                f"Camera rectification {binding_type} bindings reference unknown profiles: {unknown}"
+            )
+        return bindings
+
+    @staticmethod
+    def _parse_profile(profile_id: str, raw: Any) -> _CameraRectificationProfile:
+        if not isinstance(raw, dict):
+            raise ValueError(f"Camera rectification profile {profile_id!r} must be an object.")
+        model = str(raw.get("model", "")).strip().lower()
+        if model != "opencv_fisheye":
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} uses unsupported model {model!r}."
+            )
+        image_size = tuple(int(value) for value in raw.get("image_size", ()))
+        if len(image_size) != 2 or any(value <= 1 for value in image_size):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} image_size must be [height,width]."
+            )
+        matrix = np.asarray(raw.get("camera_matrix"), dtype=np.float64)
+        if matrix.shape != (3, 3) or not np.isfinite(matrix).all():
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} camera_matrix must be finite 3x3."
+            )
+        if matrix[0, 0] <= 0 or matrix[1, 1] <= 0:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} focal lengths must be positive."
+            )
+        if not np.allclose(matrix[2], np.asarray([0.0, 0.0, 1.0])):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} camera_matrix bottom row is invalid."
+            )
+        if not np.isclose(matrix[0, 1], 0.0) or not np.isclose(matrix[1, 0], 0.0):
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} skew is not supported."
+            )
+        distortion = tuple(float(value) for value in raw.get("distortion_coefficients", ()))
+        if len(distortion) != 4 or not np.isfinite(distortion).all():
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} distortion_coefficients must have 4 finite values."
+            )
+        virtual = raw.get("virtual_camera") or {}
+        horizontal_fov = float(virtual.get("horizontal_fov_degrees", 0.0))
+        if not 1.0 < horizontal_fov < 179.0:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} virtual horizontal FOV must be in (1,179)."
+            )
+        calibration_status = str(raw.get("calibration_status", "unspecified")).strip()
+        if not calibration_status:
+            raise ValueError(
+                f"Camera rectification profile {profile_id!r} calibration_status is required."
+            )
+        return _CameraRectificationProfile(
+            profile_id=profile_id,
+            model=model,
+            calibration_status=calibration_status,
+            image_size=(image_size[0], image_size[1]),
+            camera_matrix=tuple(tuple(float(value) for value in row) for row in matrix),
+            distortion_coefficients=distortion,
+            virtual_horizontal_fov_degrees=horizontal_fov,
+        )
+
+    def resolve(self, camera: dict[str, Any]) -> _CameraRectificationProfile | None:
+        profile_id = self.source_key_bindings.get(str(camera.get("source_key", "")))
+        if profile_id is None:
+            profile_id = self.role_bindings.get(str(camera.get("role", "")))
+        if profile_id is None:
+            profile_id = self.default_profile
+        if profile_id is None:
+            if self.unmatched_policy == "error":
+                raise ValueError(
+                    "No camera rectification profile matches "
+                    f"source_key={camera.get('source_key')!r}, role={camera.get('role')!r}."
+                )
+            return None
+        return self.profiles[profile_id]
+
+    def _build_grid(
+        self,
+        profile: _CameraRectificationProfile,
+        *,
+        source_size: tuple[int, int],
+        output_size: tuple[int, int],
+    ) -> torch.Tensor:
+        source_height, source_width = source_size
+        if source_size != profile.image_size:
+            raise ValueError(
+                f"Camera rectification profile {profile.profile_id!r} expects source "
+                f"{profile.image_size}, got {source_size}."
+            )
+        output_height, output_width = output_size
+        key = (
+            profile.profile_id,
+            source_height,
+            source_width,
+            output_height,
+            output_width,
+        )
+        cached = self._grid_cache.get(key)
+        if cached is not None:
+            return cached
+
+        matrix = profile.camera_matrix
+        source_fx = matrix[0][0]
+        source_fy = matrix[1][1]
+        source_cx = matrix[0][2]
+        source_cy = matrix[1][2]
+        virtual_fx = (output_width * 0.5) / np.tan(
+            np.deg2rad(profile.virtual_horizontal_fov_degrees) * 0.5
+        )
+        virtual_fy = virtual_fx
+        virtual_cx = (output_width - 1) * 0.5
+        virtual_cy = (output_height - 1) * 0.5
+
+        yy, xx = torch.meshgrid(
+            torch.arange(output_height, dtype=torch.float32),
+            torch.arange(output_width, dtype=torch.float32),
+            indexing="ij",
+        )
+        x = (xx - virtual_cx) / float(virtual_fx)
+        y = (yy - virtual_cy) / float(virtual_fy)
+        radius = torch.sqrt(x.square() + y.square())
+        theta = torch.atan(radius)
+        theta2 = theta.square()
+        k1, k2, k3, k4 = profile.distortion_coefficients
+        theta_distorted = theta * (
+            1.0
+            + k1 * theta2
+            + k2 * theta2.square()
+            + k3 * theta2.pow(3)
+            + k4 * theta2.pow(4)
+        )
+        scale = torch.where(
+            radius > 1.0e-8,
+            theta_distorted / radius.clamp_min(1.0e-8),
+            torch.ones_like(radius),
+        )
+        source_x = float(source_fx) * x * scale + float(source_cx)
+        source_y = float(source_fy) * y * scale + float(source_cy)
+        grid_x = source_x.mul(2.0 / float(source_width - 1)).sub(1.0)
+        grid_y = source_y.mul(2.0 / float(source_height - 1)).sub(1.0)
+        grid = torch.stack([grid_x, grid_y], dim=-1).unsqueeze(0).contiguous()
+        self._grid_cache[key] = grid
+        return grid
+
+    def rectify(
+        self,
+        frames: torch.Tensor,
+        *,
+        camera: dict[str, Any],
+        output_size: tuple[int, int],
+    ) -> tuple[torch.Tensor, bool]:
+        if frames.ndim != 4 or frames.shape[1] != 3:
+            raise ValueError(f"Camera frames must be [T,3,H,W], got {tuple(frames.shape)}")
+        profile = self.resolve(camera)
+        if profile is None:
+            return (
+                transforms_F.resize(
+                    frames,
+                    size=list(output_size),
+                    interpolation=transforms_F.InterpolationMode.BILINEAR,
+                    antialias=True,
+                ),
+                False,
+            )
+        grid = self._build_grid(
+            profile,
+            source_size=(int(frames.shape[2]), int(frames.shape[3])),
+            output_size=output_size,
+        ).to(device=frames.device, dtype=frames.dtype)
+        rectified = nn_F.grid_sample(
+            frames,
+            grid.expand(frames.shape[0], -1, -1, -1),
+            mode="bilinear",
+            padding_mode="zeros",
+            align_corners=True,
+        )
+        return rectified, True
+
+
+def _as_string_set(value: str | Sequence[str] | None) -> set[str] | None:
+    if value is None:
+        return None
+    if isinstance(value, str):
+        return {value}
+    return {str(item) for item in value}
+
+
+def _expand_valid_starts(spec: Any) -> list[int]:
+    if isinstance(spec, list):
+        starts = [int(value) for value in spec]
+    elif isinstance(spec, dict):
+        start = int(spec.get("start", 0))
+        stop = int(spec["stop_exclusive"])
+        stride = int(spec["stride"])
+        if start < 0 or stop < start or stride <= 0:
+            raise ValueError(f"Invalid compact valid-start range: {spec}")
+        starts = list(range(start, stop, stride))
+        declared_count = spec.get("count")
+        if declared_count is not None and int(declared_count) != len(starts):
+            raise ValueError(
+                f"Valid-start count mismatch: declared={declared_count}, expanded={len(starts)}, spec={spec}"
+            )
+    else:
+        raise TypeError(f"Unsupported valid_starts type: {type(spec)}")
+    if any(value < 0 for value in starts):
+        raise ValueError(f"Valid starts must be non-negative, got {starts[:8]}")
+    return starts
+
+
+def _split_tar_uri(uri: str) -> tuple[Path, str]:
+    if not uri.startswith("tar://"):
+        raise ValueError(f"Expected tar:// URI, got {uri}")
+    payload = uri[len("tar://") :]
+    if "!" not in payload:
+        raise ValueError(f"tar URI must use tar://ARCHIVE!MEMBER syntax: {uri}")
+    archive_path, member_name = payload.split("!", 1)
+    archive = Path(archive_path).expanduser().resolve(strict=True)
+    member = member_name.lstrip("/")
+    if not member:
+        raise ValueError(f"tar URI has an empty member name: {uri}")
+    return archive, member
+
+
+def materialize_tar_video_member(uri: str, cache_dir: str | os.PathLike[str]) -> Path:
+    """Extract one tar member into a content-addressed, process-safe cache."""
+    archive_path, member_name = _split_tar_uri(uri)
+    archive_stat = archive_path.stat()
+    cache_key = hashlib.sha256(
+        (
+            f"{archive_path}\0{member_name}\0"
+            f"{archive_stat.st_size}\0{archive_stat.st_mtime_ns}"
+        ).encode("utf-8")
+    ).hexdigest()
+    suffix = Path(member_name).suffix
+    if len(suffix) > 16:
+        suffix = ""
+    target = Path(cache_dir).expanduser() / cache_key[:2] / f"{cache_key}{suffix}"
+    if target.is_file() and target.stat().st_size > 0:
+        return target
+
+    target.parent.mkdir(parents=True, exist_ok=True)
+    temp_path: Path | None = None
+    try:
+        with tempfile.NamedTemporaryFile(
+            mode="wb",
+            dir=target.parent,
+            prefix=f".{target.name}.",
+            suffix=".tmp",
+            delete=False,
+        ) as temporary:
+            temp_path = Path(temporary.name)
+            with tarfile.open(archive_path, mode="r:*") as archive:
+                extracted = archive.extractfile(member_name)
+                if extracted is None:
+                    raise FileNotFoundError(f"Video member not found in archive: {uri}")
+                shutil.copyfileobj(extracted, temporary, length=1024 * 1024)
+            temporary.flush()
+            os.fsync(temporary.fileno())
+        if temp_path.stat().st_size <= 0:
+            raise ValueError(f"Video member is empty: {uri}")
+        os.replace(temp_path, target)
+        temp_path = None
+    finally:
+        if temp_path is not None:
+            temp_path.unlink(missing_ok=True)
+    return target
+
+
+@contextmanager
+def _open_video_source(
+    uri: str,
+    *,
+    tar_member_cache_dir: str | os.PathLike[str] | None = None,
+):
+    """Open a file or tar://archive!member URI for PyAV."""
+    if uri.startswith("tar://"):
+        if tar_member_cache_dir is not None:
+            cached_path = materialize_tar_video_member(uri, tar_member_cache_dir)
+            with av.open(str(cached_path), mode="r") as container:
+                yield container
+            return
+
+        archive_path, member_name = _split_tar_uri(uri)
+        with tarfile.open(archive_path, mode="r:*") as archive:
+            extracted = archive.extractfile(member_name)
+            if extracted is None:
+                raise FileNotFoundError(f"Video member not found in archive: {uri}")
+            buffer = io.BytesIO(extracted.read())
+            with av.open(buffer, mode="r") as container:
+                yield container
+        return
+
+    path = Path(uri).expanduser()
+    if not path.is_file():
+        raise FileNotFoundError(f"Video source does not exist: {path}")
+    with av.open(str(path), mode="r") as container:
+        yield container
+
+
+class _RestrictedNumpyUnpickler(pickle.Unpickler):
+    """Unpickler limited to the NumPy constructors used by OXE WebDataset."""
+
+    _ALLOWED = {
+        ("numpy.core.multiarray", "_reconstruct"): np.core.multiarray._reconstruct,
+        ("numpy.core.multiarray", "scalar"): np.core.multiarray.scalar,
+        ("numpy", "dtype"): np.dtype,
+        ("numpy", "ndarray"): np.ndarray,
+    }
+
+    def find_class(self, module: str, name: str):
+        value = self._ALLOWED.get((module, name))
+        if value is None:
+            raise pickle.UnpicklingError(f"Blocked pickle global: {module}.{name}")
+        return value
+
+
+def _image_to_rgb_tensor(value: Any, *, array_color_order: str = "rgb") -> torch.Tensor:
+    if isinstance(value, np.ndarray) and value.ndim == 1 and value.dtype == np.uint8:
+        value = value.tobytes()
+    if isinstance(value, (bytes, bytearray, memoryview)):
+        with Image.open(io.BytesIO(bytes(value))) as image:
+            array = np.array(image.convert("RGB"), dtype=np.uint8, copy=True)
+    else:
+        array = np.asarray(value)
+        if array.ndim != 3 or array.shape[2] not in (3, 4):
+            raise ValueError(f"Embedded image must be HWC RGB/RGBA, got {array.shape}")
+        array = np.asarray(array[..., :3], dtype=np.uint8)
+        if array_color_order.lower() == "bgr":
+            array = array[..., ::-1]
+    return torch.from_numpy(np.ascontiguousarray(array))
+
+
+def _decode_oxe_pickle_frames(uri: str, requested: Sequence[int]) -> dict[int, torch.Tensor]:
+    payload = uri[len("oxe-pickle://") :]
+    container, separator, selector = payload.partition("#")
+    if not separator or "!" not in container:
+        raise ValueError(f"Malformed OXE pickle URI: {uri}")
+    archive_path, member_name = container.split("!", 1)
+    if not selector.startswith("observation.") or len(selector) == len("observation."):
+        raise ValueError(f"Unsupported OXE image selector {selector!r}")
+    image_key = selector.removeprefix("observation.")
+    with tarfile.open(archive_path, mode="r:*") as archive:
+        extracted = archive.extractfile(member_name.lstrip("/"))
+        if extracted is None:
+            raise FileNotFoundError(f"OXE pickle member not found: {uri}")
+        episode = _RestrictedNumpyUnpickler(extracted).load()
+    steps = episode.get("steps") if isinstance(episode, dict) else None
+    if not isinstance(steps, list):
+        raise ValueError(f"OXE pickle has no list-valued steps: {uri}")
+    frames: dict[int, torch.Tensor] = {}
+    for index in requested:
+        if index >= len(steps):
+            raise IndexError(f"OXE frame index {index} exceeds {len(steps)} steps: {uri}")
+        observation = steps[index].get("observation") if isinstance(steps[index], dict) else None
+        if not isinstance(observation, dict) or image_key not in observation:
+            raise ValueError(f"OXE step {index} has no {selector}: {uri}")
+        frames[index] = _image_to_rgb_tensor(observation[image_key])
+    return frames
+
+
+def _decode_hdf5_frames(uri: str, requested: Sequence[int]) -> dict[int, torch.Tensor]:
+    payload = uri[len("hdf5://") :]
+    path, separator, fragment = payload.partition("#")
+    if not separator:
+        raise ValueError(f"Malformed HDF5 image URI: {uri}")
+    selector, *options = fragment.split(";")
+    option_map = dict(item.split("=", 1) for item in options if "=" in item)
+    try:
+        import h5py
+    except ImportError as exc:
+        raise ImportError("h5py is required to decode RoboMIND HDF5 images") from exc
+    frames: dict[int, torch.Tensor] = {}
+    with h5py.File(path, mode="r") as handle:
+        if selector not in handle:
+            raise KeyError(f"HDF5 image dataset {selector!r} does not exist in {path}")
+        dataset = handle[selector]
+        for index in requested:
+            if index >= len(dataset):
+                raise IndexError(f"HDF5 frame index {index} exceeds {len(dataset)} rows: {uri}")
+            frames[index] = _image_to_rgb_tensor(
+                dataset[index], array_color_order=option_map.get("array_color_order", "rgb")
+            )
+    return frames
+
+
+def decode_video_frames(
+    uri: str,
+    frame_indices: Sequence[int],
+    *,
+    tar_member_cache_dir: str | os.PathLike[str] | None = None,
+) -> torch.Tensor:
+    """Decode exact zero-based frame indices and return uint8 [T,H,W,3]."""
+    requested = [int(value) for value in frame_indices]
+    if not requested:
+        raise ValueError("At least one video frame index is required.")
+    if min(requested) < 0:
+        raise ValueError(f"Frame indices must be non-negative, got {min(requested)}")
+
+    unique_requested = sorted(set(requested))
+    if uri.startswith("oxe-pickle://"):
+        frames = _decode_oxe_pickle_frames(uri, unique_requested)
+    elif uri.startswith("hdf5://"):
+        frames = _decode_hdf5_frames(uri, unique_requested)
+    else:
+        target_set = set(unique_requested)
+        frames: dict[int, torch.Tensor] = {}
+        last_target = unique_requested[-1]
+        with _open_video_source(uri, tar_member_cache_dir=tar_member_cache_dir) as container:
+            if not container.streams.video:
+                raise ValueError(f"No video stream found: {uri}")
+            stream = container.streams.video[0]
+            stream.thread_type = "AUTO"
+            for frame_index, frame in enumerate(container.decode(stream)):
+                if frame_index in target_set:
+                    array = frame.to_ndarray(format="rgb24")
+                    frames[frame_index] = torch.from_numpy(np.ascontiguousarray(array))
+                if frame_index >= last_target:
+                    break
+
+    missing = [value for value in unique_requested if value not in frames]
+    if missing:
+        raise IndexError(
+            f"Video ended before requested frames were decoded: uri={uri}, missing={missing[:8]}"
+        )
+    shapes = {tuple(frames[value].shape) for value in requested}
+    if len(shapes) != 1:
+        raise ValueError(f"Decoded video frames have inconsistent shapes: uri={uri}, shapes={sorted(shapes)}")
+    return torch.stack([frames[value] for value in requested], dim=0)
+
+
+class TrainingCaseDataset(torch.utils.data.Dataset):
+    """Strict bridge from TrainingCaseV1 sidecars to FastWAM training samples."""
+
+    def __init__(
+        self,
+        case_manifests: str | Sequence[str],
+        data_root: str,
+        normalization_stats: str | None,
+        text_embedding_cache_dir: str,
+        context_len: int = 128,
+        split: str | Sequence[str] | None = "train",
+        allowed_modes: str | Sequence[str] | None = ("joint_video_action",),
+        allowed_quality_tiers: str | Sequence[str] | None = ("A",),
+        action_dim: int = CANONICAL_DIM,
+        proprio_dim: int = CANONICAL_DIM,
+        video_size: Sequence[int] = (384, 320),
+        camera_roles: Sequence[str] = ("global_primary", "left_wrist", "right_wrist"),
+        missing_camera_policy: str = "zero",
+        camera_rectification_config: str | None = None,
+        normalization_clip: float | None = 10.0,
+        episode_cache_size: int = 2,
+        tar_member_cache_dir: str | None = None,
+        sample_offset_per_case: int = 0,
+        max_samples_per_case: int | None = None,
+        sample_offset: int = 0,
+        sample_stride: int = 1,
+        max_samples: int | None = None,
+        include_robot_supervision: bool = True,
+    ):
+        super().__init__()
+        if isinstance(case_manifests, (str, os.PathLike)):
+            case_manifests = [str(case_manifests)]
+        self.case_manifests = [str(Path(path).expanduser()) for path in case_manifests]
+        if not self.case_manifests:
+            raise ValueError("At least one TrainingCaseV1 manifest is required.")
+
+        self.data_root = Path(data_root).expanduser()
+        self.normalization_stats_path = (
+            None if normalization_stats is None else Path(normalization_stats).expanduser()
+        )
+        self.text_embedding_cache_dir = Path(text_embedding_cache_dir).expanduser()
+        self.context_len = int(context_len)
+        self.action_dim = int(action_dim)
+        self.proprio_dim = int(proprio_dim)
+        self.video_size = tuple(int(value) for value in video_size)
+        self.camera_roles = tuple(str(value) for value in camera_roles)
+        self.missing_camera_policy = str(missing_camera_policy)
+        rectification_path = None
+        if camera_rectification_config is not None:
+            rectification_path = Path(camera_rectification_config).expanduser()
+            if not rectification_path.is_absolute():
+                rectification_path = self.data_root / rectification_path
+        self.camera_rectification = (
+            None
+            if rectification_path is None
+            else CameraRectificationRegistry(rectification_path)
+        )
+        self.camera_rectification_metadata = (
+            None if self.camera_rectification is None else self.camera_rectification.metadata
+        )
+        self.normalization_clip = None if normalization_clip is None else float(normalization_clip)
+        self.episode_cache_size = int(episode_cache_size)
+        self.tar_member_cache_dir = (
+            None if tar_member_cache_dir is None else Path(tar_member_cache_dir).expanduser()
+        )
+        self.include_robot_supervision = bool(include_robot_supervision)
+        self._episode_cache: OrderedDict[str, dict[str, np.ndarray]] = OrderedDict()
+
+        if self.action_dim != CANONICAL_DIM or self.proprio_dim != CANONICAL_DIM:
+            raise ValueError(
+                f"TrainingCaseV1 uses fixed {CANONICAL_DIM}D action/state, got "
+                f"action_dim={self.action_dim}, proprio_dim={self.proprio_dim}."
+            )
+        if len(self.video_size) != 2 or any(value <= 0 for value in self.video_size):
+            raise ValueError(f"video_size must be [height, width], got {self.video_size}")
+        if self.video_size[0] % 16 or self.video_size[1] % 16:
+            raise ValueError(f"FastWAM video_size must use multiples of 16, got {self.video_size}")
+        if self.camera_roles != ("global_primary", "left_wrist", "right_wrist"):
+            raise ValueError(
+                "The canonical FastWAM composite currently requires camera_roles="
+                "[global_primary,left_wrist,right_wrist]."
+            )
+        if self.missing_camera_policy not in {"zero", "repeat_global"}:
+            raise ValueError(
+                f"Unsupported missing_camera_policy={self.missing_camera_policy}; expected zero or repeat_global."
+            )
+        if self.episode_cache_size < 0:
+            raise ValueError("episode_cache_size must be >= 0.")
+        if sample_stride <= 0:
+            raise ValueError("sample_stride must be positive.")
+        if sample_offset < 0:
+            raise ValueError("sample_offset must be non-negative.")
+        if sample_offset_per_case < 0:
+            raise ValueError("sample_offset_per_case must be non-negative.")
+        if max_samples_per_case is not None and int(max_samples_per_case) <= 0:
+            raise ValueError("max_samples_per_case must be positive when provided.")
+
+        if self.include_robot_supervision and self.normalization_stats_path is None:
+            raise ValueError("normalization_stats is required when include_robot_supervision=true.")
+        self._normalization = (
+            self._load_normalization_stats(self.normalization_stats_path)
+            if self.normalization_stats_path is not None
+            else None
+        )
+        split_set = _as_string_set(split)
+        mode_set = _as_string_set(allowed_modes)
+        tier_set = _as_string_set(allowed_quality_tiers)
+        self.cases = self._load_cases(split_set=split_set, mode_set=mode_set, tier_set=tier_set)
+
+        samples: list[_SampleRef] = []
+        for case_index, case in enumerate(self.cases):
+            starts = _expand_valid_starts(case["sampling"]["valid_starts"])
+            starts = starts[int(sample_offset_per_case) :]
+            if max_samples_per_case is not None:
+                starts = starts[: int(max_samples_per_case)]
+            samples.extend(_SampleRef(case_index=case_index, start=start) for start in starts)
+        samples = samples[int(sample_offset) :: int(sample_stride)]
+        if max_samples is not None:
+            if int(max_samples) <= 0:
+                raise ValueError("max_samples must be positive when provided.")
+            samples = samples[: int(max_samples)]
+        if not samples:
+            raise ValueError("No TrainingCaseV1 windows remain after filtering.")
+        self.samples = samples
+        self.sample_group_ids = tuple(
+            str(self.cases[ref.case_index]["dataset"]) for ref in self.samples
+        )
+        self.sample_episode_ids = tuple(
+            str(
+                self.cases[ref.case_index].get("split_group_id")
+                or self.cases[ref.case_index].get("source_episode_id")
+                or self.cases[ref.case_index]["case_id"]
+            )
+            for ref in self.samples
+        )
+
+        logger.info(
+            "Loaded TrainingCaseV1 dataset: manifests=%d cases=%d windows=%d video=%s action=%d state=%d",
+            len(self.case_manifests),
+            len(self.cases),
+            len(self.samples),
+            self.video_size,
+            self.action_dim,
+            self.proprio_dim,
+        )
+
+    @staticmethod
+    def _load_normalization_stats(path: Path) -> dict[str, Any]:
+        if not path.is_file():
+            raise FileNotFoundError(f"Normalization stats do not exist: {path}")
+        with path.open("r", encoding="utf-8") as handle:
+            payload = json.load(handle)
+        if payload.get("schema_version") != NORMALIZATION_SCHEMA_VERSION:
+            raise ValueError(
+                f"Unsupported normalization schema in {path}: {payload.get('schema_version')}"
+            )
+        if payload.get("method") != "zscore":
+            raise ValueError(f"Only zscore normalization is supported, got {payload.get('method')}")
+        if not isinstance(payload.get("domains"), dict) or not payload["domains"]:
+            raise ValueError(f"Normalization stats contain no domains: {path}")
+        return payload
+
+    def _load_cases(
+        self,
+        split_set: set[str] | None,
+        mode_set: set[str] | None,
+        tier_set: set[str] | None,
+    ) -> list[dict[str, Any]]:
+        cases: list[dict[str, Any]] = []
+        seen_ids: set[str] = set()
+        for manifest in self.case_manifests:
+            path = Path(manifest)
+            if not path.is_file():
+                raise FileNotFoundError(f"TrainingCaseV1 manifest does not exist: {path}")
+            with path.open("r", encoding="utf-8") as handle:
+                for line_number, line in enumerate(handle, start=1):
+                    if not line.strip():
+                        continue
+                    case = json.loads(line)
+                    self._validate_case(case, path=path, line_number=line_number)
+                    if split_set is not None and str(case["split"]) not in split_set:
+                        continue
+                    if mode_set is not None and str(case["training"]["mode"]) not in mode_set:
+                        continue
+                    if tier_set is not None and str(case["quality"]["tier"]) not in tier_set:
+                        continue
+                    case_id = str(case["case_id"])
+                    if case_id in seen_ids:
+                        raise ValueError(f"Duplicate case_id across manifests: {case_id}")
+                    seen_ids.add(case_id)
+                    cases.append(case)
+        if not cases:
+            raise ValueError(
+                f"No cases match split={split_set}, modes={mode_set}, tiers={tier_set} in {self.case_manifests}"
+            )
+        return cases
+
+    @staticmethod
+    def _validate_case(case: dict[str, Any], path: Path, line_number: int) -> None:
+        label = f"{path}:{line_number}"
+        if case.get("schema_version") != SCHEMA_VERSION:
+            raise ValueError(f"Unsupported TrainingCaseV1 schema at {label}: {case.get('schema_version')}")
+        if not case.get("dataset"):
+            raise ValueError(f"dataset is required at {label}")
+        timeline = case.get("timeline") or {}
+        expected_offsets = list(range(0, 81, 4))
+        expected = {
+            "state_steps": 81,
+            "action_steps": 80,
+            "video_steps": 21,
+            "video_offsets": expected_offsets,
+        }
+        for key, value in expected.items():
+            if timeline.get(key) != value:
+                raise ValueError(f"Invalid timeline.{key} at {label}: expected {value}, got {timeline.get(key)}")
+        if float(timeline.get("target_fps", 0.0)) != 20.0:
+            raise ValueError(f"TrainingCase target_fps must be 20 Hz at {label}")
+        inputs = case.get("inputs") or {}
+        if inputs.get("action_dimension") != CANONICAL_DIM or inputs.get("state_dimension") != CANONICAL_DIM:
+            raise ValueError(f"TrainingCase dimensions must both be {CANONICAL_DIM} at {label}")
+        for key in ("action_slot_mask", "state_slot_mask"):
+            if len(inputs.get(key) or []) != CANONICAL_DIM:
+                raise ValueError(f"inputs.{key} must have {CANONICAL_DIM} entries at {label}")
+        if not inputs.get("canonical_parquet"):
+            raise ValueError(f"inputs.canonical_parquet is required at {label}")
+        if not (case.get("language") or {}).get("primary"):
+            raise ValueError(f"language.primary is required at {label}")
+        if not (case.get("embodiment") or {}).get("normalization_domain"):
+            raise ValueError(f"embodiment.normalization_domain is required at {label}")
+
+    def __len__(self) -> int:
+        return len(self.samples)
+
+    def denormalize_action(
+        self, action: torch.Tensor, sample_index: int
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        """Map canonical z-score action tensors back to their source-domain units."""
+        if self._normalization is None:
+            raise RuntimeError("Action denormalization requires normalization stats.")
+        if sample_index < 0 or sample_index >= len(self.samples):
+            raise IndexError(
+                f"sample_index={sample_index} is outside dataset size {len(self.samples)}."
+            )
+        squeeze_batch = action.ndim == 2
+        if squeeze_batch:
+            action = action.unsqueeze(0)
+        if action.ndim != 3 or action.shape[2] != CANONICAL_DIM:
+            raise ValueError(
+                f"action must be [T,{CANONICAL_DIM}] or [B,T,{CANONICAL_DIM}], "
+                f"got {tuple(action.shape)}."
+            )
+        ref = self.samples[sample_index]
+        case = self.cases[ref.case_index]
+        mean, std, valid = self._domain_stats(case, "action")
+        mean_tensor = torch.from_numpy(mean).to(device=action.device, dtype=action.dtype)
+        std_tensor = torch.from_numpy(std).to(device=action.device, dtype=action.dtype)
+        valid_tensor = torch.from_numpy(valid).to(device=action.device, dtype=torch.bool)
+        denormalized = action * std_tensor.view(1, 1, -1) + mean_tensor.view(1, 1, -1)
+        denormalized = denormalized.masked_fill(~valid_tensor.view(1, 1, -1), 0.0)
+        return (
+            denormalized[0] if squeeze_batch else denormalized,
+            valid_tensor,
+        )
+
+    def _resolve_data_path(self, value: str) -> Path:
+        path = Path(value).expanduser()
+        return path if path.is_absolute() else self.data_root / path
+
+    def _read_episode(self, case: dict[str, Any]) -> dict[str, np.ndarray]:
+        path = self._resolve_data_path(case["inputs"]["canonical_parquet"])
+        cache_key = str(path)
+        cached = self._episode_cache.get(cache_key)
+        if cached is not None:
+            self._episode_cache.move_to_end(cache_key)
+            return cached
+        if not path.is_file():
+            raise FileNotFoundError(f"Canonical episode parquet does not exist: {path}")
+
+        inputs = case["inputs"]
+        columns = [
+            "source_nearest_frame_index",
+            inputs["state_column"],
+            inputs["state_mask_column"],
+            inputs["action_column"],
+            inputs["action_mask_column"],
+        ]
+        table = pq.read_table(path, columns=columns)
+        episode = {
+            "source_frame_index": np.asarray(table["source_nearest_frame_index"].to_pylist(), dtype=np.int64),
+            "state": np.asarray(table[inputs["state_column"]].to_pylist(), dtype=np.float32),
+            "state_mask": np.asarray(table[inputs["state_mask_column"]].to_pylist(), dtype=np.bool_),
+            "action": np.asarray(table[inputs["action_column"]].to_pylist(), dtype=np.float32),
+            "action_mask": np.asarray(table[inputs["action_mask_column"]].to_pylist(), dtype=np.bool_),
+        }
+        row_count = len(episode["source_frame_index"])
+        for name in ("state", "state_mask", "action", "action_mask"):
+            if episode[name].shape != (row_count, CANONICAL_DIM):
+                raise ValueError(
+                    f"Canonical parquet shape mismatch: path={path}, field={name}, "
+                    f"expected={(row_count, CANONICAL_DIM)}, got={episode[name].shape}"
+                )
+        if self.episode_cache_size > 0:
+            self._episode_cache[cache_key] = episode
+            while len(self._episode_cache) > self.episode_cache_size:
+                self._episode_cache.popitem(last=False)
+        return episode
+
+    def _domain_stats(self, case: dict[str, Any], kind: str) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
+        if self._normalization is None or self.normalization_stats_path is None:
+            raise RuntimeError("Robot normalization was disabled for this dataset instance.")
+        domain = str(case["embodiment"]["normalization_domain"])
+        payload = (self._normalization["domains"].get(domain) or {}).get(kind)
+        if payload is None:
+            raise KeyError(
+                f"Missing {kind} normalization for domain={domain} in {self.normalization_stats_path}"
+            )
+        mean = np.asarray(payload.get("mean"), dtype=np.float32)
+        std = np.asarray(payload.get("std"), dtype=np.float32)
+        valid = np.asarray(payload.get("valid_mask"), dtype=np.bool_)
+        if mean.shape != (CANONICAL_DIM,) or std.shape != (CANONICAL_DIM,) or valid.shape != (CANONICAL_DIM,):
+            raise ValueError(
+                f"Malformed {kind} stats for domain={domain}: mean={mean.shape}, std={std.shape}, valid={valid.shape}"
+            )
+        if not np.isfinite(mean).all() or not np.isfinite(std).all() or (std <= 0).any():
+            raise ValueError(f"Non-finite or non-positive {kind} stats for domain={domain}")
+        return mean, std, valid
+
+    def _normalize(
+        self,
+        values: np.ndarray,
+        dimension_valid: np.ndarray,
+        case: dict[str, Any],
+        kind: str,
+    ) -> tuple[torch.Tensor, torch.Tensor]:
+        mean, std, stats_valid = self._domain_stats(case, kind)
+        effective_valid = np.asarray(dimension_valid, dtype=np.bool_) & stats_valid
+        normalized = (values - mean[None, :]) / std[None, :]
+        if self.normalization_clip is not None:
+            normalized = np.clip(normalized, -self.normalization_clip, self.normalization_clip)
+        normalized[:, ~effective_valid] = 0.0
+        if not np.isfinite(normalized).all():
+            raise ValueError(f"Non-finite normalized {kind} values for case_id={case['case_id']}")
+        return torch.from_numpy(np.ascontiguousarray(normalized, dtype=np.float32)), torch.from_numpy(effective_valid.copy())
+
+    @staticmethod
+    def _camera_lookup(case: dict[str, Any]) -> dict[str, dict[str, Any]]:
+        lookup = {}
+        for camera in case["inputs"].get("camera_slots") or []:
+            if camera.get("valid") and camera.get("source_uri"):
+                lookup[str(camera["role"])] = camera
+        return lookup
+
+    def _resolve_video_uri(self, value: str) -> str:
+        if value.startswith(("oxe-pickle://", "hdf5://")):
+            return value
+        if value.startswith("tar://"):
+            payload = value[len("tar://") :]
+            if "!" not in payload:
+                raise ValueError(f"tar URI must use tar://ARCHIVE!MEMBER syntax: {value}")
+            archive, member = payload.split("!", 1)
+            archive_path = Path(archive).expanduser()
+            if not archive_path.is_absolute():
+                archive_path = self.data_root / archive_path
+            return f"tar://{archive_path}!{member}"
+        path = Path(value).expanduser()
+        if not path.is_absolute():
+            path = self.data_root / path
+        return str(path)
+
+    def _compose_video(
+        self, case: dict[str, Any], source_indices: Sequence[int]
+    ) -> tuple[torch.Tensor, torch.Tensor, torch.Tensor]:
+        cameras = self._camera_lookup(case)
+        global_camera = cameras.get("global_primary") or cameras.get("global_secondary") or cameras.get("auxiliary")
+        if global_camera is None:
+            raise ValueError(f"No valid global camera for case_id={case['case_id']}")
+
+        selected = [global_camera, cameras.get("left_wrist"), cameras.get("right_wrist")]
+        present = torch.tensor([camera is not None for camera in selected], dtype=torch.bool)
+        decoded: dict[str, torch.Tensor] = {}
+        for camera in selected:
+            if camera is None:
+                continue
+            uri = self._resolve_video_uri(str(camera["source_uri"]))
+            if uri not in decoded:
+                decoded[uri] = decode_video_frames(
+                    uri,
+                    source_indices,
+                    tar_member_cache_dir=self.tar_member_cache_dir,
+                )
+
+        def prepare(
+            camera: dict[str, Any] | None, size: tuple[int, int]
+        ) -> tuple[torch.Tensor, bool]:
+            if camera is None:
+                if self.missing_camera_policy == "repeat_global":
+                    camera = global_camera
+                else:
+                    return (
+                        torch.zeros((len(source_indices), 3, *size), dtype=torch.float32),
+                        False,
+                    )
+            uri = self._resolve_video_uri(str(camera["source_uri"]))
+            frames = decoded.get(uri)
+            if frames is None:
+                frames = decode_video_frames(
+                    uri,
+                    source_indices,
+                    tar_member_cache_dir=self.tar_member_cache_dir,
+                )
+                decoded[uri] = frames
+            tensor = frames.permute(0, 3, 1, 2).to(dtype=torch.float32).div_(255.0)
+            if self.camera_rectification is not None:
+                return self.camera_rectification.rectify(
+                    tensor,
+                    camera=camera,
+                    output_size=size,
+                )
+            return (
+                transforms_F.resize(
+                    tensor,
+                    size=list(size),
+                    interpolation=transforms_F.InterpolationMode.BILINEAR,
+                    antialias=True,
+                ),
+                False,
+            )
+
+        top, top_rectified = prepare(selected[0], (256, 320))
+        left, left_rectified = prepare(selected[1], (128, 160))
+        right, right_rectified = prepare(selected[2], (128, 160))
+        composite = torch.cat([top, torch.cat([left, right], dim=-1)], dim=-2)
+        if tuple(composite.shape[-2:]) != self.video_size:
+            composite = transforms_F.resize(
+                composite,
+                size=list(self.video_size),
+                interpolation=transforms_F.InterpolationMode.BILINEAR,
+                antialias=True,
+            )
+        video = composite.mul(2.0).sub(1.0).permute(1, 0, 2, 3).contiguous()
+        rectified = torch.tensor(
+            [top_rectified, left_rectified, right_rectified], dtype=torch.bool
+        )
+        return video, present, rectified
+
+    def _get_cached_text_context(self, prompt: str) -> tuple[torch.Tensor, torch.Tensor]:
+        hashed = hashlib.sha256(prompt.encode("utf-8")).hexdigest()
+        path = self.text_embedding_cache_dir / f"{hashed}.t5_len{self.context_len}.wan22ti2v5b.pt"
+        if not path.is_file():
+            raise FileNotFoundError(
+                f"Missing text embedding cache: {path}. Run scripts/precompute_text_embeds.py first."
+            )
+        payload = torch.load(path, map_location="cpu", weights_only=True)
+        context = payload["context"]
+        context_mask = payload["mask"].to(dtype=torch.bool)
+        if context.ndim != 2 or tuple(context.shape) != (self.context_len, 4096):
+            raise ValueError(
+                f"Cached context must have shape [{self.context_len},4096], got {tuple(context.shape)} in {path}"
+            )
+        if tuple(context_mask.shape) != (self.context_len,):
+            raise ValueError(
+                f"Cached context mask must have shape [{self.context_len}], got {tuple(context_mask.shape)} in {path}"
+            )
+        context = context.clone()
+        context[~context_mask] = 0.0
+        # Keep parity with the Wan2.2 text-conditioning behavior used by RobotVideoDataset.
+        context_mask = torch.ones_like(context_mask)
+        return context, context_mask
+
+    def _build_sample(
+        self,
+        index: int,
+        *,
+        additional_source_indices: Sequence[int] | None = None,
+    ) -> tuple[dict[str, Any], torch.Tensor | None]:
+        ref = self.samples[index]
+        case = self.cases[ref.case_index]
+        episode = self._read_episode(case)
+        start = ref.start
+        stop = start + 81
+        if stop > len(episode["source_frame_index"]):
+            raise IndexError(
+                f"Training window exceeds canonical episode: case_id={case['case_id']}, "
+                f"start={start}, stop={stop}, rows={len(episode['source_frame_index'])}"
+            )
+
+        training = case["training"]
+        has_robot_supervision = (
+            self.include_robot_supervision
+            and str(training.get("mode")) == "joint_video_action"
+            and bool((training.get("loss_mask") or {}).get("action", True))
+        )
+        if has_robot_supervision:
+            state_values = episode["state"][start : start + 80].copy()
+            action_values = episode["action"][start : start + 80].copy()
+            state_valid = episode["state_mask"][start : start + 80].all(axis=0)
+            action_valid = episode["action_mask"][start : start + 80].all(axis=0)
+            state_valid &= np.asarray(case["inputs"]["state_slot_mask"], dtype=np.bool_)
+            action_valid &= np.asarray(case["inputs"]["action_slot_mask"], dtype=np.bool_)
+            proprio, proprio_valid = self._normalize(state_values, state_valid, case, "state")
+            action, action_valid = self._normalize(action_values, action_valid, case, "action")
+        else:
+            proprio = torch.zeros((80, CANONICAL_DIM), dtype=torch.float32)
+            action = torch.zeros((80, CANONICAL_DIM), dtype=torch.float32)
+            proprio_valid = torch.zeros(CANONICAL_DIM, dtype=torch.bool)
+            action_valid = torch.zeros(CANONICAL_DIM, dtype=torch.bool)
+
+        offsets = np.asarray(case["timeline"]["video_offsets"], dtype=np.int64)
+        source_indices = episode["source_frame_index"][start + offsets].tolist()
+        if source_indices != sorted(source_indices):
+            raise ValueError(
+                f"Canonical-to-source video indices must be nondecreasing: "
+                f"case_id={case['case_id']}, start={start}, indices={source_indices}"
+            )
+        additional_source_indices = [
+            int(value) for value in (additional_source_indices or ())
+        ]
+        combined_video, camera_present, camera_rectified = self._compose_video(
+            case, source_indices + additional_source_indices
+        )
+        video = combined_video[:, : len(source_indices)]
+        additional_video = (
+            combined_video[:, len(source_indices) :]
+            if additional_source_indices
+            else None
+        )
+        if tuple(video.shape) != (3, 21, *self.video_size):
+            raise ValueError(
+                f"FastWAM video shape mismatch for case_id={case['case_id']}: got {tuple(video.shape)}"
+            )
+
+        task = str(case["language"]["primary"])
+        prompt = DEFAULT_PROMPT.format(task=task)
+        context, context_mask = self._get_cached_text_context(prompt)
+        conditioning_mask = training.get("conditioning_mask") or {}
+        loss_mask = training.get("loss_mask") or {}
+        loss_weights = training.get("loss_weights") or {}
+
+        sample = {
+            "video": video,
+            "action": action,
+            "proprio": proprio,
+            "prompt": prompt,
+            "context": context,
+            "context_mask": context_mask,
+            "image_is_pad": torch.zeros(21, dtype=torch.bool),
+            "action_is_pad": torch.zeros(80, dtype=torch.bool),
+            "proprio_is_pad": torch.zeros(80, dtype=torch.bool),
+            "action_dim_is_pad": ~action_valid,
+            "proprio_dim_is_pad": ~proprio_valid,
+            "proprio_condition_mask": torch.tensor(bool(conditioning_mask.get("state", True))),
+            "action_loss_mask": torch.tensor(bool(loss_mask.get("action", True))),
+            "video_loss_mask": torch.tensor(bool(loss_mask.get("video", True))),
+            "action_loss_weight": torch.tensor(float(loss_weights.get("action", 1.0)), dtype=torch.float32),
+            "video_loss_weight": torch.tensor(float(loss_weights.get("video", 1.0)), dtype=torch.float32),
+            "sample_weight": torch.tensor(
+                float(training.get("sample_weight", 1.0)) * float(training.get("mixture_weight", 1.0)),
+                dtype=torch.float32,
+            ),
+            "camera_present_mask": camera_present,
+            "camera_rectification_applied_mask": camera_rectified,
+            "sample_index": torch.tensor(index, dtype=torch.int64),
+            "window_start": torch.tensor(start, dtype=torch.int64),
+        }
+        return sample, additional_video
+
+    def __getitem__(self, index: int) -> dict[str, Any]:
+        sample, _ = self._build_sample(index)
+        return sample
+
+
+class MemoryTrainingCaseDataset(TrainingCaseDataset):
+    """TrainingCaseV1 loader with leak-free 8/2/1 historical visual memory."""
+
+    def __init__(
+        self,
+        *args,
+        memory_history_long: int = 8,
+        memory_history_mid: int = 2,
+        memory_history_short: int = 1,
+        **kwargs,
+    ):
+        super().__init__(*args, **kwargs)
+        self.memory_history_sizes = normalize_history_sizes(
+            {
+                "long": memory_history_long,
+                "mid": memory_history_mid,
+                "short": memory_history_short,
+            }
+        )
+
+    def __getitem__(self, index: int) -> dict[str, Any]:
+        ref = self.samples[index]
+        case = self.cases[ref.case_index]
+        episode = self._read_episode(case)
+        selection = select_multiscale_history_indices(
+            start_index=0,
+            current_index=ref.start,
+            end_index=len(episode["source_frame_index"]),
+            history_sizes=self.memory_history_sizes,
+        )
+        masks = torch.cat(
+            [selection.mask_long, selection.mask_mid, selection.mask_short], dim=0
+        )
+        if bool(masks.any()):
+            source_indices = episode["source_frame_index"][selection.indices_all].tolist()
+            sample, memory_video = self._build_sample(
+                index, additional_source_indices=source_indices
+            )
+            if memory_video is None:
+                raise RuntimeError("Expected decoded memory video for non-empty history.")
+        else:
+            sample, _ = self._build_sample(index)
+            count = len(selection.indices_all)
+            memory_video = sample["video"][:, :1].expand(-1, count, -1, -1).contiguous()
