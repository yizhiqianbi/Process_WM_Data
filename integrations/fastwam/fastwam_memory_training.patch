+import json
+import os
+import sys
+import zipfile
+from pathlib import Path
+
+
+SCRIPT_DIR = Path(__file__).resolve().parents[1] / "scripts" / "rmbench"
+if str(SCRIPT_DIR) not in sys.path:
+    sys.path.insert(0, str(SCRIPT_DIR))
+
+from launch_rmbench_helios_training import (  # noqa: E402
+    _checkpoint_is_complete,
+    _latest_training_state,
+)
+from experiments.robotwin.fastwam_helios_client import (  # noqa: E402
+    _should_refresh_observation,
+)
+from launch_rmbench_helios_evaluation import (  # noqa: E402
+    _available_slots,
+    _checkpoint,
+    _port_for_slot,
+    _progress_protocol_from_environment,
+    _render_lock_path_from_environment,
+    _should_retry,
+)
+
+
+def _write_checkpoint(path: Path) -> None:
+    path.parent.mkdir(parents=True, exist_ok=True)
+    with zipfile.ZipFile(path, "w") as archive:
+        archive.writestr("archive/data.pkl", b"payload")
+        archive.writestr("archive/version", b"3\n")
+
+
+def _write_state(root: Path, task: str, step: int, *, complete: bool = True) -> Path:
+    path = root / "runs" / task / "checkpoints" / "state" / f"step_{step:06d}"
+    path.mkdir(parents=True)
+    (path / "trainer_state.json").write_text(
+        json.dumps({"global_step": step}), encoding="utf-8"
+    )
+    for name in ("model.safetensors", "optimizer.bin", "scheduler.bin"):
+        (path / name).write_bytes(b"complete")
+    if complete:
+        (path / "random_states_0.pkl").write_bytes(b"complete")
+    return path
+
+
+def test_checkpoint_archive_must_have_torch_payload_and_version(tmp_path: Path):
+    checkpoint = tmp_path / "step_002500.pt"
+    _write_checkpoint(checkpoint)
+    assert _checkpoint_is_complete(checkpoint)
+
+    truncated = tmp_path / "truncated.pt"
+    truncated.write_bytes(checkpoint.read_bytes()[:24])
+    assert not _checkpoint_is_complete(truncated)
+
+
+def test_latest_training_state_ignores_partial_and_final_state(tmp_path: Path):
+    valid = _write_state(tmp_path, "press_button", 500)
+    _write_state(tmp_path, "press_button", 1000, complete=False)
+    _write_state(tmp_path, "press_button", 2500)
+
+    assert _latest_training_state(tmp_path, "press_button", 2500) == valid.resolve()
+
+
+def test_evaluation_requires_the_exact_complete_checkpoint(tmp_path: Path):
+    earlier = (
+        tmp_path
+        / "runs"
+        / "press_button"
+        / "checkpoints"
+        / "weights"
+        / "step_002000.pt"
+    )
+    _write_checkpoint(earlier)
+    try:
+        _checkpoint(tmp_path, "press_button", 2500)
+    except FileNotFoundError as error:
+        assert "step 2500" in str(error)
+    else:
+        raise AssertionError("evaluation silently selected an earlier checkpoint")
+
+    exact = earlier.with_name("step_002500.pt")
+    _write_checkpoint(exact)
+    assert _checkpoint(tmp_path, "press_button", 2500) == exact.resolve()
+
+
+def test_multi_job_evaluation_spreads_first_wave_across_all_gpus():
+    gpus = [str(index) for index in range(8)]
+    slots = _available_slots(gpus, 2, occupied=set())
+    assert slots[:8] == [(gpu, 0) for gpu in gpus]
+    assert slots[8] == ("0", 1)
+    assert len(slots) == 16
+    assert len({_port_for_slot(19000, gpu, 2, slot) for gpu, slot in slots}) == 16
+    assert _port_for_slot(19000, "0", 2, 0) == 19000
+    assert _port_for_slot(19000, "7", 2, 1) == 19015
+
+
+def test_evaluation_retries_native_failures_but_stops_at_the_bound():
+    assert _should_retry(succeeded=False, attempt=1, max_attempts=3)
+    assert _should_retry(succeeded=False, attempt=2, max_attempts=3)
+    assert not _should_retry(succeeded=False, attempt=3, max_attempts=3)
+    assert not _should_retry(succeeded=True, attempt=1, max_attempts=3)
+
+
+def test_rmbench_observation_refresh_matches_fastwam_video_stride():
+    assert [
+        completed
+        for completed in range(1, 9)
+        if _should_refresh_observation(completed, 8, 4)
+    ] == [4]
+    assert [
+        completed
+        for completed in range(1, 9)
+        if _should_refresh_observation(completed, 8, 1)
+    ] == list(range(1, 8))
+
+
+def test_evaluation_progress_identity_captures_pixels_and_observation_cadence():
+    protocol = _progress_protocol_from_environment(
+        {
+            "RMBENCH_OBSERVATION_STRIDE": "4",
+            "RMBENCH_SKIP_CAMERA_CONFIG": "1",
+            "RMBENCH_RENDER_SHADER": "rt",
+            "RMBENCH_RT_SAMPLES": "1",
+            "RMBENCH_RT_PATH_DEPTH": "1",
+            "RMBENCH_RT_DENOISER": "none",
+        }
+    )
+    assert protocol == {
+        "observation_stride_actions": 4,
+        "camera_config_in_observation": False,
+        "renderer": {
+            "shader": "rt",
+            "pipeline": "ray_tracing",
+            "samples_per_pixel": 1,
+            "path_depth": 1,
+            "denoiser": "none",
+        },
+    }
+
+    raster = _progress_protocol_from_environment(
+        {
+            "RMBENCH_OBSERVATION_STRIDE": "4",
+            "RMBENCH_SKIP_CAMERA_CONFIG": "1",
+            "RMBENCH_RENDER_SHADER": "default",
+        }
+    )
+    assert raster["renderer"] == {
+        "shader": "default",
+        "pipeline": "raster",
+        "samples_per_pixel": None,
+        "path_depth": None,
+        "denoiser": None,
+    }
+    assert _render_lock_path_from_environment(
+        {"RMBENCH_RENDER_SHADER": "default"}
+    ) is None
+    assert _render_lock_path_from_environment(
+        {
+            "RMBENCH_RENDER_SHADER": "rt",
+            "RMBENCH_RENDER_LOCK_PATH": "",
+        }
+    ) is None
+    assert _render_lock_path_from_environment(
+        {"RMBENCH_RENDER_SHADER": "rt"}
+    ) == f"/tmp/rmbench-lavapipe-render-{os.getuid()}.lock"
+
+
+def test_eval_shell_caps_cpu_thread_pools():
+    script = (SCRIPT_DIR / "eval_rmbench_helios.sh").read_text(encoding="utf-8")
+    assert 'RMBENCH_RENDER_SHADER="${RMBENCH_RENDER_SHADER:-default}"' in script
+    assert 'if [[ "${RMBENCH_RENDER_SHADER}" == "rt" ]]' in script
+    assert 'RMBENCH_RENDER_LOCK_PATH=""' in script
+    for variable in (
+        "LP_NUM_THREADS",
+        "OMP_NUM_THREADS",
+        "MKL_NUM_THREADS",
+        "OPENBLAS_NUM_THREADS",
+        "NUMEXPR_NUM_THREADS",
+        "TORCHINDUCTOR_COMPILE_THREADS",
+        "PYTHONFAULTHANDLER",
+        "XDG_CACHE_HOME",
+        "MESA_SHADER_CACHE_DIR",
+        "RMBENCH_RENDER_LOCK_PATH",
+        "RMBENCH_SKIP_CAMERA_CONFIG",
+        "RMBENCH_OBSERVATION_STRIDE",
+    ):
+        assert f"export {variable}" in script
