+from types import SimpleNamespace
+
+import torch
+
+from fastwam.datasets.memory_bank import (
+    build_multiscale_memory_videos_from_history,
+    select_multiscale_history_indices,
+)
+from fastwam.models.wan22.memory_fastwam import MemoryFastWAM
+from fastwam.models.wan22.mot import MoT
+
+
+def test_memory_selection_never_uses_current_or_future_frames():
+    selection = select_multiscale_history_indices(
+        start_index=0,
+        current_index=20,
+        end_index=200,
+        history_sizes={"long": 8, "mid": 2, "short": 1},
+    )
+
+    valid_indices = [
+        index
+        for index, valid in zip(
+            selection.indices_all,
+            torch.cat([selection.mask_long, selection.mask_mid, selection.mask_short]).tolist(),
+        )
+        if valid
+    ]
+    assert valid_indices == list(range(9, 20))
+    assert max(valid_indices) < 20
+
+
+def test_memory_selection_left_padding_is_invalid():
+    selection = select_multiscale_history_indices(
+        start_index=0,
+        current_index=2,
+        end_index=100,
+    )
+    mask = torch.cat([selection.mask_long, selection.mask_mid, selection.mask_short])
+
+    assert selection.indices_all == [2] * 9 + [0, 1]
+    assert mask.tolist() == [False] * 9 + [True, True]
+
+
+def test_closed_loop_history_builds_expected_8_2_1_groups():
+    history = [torch.full((1, 3, 4, 4), float(index)) for index in range(12)]
+
+    groups = build_multiscale_memory_videos_from_history(history)
+
+    assert groups["memory_video_long"].shape == (1, 3, 8, 4, 4)
+    assert groups["memory_video_mid"].shape == (1, 3, 2, 4, 4)
+    assert groups["memory_video_short"].shape == (1, 3, 1, 4, 4)
+    assert groups["memory_video_long"][0, 0, :, 0, 0].tolist() == list(range(8))
+    assert groups["memory_video_mid"][0, 0, :, 0, 0].tolist() == [8.0, 9.0]
+    assert groups["memory_video_short"][0, 0, :, 0, 0].tolist() == [10.0]
+    assert torch.cat(
+        [
+            groups["memory_mask_long"],
+            groups["memory_mask_mid"],
+            groups["memory_mask_short"],
+        ]
+    ).all()
+
+
+def test_closed_loop_history_excludes_current_and_masks_padding():
+    history = [torch.full((1, 3, 2, 2), float(index)) for index in range(3)]
+
+    groups = build_multiscale_memory_videos_from_history(history)
+    memory = torch.cat(
+        [
+            groups["memory_video_long"],
+            groups["memory_video_mid"],
+            groups["memory_video_short"],
+        ],
+        dim=2,
+    )
+    mask = torch.cat(
+        [
+            groups["memory_mask_long"],
+            groups["memory_mask_mid"],
+            groups["memory_mask_short"],
+        ]
+    )
+
+    assert memory[0, 0, :, 0, 0].tolist() == [2.0] * 9 + [0.0, 1.0]
+    assert mask.tolist() == [False] * 9 + [True, True]
+
+
+def test_attention_mask_hides_invalid_memory_keys():
+    class VideoExpert:
+        @staticmethod
+        def build_video_to_video_mask(video_seq_len, video_tokens_per_frame, device):
+            del video_tokens_per_frame
+            return torch.ones((video_seq_len, video_seq_len), dtype=torch.bool, device=device)
+
+    dummy = SimpleNamespace(video_expert=VideoExpert())
+    memory_valid = torch.tensor([[False, True, False], [True, True, True]])
+    mask = MemoryFastWAM._build_memory_attention_mask(
+        dummy,
+        memory_valid=memory_valid,
+        target_video_seq_len=4,
+        action_seq_len=2,
+        video_tokens_per_frame=2,
+        device=torch.device("cpu"),
+    )[:, 0]
+
+    # Target and action queries cannot consume invalid memory columns.
+    assert not mask[0, 3:, 0].any()
+    assert not mask[0, 3:, 2].any()
+    assert mask[0, 3:, 1].all()
+    assert mask[1, 3:, :3].all()
+
+
+def test_mot_accepts_per_sample_memory_attention_mask():
+    MoT._validate_attention_mask(
+        torch.ones((2, 1, 9, 9), dtype=torch.bool),
+        batch_size=2,
+        query_length=9,
+        key_length=9,
+    )
+
+
+def test_mot_rejects_wrong_memory_attention_batch():
+    try:
+        MoT._validate_attention_mask(
+            torch.ones((3, 1, 9, 9), dtype=torch.bool),
+            batch_size=2,
+            query_length=9,
+            key_length=9,
+        )
+    except ValueError as exc:
+        assert "batch dimension" in str(exc)
+    else:
+        raise AssertionError("Expected per-sample attention batch mismatch to fail")
+
+
+def test_joint_noise_removes_memory_prefix_before_video_post_dit():
+    class VideoExpert:
+        action_conditioned = False
+
+        def __init__(self):
+            self.post_tokens = None
+
+        @staticmethod
+        def pre_dit(**kwargs):
+            del kwargs
+            return {
+                "tokens": torch.full((1, 2, 4), 7.0),
+                "freqs": torch.zeros(2, 1, 2),
+                "t": torch.zeros(1, 2, 4),
+                "t_mod": torch.zeros(1, 2, 6, 4),
+                "context": torch.zeros(1, 3, 4),
+                "context_mask": torch.ones(1, 2, 3, dtype=torch.bool),
+                "meta": {"tokens_per_frame": 1, "grid_size": (2, 1, 1)},
+            }
+
+        def post_dit(self, tokens, pre_state):
+            del pre_state
+            self.post_tokens = tokens
+            return tokens
+
+    class ActionExpert:
+        action_dim = 4
+
+        @staticmethod
+        def pre_dit(**kwargs):
+            del kwargs
+            return {
+                "tokens": torch.full((1, 3, 4), 9.0),
+                "freqs": torch.zeros(3, 1, 2),
+                "context": torch.zeros(1, 3, 4),
+                "context_mask": torch.ones(1, 3, dtype=torch.bool),
+                "t_mod": torch.zeros(1, 3, 6, 4),
+            }
+
+        @staticmethod
+        def post_dit(tokens, pre_state):
+            del pre_state
+            return tokens
+
+    class Mot:
+        @staticmethod
+        def __call__(**kwargs):
+            return kwargs["embeds_all"]
+
+    video_expert = VideoExpert()
+    memory_valid = torch.tensor([[True, False, True]])
+    dummy = SimpleNamespace(
+        video_expert=video_expert,
+        action_expert=ActionExpert(),
+        mot=Mot(),
+        _prepend_memory=lambda video_pre, memory_inputs: (
+            {
+                **video_pre,
+                "tokens": torch.cat(
+                    [torch.full((1, 3, 4), 5.0), video_pre["tokens"]], dim=1
+                ),
+                "freqs": torch.zeros(5, 1, 2),
+                "t_mod": torch.zeros(1, 5, 6, 4),
+                "context_mask": torch.ones(1, 5, 3, dtype=torch.bool),
+            },
+            memory_valid,
+        ),
+        _build_memory_attention_mask=lambda **kwargs: torch.ones(
+            (1, 1, 8, 8), dtype=torch.bool
+        ),
+    )
+
+    pred_video, pred_action, returned_valid = (
+        MemoryFastWAM._predict_joint_noise_with_memory(
+            dummy,
+            latents_video=torch.zeros(1, 4, 2, 1, 1),
+            latents_action=torch.zeros(1, 3, 4),
+            timestep_video=torch.zeros(1),
+            timestep_action=torch.zeros(1),
+            context=torch.zeros(1, 3, 4),
+            context_mask=torch.ones(1, 3, dtype=torch.bool),
+            fuse_vae_embedding_in_latents=True,
+            memory_inputs={},
+        )
+    )
+
+    assert tuple(pred_video.shape) == (1, 2, 4)
+    assert tuple(pred_action.shape) == (1, 3, 4)
+    assert torch.equal(returned_valid, memory_valid)
+    assert torch.equal(video_expert.post_tokens, torch.full((1, 2, 4), 7.0))
