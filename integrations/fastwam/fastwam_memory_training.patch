diff --git a/scripts/rmbench/launch_rmbench_helios_evaluation.py b/scripts/rmbench/launch_rmbench_helios_evaluation.py
new file mode 100755
index 0000000..f611171
--- /dev/null
+++ b/scripts/rmbench/launch_rmbench_helios_evaluation.py
@@ -0,0 +1,382 @@
+#!/usr/bin/env python3
+"""Run official RMBench evaluations with one task bound to each GPU."""
+
+from __future__ import annotations
+
+import argparse
+import json
+import os
+import subprocess
+import time
+from pathlib import Path
+from typing import Any, Mapping
+
+from launch_rmbench_helios_training import _checkpoint_is_complete
+from prepare_helios_memory_data import OFFICIAL_TASKS
+
+
+def _read_json(path: Path) -> dict[str, Any] | None:
+    try:
+        return json.loads(path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError):
+        return None
+
+
+def _checkpoint(root: Path, task: str, step: int) -> Path:
+    weights = root / "runs" / task / "checkpoints" / "weights"
+    exact = weights / f"step_{step:06d}.pt"
+    if _checkpoint_is_complete(exact):
+        return exact.resolve()
+    raise FileNotFoundError(
+        f"Complete FastWAM checkpoint step {step} not found for {task}: {exact}"
+    )
+
+
+def _latest_result(rmbench_root: Path, task: str, since: float) -> Path | None:
+    task_root = rmbench_root / "eval_result" / task / "fastwam_helios_client"
+    candidates = [
+        path
+        for path in task_root.glob("**/_result.txt")
+        if path.stat().st_mtime >= since - 2.0
+    ]
+    return max(candidates, key=lambda path: path.stat().st_mtime) if candidates else None
+
+
+def _available_slots(
+    gpus: list[str], jobs_per_gpu: int, occupied: set[tuple[str, int]]
+) -> list[tuple[str, int]]:
+    return [
+        (gpu, slot)
+        for slot in range(jobs_per_gpu)
+        for gpu in gpus
+        if (gpu, slot) not in occupied
+    ]
+
+
+def _port_for_slot(port_base: int, gpu: str, jobs_per_gpu: int, slot: int) -> int:
+    return port_base + int(gpu) * jobs_per_gpu + slot
+
+
+def _should_retry(*, succeeded: bool, attempt: int, max_attempts: int) -> bool:
+    return not succeeded and attempt < max_attempts
+
+
+def _environment_bool(environment: Mapping[str, str], name: str, default: str) -> bool:
+    value = environment.get(name, default).strip().lower()
+    if value in {"1", "true", "yes"}:
+        return True
+    if value in {"0", "false", "no"}:
+        return False
+    raise ValueError(f"{name} must be a boolean value, got {value!r}")
+
+
+def _progress_protocol_from_environment(
+    environment: Mapping[str, str] | None = None,
+) -> dict[str, Any]:
+    values = os.environ if environment is None else environment
+    observation_stride = int(values.get("RMBENCH_OBSERVATION_STRIDE", "4"))
+    if observation_stride <= 0:
+        raise ValueError("RMBENCH observation stride must be positive")
+    shader = values.get("RMBENCH_RENDER_SHADER", "default").strip()
+    if not shader:
+        raise ValueError("RMBENCH_RENDER_SHADER must not be empty")
+    if shader == "rt":
+        samples = int(values.get("RMBENCH_RT_SAMPLES", "32"))
+        path_depth = int(values.get("RMBENCH_RT_PATH_DEPTH", "8"))
+        if samples <= 0 or path_depth <= 0:
+            raise ValueError(
+                "RMBENCH ray-tracing samples and path depth must be positive"
+            )
+        renderer = {
+            "shader": shader,
+            "pipeline": "ray_tracing",
+            "samples_per_pixel": samples,
+            "path_depth": path_depth,
+            "denoiser": values.get("RMBENCH_RT_DENOISER", "none"),
+        }
+    else:
+        renderer = {
+            "shader": shader,
+            "pipeline": "raster",
+            "samples_per_pixel": None,
+            "path_depth": None,
+            "denoiser": None,
+        }
+    return {
+        "observation_stride_actions": observation_stride,
+        "camera_config_in_observation": not _environment_bool(
+            values, "RMBENCH_SKIP_CAMERA_CONFIG", "0"
+        ),
+        "renderer": renderer,
+    }
+
+
+def _render_lock_path_from_environment(
+    environment: Mapping[str, str] | None = None,
+) -> str | None:
+    values = os.environ if environment is None else environment
+    if "RMBENCH_RENDER_LOCK_PATH" in values:
+        return values["RMBENCH_RENDER_LOCK_PATH"].strip() or None
+    if values.get("RMBENCH_RENDER_SHADER", "default").strip() == "rt":
+        return f"/tmp/rmbench-lavapipe-render-{os.getuid()}.lock"
+    return None
+
+
+def main() -> None:
+    parser = argparse.ArgumentParser()
+    parser.add_argument("--gpus", default="0,1,2,3,4,5,6,7")
+    parser.add_argument("--tasks", nargs="*", default=list(OFFICIAL_TASKS))
+    parser.add_argument("--step", type=int, default=2500)
+    parser.add_argument("--port-base", type=int, default=19000)
+    parser.add_argument("--jobs-per-gpu", type=int, default=1)
+    parser.add_argument("--max-attempts", type=int, default=3)
+    parser.add_argument("--launch-stagger-seconds", type=float, default=0.0)
+    parser.add_argument("--force", action="store_true")
+    parser.add_argument(
+        "--root",
+        type=Path,
+        default=Path("/public/interns/hubin/dataset/RMBench/fastwam_helios"),
+    )
+    parser.add_argument(
+        "--rmbench-root",
+        type=Path,
+        default=Path("/public/interns/hubin/code/RMBench"),
+    )
+    args = parser.parse_args()
+    gpus = [value.strip() for value in args.gpus.split(",") if value.strip()]
+    try:
+        gpu_indices = [int(value) for value in gpus]
+    except ValueError:
+        gpu_indices = []
+    unknown = [task for task in args.tasks if task not in OFFICIAL_TASKS]
+    if (
+        not gpus
+        or len(gpu_indices) != len(gpus)
+        or any(value < 0 for value in gpu_indices)
+        or len(gpu_indices) != len(set(gpu_indices))
+        or args.step <= 0
+        or args.jobs_per_gpu <= 0
+        or args.max_attempts <= 0
+        or args.launch_stagger_seconds < 0
+        or not 1 <= args.port_base <= 65535
+        or args.port_base + (max(gpu_indices, default=0) + 1) * args.jobs_per_gpu > 65536
+        or not args.tasks
+        or len(args.tasks) != len(set(args.tasks))
+        or unknown
+    ):
+        parser.error(
+            "At least one GPU, positive --step/--jobs-per-gpu/--max-attempts, "
+            "non-negative --launch-stagger-seconds, "
+            "a valid port range, "
+            f"and unique official task names are required; unknown={unknown}"
+        )
+
+    root = args.root.expanduser().resolve()
+    rmbench_root = args.rmbench_root.expanduser().resolve()
+    progress_protocol = _progress_protocol_from_environment()
+    render_lock_path = _render_lock_path_from_environment()
+    script = Path(__file__).with_name("eval_rmbench_helios.sh").resolve()
+    receipt_dir = root / "evaluation" / "receipts"
+    log_dir = root / "evaluation" / "launch_logs"
+    receipt_dir.mkdir(parents=True, exist_ok=True)
+    log_dir.mkdir(parents=True, exist_ok=True)
+
+    pending: list[tuple[str, Path, int]] = []
+    results: dict[str, dict[str, Any]] = {}
+    attempt_history: dict[str, list[dict[str, Any]]] = {}
+    for task in args.tasks:
+        checkpoint = _checkpoint(root, task, args.step)
+        receipt_path = receipt_dir / f"{task}.json"
+        existing = _read_json(receipt_path)
+        existing_progress = (
+            None
+            if existing is None
+            else _read_json(Path(str(existing.get("progress_path", ""))))
+        )
+        if (
+            not args.force
+            and existing is not None
+            and existing.get("status") == "succeeded"
+            and existing.get("checkpoint") == str(checkpoint)
+            and Path(str(existing.get("result_path", ""))).is_file()
+            and existing_progress is not None
+            and existing_progress.get("status") == "completed"
+            and int(existing_progress.get("evaluated_rollouts", -1)) == 100
+        ):
+            results[task] = existing
+            print(f"[reuse] task={task} result={existing['result_path']}", flush=True)
+        else:
+            pending.append((task, checkpoint, 1))
+
+    running: dict[
+        str, tuple[subprocess.Popen[bytes], object, str, int, int, Path, float, int]
+    ] = {}
+    while pending or running:
+        occupied = {(value[2], value[3]) for value in running.values()}
+        for gpu, gpu_slot in _available_slots(gpus, args.jobs_per_gpu, occupied):
+            if not pending:
+                break
+            task, checkpoint, attempt = pending.pop(0)
+            port = _port_for_slot(args.port_base, gpu, args.jobs_per_gpu, gpu_slot)
+            log_path = log_dir / f"{task}.log"
+            if args.force:
+                (
+                    root
+                    / "evaluation"
+                    / task
+                    / f"progress_step_{args.step:06d}_100rollouts.json"
+                ).unlink(missing_ok=True)
+            log_handle = log_path.open("a", encoding="utf-8")
+            started_at = time.time()
+            environment = os.environ.copy()
+            environment["RMBENCH_HELIOS_ROOT"] = str(root)
+            environment["RMBENCH_ROOT"] = str(rmbench_root)
+            process = subprocess.Popen(
+                [str(script), task, str(checkpoint), gpu, str(port)],
+                stdout=log_handle,
+                stderr=subprocess.STDOUT,
+                start_new_session=True,
+                env=environment,
+            )
+            running[task] = (
+                process,
+                log_handle,
+                gpu,
+                gpu_slot,
+                port,
+                checkpoint,
+                started_at,
+                attempt,
+            )
+            print(
+                f"[launch] task={task} attempt={attempt}/{args.max_attempts} "
+                f"gpu={gpu} slot={gpu_slot} port={port} "
+                f"pid={process.pid} "
+                f"checkpoint={checkpoint} log={log_path}",
+                flush=True,
+            )
+            if args.launch_stagger_seconds:
+                time.sleep(args.launch_stagger_seconds)
+
+        if running:
+            time.sleep(10)
+        for task, values in list(running.items()):
+            (
+                process,
+                log_handle,
+                gpu,
+                gpu_slot,
+                port,
+                checkpoint,
+                started_at,
+                attempt,
+            ) = values
+            return_code = process.poll()
+            if return_code is None:
+                continue
+            log_handle.close()
+            result_path = _latest_result(rmbench_root, task, started_at)
+            progress_path = (
+                root
+                / "evaluation"
+                / task
+                / f"progress_step_{args.step:06d}_100rollouts.json"
+            )
+            progress = _read_json(progress_path)
+            succeeded = (
+                return_code == 0
+                and result_path is not None
+                and progress is not None
+                and progress.get("status") == "completed"
+                and int(progress.get("evaluated_rollouts", -1)) == 100
+                and int((progress.get("identity") or {}).get("target_rollouts", -1)) == 100
+                and (progress.get("identity") or {}).get("protocol")
+                == progress_protocol
+            )
+            finished_at = time.time()
+            attempt_history.setdefault(task, []).append(
+                {
+                    "attempt": attempt,
+                    "return_code": return_code,
+                    "started_at_unix": started_at,
+                    "finished_at_unix": finished_at,
+                    "progress_status": None if progress is None else progress.get("status"),
+                    "evaluated_rollouts": (
+                        None if progress is None else progress.get("evaluated_rollouts")
+                    ),
+                }
+            )
+            del running[task]
+            if _should_retry(
+                succeeded=succeeded,
+                attempt=attempt,
+                max_attempts=args.max_attempts,
+            ):
+                pending.append((task, checkpoint, attempt + 1))
+                print(
+                    f"[retry] task={task} failed attempt={attempt}/{args.max_attempts} "
+                    f"return_code={return_code}; progress will resume if available",
+                    flush=True,
+                )
+                continue
+            receipt = {
+                "schema_version": "fastwam-rmbench-evaluation-task-v1",
+                "status": "succeeded" if succeeded else "failed",
+                "task": task,
+                "gpu": gpu,
+                "gpu_slot": gpu_slot,
+                "port": port,
+                "checkpoint": str(checkpoint),
+                "return_code": return_code,
+                "attempt": attempt,
+                "attempts": attempt_history[task],
+                "result_path": None if result_path is None else str(result_path.resolve()),
+                "progress_path": str(progress_path.resolve()),
+                "started_at_unix": started_at,
+                "finished_at_unix": finished_at,
+                "protocol": {
+                    "rollouts": 100,
+                    "instruction_type": "unseen",
+                    "expert_seed_filter": True,
+                    "observation_stride_actions": progress_protocol[
+                        "observation_stride_actions"
+                    ],
+                    "camera_config_in_observation": progress_protocol[
+                        "camera_config_in_observation"
+                    ],
+                    "renderer": {
+                        **progress_protocol["renderer"],
+                        "vulkan_device": "Mesa lavapipe (CPU)",
+                        "interprocess_lock_path": render_lock_path,
+                    },
+                },
+            }
+            (receipt_dir / f"{task}.json").write_text(
+                json.dumps(receipt, indent=2, sort_keys=True) + "\n", encoding="utf-8"
+            )
+            results[task] = receipt
+            print(
+                f"[done] task={task} gpu={gpu} status={receipt['status']} "
+                f"result={receipt['result_path']}",
+                flush=True,
+            )
+
+    suite = {
+        "schema_version": "fastwam-rmbench-evaluation-suite-v1",
+        "tasks": list(args.tasks),
+        "checkpoint_step_requested": args.step,
+        "jobs_per_gpu": args.jobs_per_gpu,
+        "max_attempts": args.max_attempts,
+        "launch_stagger_seconds": args.launch_stagger_seconds,
+        "results": results,
+        "succeeded": all(item.get("status") == "succeeded" for item in results.values()),
+    }
+    suite_path = root / "evaluation" / "evaluation_suite_receipt.json"
+    suite_path.write_text(json.dumps(suite, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    print(json.dumps(suite, indent=2, sort_keys=True))
+    if not suite["succeeded"]:
+        raise SystemExit(1)
+
+
+if __name__ == "__main__":
+    main()
