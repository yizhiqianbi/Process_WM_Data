+    assert rectified.tolist() == [False, False, False, False]
+    restored = ((video[:, 0] + 1.0) * 127.5).round().to(torch.uint8)
+    assert [
+        int(restored[0, 0, 0]),
+        int(restored[0, 0, 319]),
+        int(restored[0, 383, 0]),
