+export PYTHONPATH="${FASTWAM_ROOT}/experiments/robotwin:${FASTWAM_ROOT}/src:${FASTWAM_ROOT}:${RMBENCH_ROOT}/policy:${RMBENCH_ROOT}:${PYTHONPATH:-}"
+export DIFFSYNTH_MODEL_BASE_PATH="${DIFFSYNTH_MODEL_BASE_PATH:-${FASTWAM_ROOT}/checkpoints}"
+
+if ! "${RMBENCH_PYTHON}" - <<'PY'
+import sapien
+
+print(f"RMBench renderer preflight: SAPIEN {getattr(sapien, '__version__', 'unknown')}")
+PY
+then
+  echo "SAPIEN failed under the configured Mesa/EGL environment." >&2
+  exit 1
+fi
+
+"${FASTWAM_PYTHON}" script/policy_model_server.py \
+  --port "${PORT}" \
