@@ -0,0 +1,109 @@
+"""Resolve machine-specific paths in Curobo robot configuration files."""
+
+from __future__ import annotations
+
+import hashlib
+import os
+import tempfile
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+
+_FILE_FIELDS = ("urdf_path", "collision_spheres", "usd_path")
+
+
+def _resolve_asset_path(value: str, *, source: Path, repository_root: Path) -> Path:
+    expanded = value.replace("${ASSETS_PATH}", str(repository_root))
+    expanded = os.path.expanduser(os.path.expandvars(expanded))
+    candidate = Path(expanded)
+    if candidate.exists():
+        return candidate.resolve()
+
+    marker = "/assets/"
+    normalized = expanded.replace("\\", "/")
+    if marker in normalized:
+        relative = normalized.split(marker, 1)[1]
+        candidate = repository_root / "assets" / relative
+    elif candidate.is_absolute():
+        candidate = repository_root / candidate.name
+    else:
+        candidate = source.parent / candidate
+    return candidate.resolve()
+
+
+def resolve_curobo_config(
+    source_path: str | os.PathLike[str],
+    repository_root: str | os.PathLike[str],
+    *,
+    runtime_root: str | os.PathLike[str] | None = None,
+) -> str:
+    """Return a portable Curobo config path with all referenced assets validated."""
+    source = Path(source_path).expanduser().resolve()
+    root = Path(repository_root).expanduser().resolve()
+    if not source.is_file():
+        raise FileNotFoundError(f"Curobo config does not exist: {source}")
+
+    payload: dict[str, Any] = yaml.safe_load(source.read_text(encoding="utf-8"))
+    try:
+        kinematics = payload["robot_cfg"]["kinematics"]
+    except (KeyError, TypeError) as exc:
+        raise ValueError(f"Invalid Curobo config structure: {source}") from exc
+
+    changed = False
+    missing: list[str] = []
+    for field in _FILE_FIELDS:
+        value = kinematics.get(field)
+        if not value or value == "FILL_THIS":
+            continue
+        resolved = _resolve_asset_path(str(value), source=source, repository_root=root)
+        if not resolved.is_file():
+            missing.append(f"{field}={resolved}")
+            continue
+        resolved_value = str(resolved)
+        if resolved_value != value:
+            kinematics[field] = resolved_value
+            changed = True
+
+    asset_root = kinematics.get("asset_root_path")
+    if asset_root:
+        resolved_root = _resolve_asset_path(
+            str(asset_root), source=source, repository_root=root
+        )
+        if not resolved_root.is_dir():
+            missing.append(f"asset_root_path={resolved_root}")
+        elif str(resolved_root) != asset_root:
+            kinematics["asset_root_path"] = str(resolved_root)
+            changed = True
+
+    if missing:
+        raise FileNotFoundError(
+            f"Curobo config {source} references missing assets: {', '.join(missing)}"
+        )
+    if not changed:
+        return str(source)
+
+    digest = hashlib.sha256(
+        (str(source) + "\0" + str(root) + "\0" + source.read_text(encoding="utf-8")).encode(
+            "utf-8"
+        )
+    ).hexdigest()[:12]
+    base = (
+        Path(runtime_root).expanduser().resolve()
+        if runtime_root is not None
+        else Path(tempfile.gettempdir()) / f"rmbench-curobo-{os.getuid()}"
+    )
+    try:
+        relative_parent = source.parent.relative_to(root)
+    except ValueError:
+        relative_parent = Path(source.parent.name)
+    output_dir = base / digest / relative_parent
+    output_dir.mkdir(parents=True, exist_ok=True)
+    output = output_dir / f"{source.stem}-resolved.yml"
+    temporary = output.with_suffix(output.suffix + f".{os.getpid()}.tmp")
+    temporary.write_text(
+        yaml.safe_dump(payload, sort_keys=False), encoding="utf-8"
+    )
+    os.replace(temporary, output)
+    return str(output)
